---
import EsProductLayout from '../../../../layouts/EsProductLayout.astro';
---

<EsProductLayout title="ST-E Serie Barra de Iones Inteligente | DGSDK"
  description="Barra de iones inteligente compacta, con eliminación de estática estable y fiable para ensamblaje electrónico, cintas transportadoras y líneas industriales de precisión."
  image="/assets/img/static-eliminator/st-e-series.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/es/">Inicio</a>
        <span>/</span>
        <a href="/es/products">Productos</a>
        <span>/</span>
        <a href="/es/products/static-eliminator">Eliminadores de Estática</a>
        <span>/</span>
        <span>ST-E Serie Barra de Iones Inteligente</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/static-eliminator/st-e.jpg"
              alt="ST-E Serie Barra de Iones Inteligente"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/static-eliminator/st-e.jpg"
              alt="ST-E Thumbnail 1"
              data-full="/assets/img/static-eliminator/st-e.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>ST-E Serie Barra de Iones Inteligente</h1>
          <p class="product-short-desc">
            Barra de iones inteligente compacta, con eliminación de estática estable y fiable para ensamblaje electrónico, cintas transportadoras y líneas industriales de precisión.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Solicitar Cotización</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Diseño Compacto</h4>
              <p>Cuerpo pequeño para una integración sencilla en todo tipo de equipos industriales.</p>
            </div>
            <div class="highlight-item">
              <h4>Neutralización Estable</h4>
              <p>Salida de iones eficiente para una eliminación de estática continua y constante.</p>
            </div>
            <div class="highlight-item">
              <h4>Instalación Sencilla</h4>
              <p>Estructura simple para una instalación rápida en cintas transportadoras y equipos.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Descripción del Producto</h2>
        <p>
          La barra de iones inteligente ST-E está diseñada para el control de estática en línea, ayudando a eliminar cargas electrostáticas en cintas transportadoras, líneas de producción y superficies de piezas.
        </p>
        <p>
          Adecuada para ensamblaje electrónico, SMT, películas ópticas y entornos industriales que requieren un control preciso de la estática.
        </p>
      </section>

      <section class="detail-block">
        <h2>Características del Producto</h2>
        <ul class="feature-list">
          <li>Eliminación de estática en línea para cintas transportadoras y líneas de producción</li>
          <li>Estructura compacta con integración conveniente</li>
          <li>Salida de iones estable y control de estática fiable</li>
          <li>Adecuada para aplicaciones electrónicas e industriales de precisión</li>
          <li>Diseño duradero para operación industrial prolongada</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Ventajas Técnicas</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Integración Compacta</h3>
            <p>Perfil compacto que facilita la instalación en cintas transportadoras y equipos industriales variados.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>Neutralización Estable</h3>
            <p>Salida de iones continua y constante para un control eficaz de la estática durante el proceso de producción.</p>
          </div>
          <div class="advantage-card green">
            <h3>Fiable y Duradero</h3>
            <p>Diseño industrial para una operación estable y prolongada en entornos de producción continua.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Sectores de Aplicación</h2>
        <div class="application-tags">
          <span>Fabricación Electrónica</span>
          <span>Producción SMT</span>
          <span>Películas Ópticas</span>
          <span>Ensamblaje de Precisión</span>
          <span>Embalaje</span>
          <span>Líneas de Producción Automatizadas</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="st-e-series">
          <div class="related-slider-header">
            <h2>Productos Relacionados</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/es/products/static-eliminator/st-g-series" class="related-slide-card" data-key="st-g-series">
              <img src="/assets/img/static-eliminator/st-g.jpg" alt="ST-G Serie Barra de Iones Inteligente" loading="lazy" />
              <h4>ST-G Serie Barra de Iones Inteligente</h4>
            </a>
            <a href="/es/products/static-eliminator/st-e-series" class="related-slide-card" data-key="st-e-series">
              <img src="/assets/img/static-eliminator/st-e.jpg" alt="ST-E Serie Barra de Iones Inteligente" loading="lazy" />
              <h4>ST-E Serie Barra de Iones Inteligente</h4>
            </a>
            <a href="/es/products/static-eliminator/st-f-series" class="related-slide-card" data-key="st-f-series">
              <img src="/assets/img/static-eliminator/st-f.jpg" alt="ST-F Serie Barra de Iones Inteligente" loading="lazy" />
              <h4>ST-F Serie Barra de Iones Inteligente</h4>
            </a>
            <a href="/es/products/static-eliminator/st-s200" class="related-slide-card" data-key="st-s200">
              <img src="/assets/img/static-eliminator/st-s200.jpg" alt="ST-S200 Soplador de Iones Compacto" loading="lazy" />
              <h4>ST-S200 Soplador de Iones Compacto</h4>
            </a>
            <a href="/es/products/static-eliminator/st-101a" class="related-slide-card" data-key="st-101a">
              <img src="/assets/img/static-eliminator/st-101a.webp" alt="ST101A Soplador de Iones de Sobremesa" loading="lazy" />
              <h4>ST101A Soplador de Iones de Sobremesa</h4>
            </a>
            <a href="/es/products/static-eliminator/st-104a" class="related-slide-card" data-key="st-104a">
              <img src="/assets/img/static-eliminator/st-104a.jpg" alt="ST104A Soplador de Iones Horizontal" loading="lazy" />
              <h4>ST104A Soplador de Iones Horizontal</h4>
            </a>
            <a href="/es/products/static-eliminator/st-1200" class="related-slide-card" data-key="st-1200">
              <img src="/assets/img/static-eliminator/st-1200.jpg" alt="ST1200 Soplador de Iones Horizontal" loading="lazy" />
              <h4>ST1200 Soplador de Iones Horizontal</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</EsProductLayout>
