---
import EsLayout from '../../../layouts/EsLayout.astro';
---

<EsLayout
  title="Productos | DGSDK"
  description="Línea completa de productos industriales DGSDK: sistemas eliminadores de estática, máquinas limpiadoras industriales, piezas CNC de precisión y equipos de automatización, para electrónica, SMT, películas ópticas y fabricación de precisión."
  canonical="https://www.dg-sdk.com/es/products"
>
  <section
    class="products-hero"
    style="background: linear-gradient(rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.18)), url('/assets/img/all-products/all-products.jpg') center/cover no-repeat;"
  >
    <div class="container products-hero-inner">
      <span class="products-hero-kicker">Catálogo de productos DGSDK</span>
      <h1>Línea completa de productos de automatización industrial</h1>
      <p>
        Sistemas eliminadores de estática, máquinas limpiadoras industriales, piezas CNC de precisión y equipos de automatización, para electrónica, SMT, películas ópticas y fabricación de precisión.
      </p>
    </div>
  </section>

  <section class="products-overview-section">
    <div class="container products-overview-layout">
      <aside class="products-sidebar">
        <div class="products-sidebar-box">
          <h3>Categorías</h3>
          <a href="/es/products" class="active-category">Todos los productos</a>
          <a href="/es/products/static-eliminator">Sistemas eliminadores de estática</a>
          <a href="/es/products/cleaning-machine">Máquinas limpiadoras industriales</a>
          <a href="/es/products/precision-machined-parts">Piezas mecanizadas de precisión</a>
          <a href="/es/products/automation">Equipos de automatización</a>
        </div>
      </aside>

      <div class="products-main">
        <!-- Sistemas eliminadores de estática -->
        <div class="products-category-block">
          <div class="products-category-header">
            <h2>Sistemas eliminadores de estática</h2>
            <a href="/es/products/static-eliminator" class="products-category-link">Ver todos →</a>
          </div>
          <section class="apple-product-section">
            <div class="apple-card-grid">
              <a href="/es/products/static-eliminator/st-g-series" class="apple-product-card">
                <img src="/assets/img/static-eliminator/st-g.jpg" alt="ST-G Series Smart Ionizing Bar" loading="lazy" />
                <span class="apple-card-tag">Eliminador de estática</span>
                <h3>ST-G Series Smart Ionizing Bar</h3>
                <p>Barra ionizadora de alto rendimiento para una eliminación de estática estable y eficiente.</p>
              </a>
              <a href="/es/products/static-eliminator/st-e-series" class="apple-product-card">
                <img src="/assets/img/static-eliminator/st-e.jpg" alt="ST-E Series Smart Ionizing Bar" loading="lazy" />
                <span class="apple-card-tag">Eliminador de estática</span>
                <h3>ST-E Series Smart Ionizing Bar</h3>
                <p>Control de estática confiable para integración industrial compacta.</p>
              </a>
              <a href="/es/products/static-eliminator/st-f-series" class="apple-product-card">
                <img src="/assets/img/static-eliminator/st-f.jpg" alt="ST-F Series Smart Ionizing Bar" loading="lazy" />
                <span class="apple-card-tag">Eliminador de estática</span>
                <h3>ST-F Series Smart Ionizing Bar</h3>
                <p>Solución de ionización de respuesta rápida para líneas de producción continua.</p>
              </a>
              <a href="/es/products/static-eliminator/st-s200" class="apple-product-card">
                <img src="/assets/img/static-eliminator/st-s200.jpg" alt="ST-S200 Mini Ion Blower" loading="lazy" />
                <span class="apple-card-tag">Eliminador de estática</span>
                <h3>ST-S200 Mini Ion Blower</h3>
                <p>Soplador antiestático compacto para estaciones de trabajo y aplicaciones sensibles.</p>
              </a>
            </div>
          </section>
        </div>

        <!-- Máquinas limpiadoras industriales -->
        <div class="products-category-block">
          <div class="products-category-header">
            <h2>Máquinas limpiadoras industriales</h2>
            <a href="/es/products/cleaning-machine" class="products-category-link">Ver todas →</a>
          </div>
          <section class="apple-product-section">
            <div class="apple-card-grid">
              <a href="/es/products/cleaning-machine/polarizer-cleaner" class="apple-product-card">
                <img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="Polarizer Precision Cleaner" loading="lazy" />
                <span class="apple-card-tag">Limpiadora</span>
                <h3>Polarizer Precision Cleaner</h3>
                <p>Diseñada para una limpieza estable y confiable de superficies de polarizadores sensibles.</p>
              </a>
              <a href="/es/products/cleaning-machine/fpc-4-axis-cleaner" class="apple-product-card">
                <img src="/assets/img/cleaning-machine/fpc-4-axis-cleaner.jpg" alt="FPC 4-Axis High Precision Cleaner" loading="lazy" />
                <span class="apple-card-tag">Limpiadora</span>
                <h3>FPC 4-Axis High Precision Cleaner</h3>
                <p>Sistema de limpieza de alta precisión para aplicaciones de circuitos flexibles.</p>
              </a>
              <a href="/es/products/cleaning-machine/smt-cleaner" class="apple-product-card">
                <img src="/assets/img/cleaning-machine/smt-cleaner.jpg" alt="SMT Inline Cleaner" loading="lazy" />
                <span class="apple-card-tag">Limpiadora</span>
                <h3>SMT Inline Cleaner</h3>
                <p>Limpieza en línea para procesos SMT y líneas de ensamble de precisión.</p>
              </a>
              <a href="/es/products/cleaning-machine/pcb-cleaner" class="apple-product-card">
                <img src="/assets/img/cleaning-machine/pcb-cleaner.jpg" alt="PCB Surface Cleaner" loading="lazy" />
                <span class="apple-card-tag">Limpiadora</span>
                <h3>PCB Surface Cleaner</h3>
                <p>Limpieza estable de superficies para las fases de fabricación e inspección de PCB.</p>
              </a>
            </div>
          </section>
        </div>

        <!-- Piezas mecanizadas de precisión -->
        <div class="products-category-block">
          <div class="products-category-header">
            <h2>Piezas mecanizadas de precisión</h2>
            <a href="/es/products/precision-machined-parts" class="products-category-link">Ver todas →</a>
          </div>
          <section class="apple-product-section">
            <div class="apple-card-grid">
              <a href="/es/products/precision-machined-parts/custom-precision-machined-parts" class="apple-product-card">
                <img src="/assets/img/precision-machined-parts/precision-machined-parts.jpg" alt="Custom Precision Machined Parts" loading="lazy" />
                <span class="apple-card-tag">Piezas de precisión</span>
                <h3>Custom Precision Machined Parts</h3>
                <p>Piezas CNC de alta precisión según planos y especificaciones del cliente.</p>
              </a>
              <a href="/es/products/precision-machined-parts/precision-bearing-bracket-cnc-milled" class="apple-product-card">
                <img src="/assets/img/precision-machined-parts/precision-bearing-bracket-cnc-milled.jpg" alt="Precision Bearing Bracket CNC Milled" loading="lazy" />
                <span class="apple-card-tag">Piezas de precisión</span>
                <h3>Precision Bearing Bracket (CNC Milled)</h3>
                <p>Soporte de rodamiento fresado en CNC de alta precisión con tolerancias estables y confiables.</p>
              </a>
            </div>
          </section>
        </div>

        <!-- Equipos de automatización -->
        <div class="products-category-block">
          <div class="products-category-header">
            <h2>Equipos de automatización</h2>
            <a href="/es/products/automation" class="products-category-link">Ver todos →</a>
          </div>
          <section class="apple-product-section">
            <div class="apple-card-grid">
              <a href="/es/products/automation/product-a" class="apple-product-card">
                <img src="/assets/img/automation/product-a.jpg" alt="Diffuser Plate Cleaning Inspection Line" loading="lazy" />
                <span class="apple-card-tag">Automatización</span>
                <h3>Diffuser Plate Cleaning Inspection Line</h3>
                <p>Línea de producción automatizada que integra limpieza, inspección y transporte continuo.</p>
              </a>
              <a href="/es/products/automation/product-b" class="apple-product-card">
                <img src="/assets/img/automation/product-b.jpg" alt="Robotic Auto Load/Unload Washer" loading="lazy" />
                <span class="apple-card-tag">Automatización</span>
                <h3>Robotic Auto Load/Unload Washer</h3>
                <p>Integración robótica con carga/descarga automática para alta eficiencia de lavado.</p>
              </a>
              <a href="/es/products/automation/product-c" class="apple-product-card">
                <img src="/assets/img/automation/product-c.jpg" alt="Polarizer Absorption Axis Angle Measurement System" loading="lazy" />
                <span class="apple-card-tag">Automatización</span>
                <h3>Polarizer Absorption Axis Angle Measurement</h3>
                <p>Sistema de detección automática de alta precisión para ángulos de eje de absorción de polarizadores.</p>
              </a>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>

  <style>
    .products-category-block {
      margin-bottom: 60px;
    }
    .products-category-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 24px;
      padding-bottom: 14px;
      border-bottom: 2px solid #f0f0f0;
    }
    .products-category-header h2 {
      font-size: 1.6rem;
      font-weight: 800;
      color: #111;
      margin: 0;
    }
    .products-category-link {
      font-size: 0.95rem;
      font-weight: 600;
      color: #0071e3;
      text-decoration: none;
    }
    .products-category-link:hover {
      text-decoration: underline;
    }
  </style>
</EsLayout>
