---
import EsLayout from '../../../../layouts/EsLayout.astro';
---

<EsLayout
  title="Máquinas limpiadoras industriales | DGSDK"
  description="Máquinas limpiadoras industriales DGSDK: limpiadoras de polarizadores, limpiadoras de FPC, limpiadoras de PCB, limpiadoras SMT, limpiadoras de películas ópticas, limpiadoras LCM y más para fabricación de precisión."
  canonical="https://www.dg-sdk.com/es/products/cleaning-machine"
>
  <section
    class="products-hero"
    style="background: linear-gradient(rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.18)), url('/assets/img/cleaning-machine/cnc.jpg') center/cover no-repeat;"
  >
    <div class="container products-hero-inner">
      <span class="products-hero-kicker">Línea de productos DGSDK</span>
      <h1>Máquinas limpiadoras industriales</h1>
      <p>
        Soluciones de limpieza industrial para aplicaciones de PCB, FPC, polarizadores, retroiluminación, películas ópticas, SMT, LCM y otras aplicaciones de fabricación de precisión.
      </p>
    </div>
  </section>

  <section class="products-overview-section">
    <div class="container products-overview-layout">
      <aside class="products-sidebar">
        <div class="products-sidebar-box">
          <h3>Categorías</h3>
          <a href="/es/products">Todos los productos</a>
          <a href="/es/products/static-eliminator">Sistemas eliminadores de estática</a>
          <a href="/es/products/cleaning-machine" class="active-category">Máquinas limpiadoras industriales</a>
          <a href="/es/products/precision-machined-parts">Piezas mecanizadas de precisión</a>
          <a href="/es/products/automation">Equipos de automatización</a>
        </div>
      </aside>

      <div class="products-main">
        <section class="apple-product-section">
          <div class="apple-card-grid">
            <a href="/es/products/cleaning-machine/polarizer-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="Limpiadora de precisión para polarizadores" loading="lazy" />
              <span class="apple-card-tag">Limpiadora</span>
              <h3>Limpiadora de precisión para polarizadores</h3>
              <p>Diseñada para el tratamiento estable y seguro de superficies de polarizadores sensibles.</p>
            </a>

            <a href="/es/products/cleaning-machine/fpc-4-axis-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/fpc-4-axis-cleaner.jpg" alt="Limpiadora FPC de alta precisión de 4 ejes" loading="lazy" />
              <span class="apple-card-tag">Limpiadora</span>
              <h3>Limpiadora FPC de alta precisión de 4 ejes</h3>
              <p>Sistema de limpieza de alta precisión para aplicaciones de circuitos impresos flexibles.</p>
            </a>

            <a href="/es/products/cleaning-machine/fpc-8-axis-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/fpc-8-axis-cleaner.jpg" alt="Limpiadora FPC de alto rendimiento de 8 ejes" loading="lazy" />
              <span class="apple-card-tag">Limpiadora</span>
              <h3>Limpiadora FPC de alto rendimiento de 8 ejes</h3>
              <p>Plataforma de limpieza multieje avanzada para flujos de trabajo de producción exigentes.</p>
            </a>

            <a href="/es/products/cleaning-machine/optical-film-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/optical.jpg" alt="Limpiadora de películas ópticas de gran formato" loading="lazy" />
              <span class="apple-card-tag">Limpiadora</span>
              <h3>Limpiadora de películas ópticas de gran formato</h3>
              <p>Equipo de limpieza de superficies industrial para aplicaciones de películas ópticas de gran área.</p>
            </a>

            <a href="/es/products/cleaning-machine/lcm-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/lcm-cleaner.jpg" alt="Limpiadora industrial para módulos LCM" loading="lazy" />
              <span class="apple-card-tag">Limpiadora</span>
              <h3>Limpiadora industrial para módulos LCM</h3>
              <p>Sistema de limpieza industrial para el procesamiento de módulos y líneas de ensamblaje de pantallas.</p>
            </a>

            <a href="/es/products/cleaning-machine/pcb-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/pcb-cleaner.jpg" alt="Limpiadora de superficies PCB" loading="lazy" />
              <span class="apple-card-tag">Limpiadora</span>
              <h3>Limpiadora de superficies PCB</h3>
              <p>Equipo estable de limpieza de superficies para procesos de fabricación e inspección de PCB.</p>
            </a>

            <a href="/es/products/cleaning-machine/pcb-vertical-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/stick-pcb-vertical-cleaning-machine.jpg" alt="Sistema de limpieza vertical para PCB" loading="lazy" />
              <span class="apple-card-tag">Limpiadora</span>
              <h3>Sistema de limpieza vertical para PCB</h3>
              <p>Diseño de limpieza vertical que apoya eficientemente el flujo de procesos PCB.</p>
            </a>

            <a href="/es/products/cleaning-machine/roll-chip-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/roll-chip-cleaner.jpg" alt="Limpiadora universal de rodillos" loading="lazy" />
              <span class="apple-card-tag">Limpiadora</span>
              <h3>Limpiadora universal de rodillos</h3>
              <p>Solución de limpieza versátil para el manejo de rodillos y materiales de precisión.</p>
            </a>

            <a href="/es/products/cleaning-machine/smt-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/smt-cleaner.jpg" alt="Limpiadora en línea SMT" loading="lazy" />
              <span class="apple-card-tag">Limpiadora</span>
              <h3>Limpiadora en línea SMT</h3>
              <p>Equipo de apoyo para limpieza en línea en procesos SMT y líneas de ensamblaje de precisión.</p>
            </a>

            <a href="/es/products/cleaning-machine/backlight-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/backlight-cleaner.jpg" alt="Limpiadora de retroiluminación" loading="lazy" />
              <span class="apple-card-tag">Limpiadora</span>
              <h3>Limpiadora de retroiluminación</h3>
              <p>Equipo de limpieza de precisión para entornos de producción de retroiluminación.</p>
            </a>

            <a href="/es/products/cleaning-machine/ccl-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/ccl-cleaner.jpg" alt="DGSDK Limpiadora CCL ST DT1340" loading="lazy" />
              <span class="apple-card-tag">Limpiadora</span>
              <h3>DGSDK Limpiadora CCL ST DT1340</h3>
              <p>Soporte de limpieza estable para líneas de fabricación en industrias relacionadas con CCL.</p>
            </a>

            <a href="/es/products/cleaning-machine/inspection-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/inspection-cleaner.jpg" alt="Limpiadora de mesa de inspección (serie STXT)" loading="lazy" />
              <span class="apple-card-tag">Limpiadora</span>
              <h3>Limpiadora de mesa de inspección (serie STXT)</h3>
              <p>Soporte integrado de inspección y limpieza para flujos de trabajo de producción de precisión.</p>
            </a>
          </div>
        </section>
      </div>
    </div>
  </section>
</EsLayout>
