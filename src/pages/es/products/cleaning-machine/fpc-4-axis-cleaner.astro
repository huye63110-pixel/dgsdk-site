              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/es/products/cleaning-machine/polarizer-cleaner" class="related-slide-card" data-key="polarizer-cleaner">
              <img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="Máquina de Limpieza de Precisión para Polarizadores" loading="lazy" />
              <h4>Máquina de Limpieza de Precisión para Polarizadores</h4>
            </a>
            <a href="/es/products/cleaning-machine/fpc-4-axis-cleaner" class="related-slide-card" data-key="fpc-4-axis-cleaner">
              <img src="/assets/img/cleaning-machine/fpc-4-axis-cleaner.jpg" alt="Máquina de Limpieza FPC de 4 Ejes" loading="lazy" />
              <h4>Máquina de Limpieza FPC de 4 Ejes</h4>
            </a>
            <a href="/es/products/cleaning-machine/fpc-8-axis-cleaner" class="related-slide-card" data-key="fpc-8-axis-cleaner">
              <img src="/assets/img/cleaning-machine/fpc-8-axis-cleaner.jpg" alt="Máquina de Limpieza FPC de 8 Ejes Premium" loading="lazy" />
              <h4>Máquina de Limpieza FPC de 8 Ejes Premium</h4>
            </a>
            <a href="/es/products/cleaning-machine/optical-film-cleaner" class="related-slide-card" data-key="optical-film-cleaner">
              <img src="/assets/img/cleaning-machine/optical.jpg" alt="Máquina de Limpieza de Películas Ópticas de Gran Formato" loading="lazy" />
              <h4>Máquina de Limpieza de Películas Ópticas de Gran Formato</h4>
            </a>
            <a href="/es/products/cleaning-machine/lcm-cleaner" class="related-slide-card" data-key="lcm-cleaner">
              <img src="/assets/img/cleaning-machine/lcm-cleaner.jpg" alt="Máquina de Limpieza Industrial para Módulos LCM" loading="lazy" />
              <h4>Máquina de Limpieza Industrial para Módulos LCM</h4>
            </a>
            <a href="/es/products/cleaning-machine/pcb-cleaner" class="related-slide-card" data-key="pcb-cleaner">
