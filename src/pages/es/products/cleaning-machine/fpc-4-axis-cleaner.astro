            </a>
            <a href="/es/products/cleaning-machine/pcb-vertical-cleaner" class="related-slide-card" data-key="pcb-vertical-cleaner">
              <img src="/assets/img/cleaning-machine/stick-pcb-vertical-cleaning-machine.jpg" alt="Sistema de Limpieza Vertical para PCB" loading="lazy" />
              <h4>Sistema de Limpieza Vertical para PCB</h4>
            </a>
            <a href="/es/products/cleaning-machine/roll-chip-cleaner" class="related-slide-card" data-key="roll-chip-cleaner">
              <img src="/assets/img/cleaning-machine/roll-chip-cleaner.jpg" alt="Máquina de Limpieza Universal por Rodillo" loading="lazy" />
              <h4>Máquina de Limpieza Universal por Rodillo</h4>
            </a>
            <a href="/es/products/cleaning-machine/smt-cleaner" class="related-slide-card" data-key="smt-cleaner">
              <img src="/assets/img/cleaning-machine/smt-cleaner.jpg" alt="Máquina de Limpieza en Línea SMT" loading="lazy" />
              <h4>Máquina de Limpieza en Línea SMT</h4>
            </a>
            <a href="/es/products/cleaning-machine/backlight-cleaner" class="related-slide-card" data-key="backlight-cleaner">
              <img src="/assets/img/cleaning-machine/backlight-cleaner.jpg" alt="Máquina de Limpieza para Placas de Retroiluminación" loading="lazy" />
              <h4>Máquina de Limpieza para Placas de Retroiluminación</h4>
            </a>
            <a href="/es/products/cleaning-machine/ccl-cleaner" class="related-slide-card" data-key="ccl-cleaner">
              <img src="/assets/img/cleaning-machine/ccl-cleaner.jpg" alt="Máquina de Limpieza CCL Stick" loading="lazy" />
              <h4>Máquina de Limpieza CCL Stick</h4>
            </a>
            <a href="/es/products/cleaning-machine/inspection-cleaner" class="related-slide-card" data-key="inspection-cleaner">
              <img src="/assets/img/cleaning-machine/inspection-cleaner.jpg" alt="Máquina de Limpieza para Mesa de Inspección" loading="lazy" />
              <h4>Máquina de Limpieza para Mesa de Inspección</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</EsProductLayout>
