---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Static Elimination Systems | DGSDK">
  <section
    class="products-hero"
    style="background: linear-gradient(rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.18)), url('/assets/img/header-bg.jpg') center/cover no-repeat;"
  >
    <div class="container products-hero-inner">
      <span class="products-hero-kicker">DGSDK Product Portfolio</span>
      <h1>Static Elimination Systems</h1>
      <p>
        Professional electrostatic control solutions for electronics, SMT,
        packaging, printing, textile, plastics, and automated industrial production lines.
      </p>
    </div>
  </section>

  <section class="products-overview-section">
    <div class="container products-overview-layout">
      <aside class="products-sidebar">
        <div class="products-sidebar-box">
          <h3>Browse Categories</h3>
          <a href="/products">All Products</a>
          <a href="/products/static-eliminator" class="active-category">Static Elimination Systems</a>
          <a href="/products/cleaning-machine">Cleaning Machine</a>
          <a href="/products/precision-machined parts">Precision Machined Parts</a>
          <a href="/products/automation">Automation Equipment</a>
        </div>
      </aside>

      <div class="products-main">
        <section class="apple-product-section">
          <div class="apple-card-grid">
            <a href="/products/static-eliminator/st-g-series" class="apple-product-card">
              <img src="/assets/img/static-eliminator/ST-G.jpg" alt="ST-G Intelligent Static Elimination Bar" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST-G Intelligent Static Elimination Bar</h3>
              <p>High-performance ion bar for stable and efficient static removal.</p>
            </a>

            <a href="/products/static-eliminator/st-e-series" class="apple-product-card">
              <img src="/assets/img/static-eliminator/ST-E.jpg" alt="ST-E Intelligent Ion Rod" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST-E Intelligent Ion Rod</h3>
              <p>Reliable electrostatic control for compact industrial integration.</p>
            </a>

            <a href="/products/static-eliminator/st-f-series" class="apple-product-card">
              <img src="/assets/img/static-eliminator/ST-F.jpg" alt="ST-F Intelligent Ion Rod" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST-F Intelligent Ion Rod</h3>
              <p>Fast-response ionizing solution for continuous production lines.</p>
            </a>

            <a href="/products/static-eliminator/st-s200" class="apple-product-card">
              <img src="/assets/img/static-eliminator/ST-S200.jpg" alt="ST-S200 Mini Ionizer Fan" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST-S200 Mini Ionizer Fan</h3>
              <p>Compact anti-static fan for workstations and sensitive applications.</p>
            </a>

            <a href="/products/static-eliminator/st-101a" class="apple-product-card">
              <img src="/assets/img/static-eliminator/ST-101A.jpg" alt="ST101A Desktop Ion Fan" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST101A Desktop Ion Fan</h3>
              <p>Desktop anti-static fan solution for stable workstation performance.</p>
            </a>

            <a href="/products/static-eliminator/st-104a" class="apple-product-card">
              <img src="/assets/img/static-eliminator/ST-104A.jpg" alt="ST104A Horizontal Ion Blower" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST104A Horizontal Ion Blower</h3>
              <p>Horizontal ion blowing support for larger anti-static coverage zones.</p>
            </a>

            <a href="/products/static-eliminator/st-1200" class="apple-product-card">
              <img src="/assets/img/static-eliminator/ST-1200.jpg" alt="ST1200 Horizontal Ion Fan" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST1200 Horizontal Ion Fan</h3>
              <p>Wide-area electrostatic control for industrial workstations and lines.</p>
            </a>
          </div>
        </section>
      </div>
    </div>
  </section>
</Layout>