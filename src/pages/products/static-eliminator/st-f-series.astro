---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="ST-F Series Ion Bar | DGSDK"
  description="ST-F Series industrial ionizing bar for static control in wide-area applications including film, optical, and electronics manufacturing."
  image="/assets/img/static-eliminator/st-f-series.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/static-eliminator">Static Eliminator</a>
        <span>/</span>
        <span>ST-F Series</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/static-eliminator/st-f.jpg"
              alt="ST-F Series Intelligent Ion Bar"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/static-eliminator/st-f.jpg"
              alt="ST-F Series Thumbnail"
              data-full="/assets/img/static-eliminator/st-f.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>ST-F Series Intelligent Ion Bar</h1>
          <p class="product-short-desc">
            ST-F Series intelligent ion rod — DC high voltage ±5kV, up to 400mm elimination
            distance, ±10V ion balance, fast response for continuous production lines,
            CE certified.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Up to 400mm Range</h4>
              <p>Long elimination distance with powerful airflow for larger coverage areas.</p>
            </div>
            <div class="highlight-item">
              <h4>Fast Response</h4>
              <p>Ideal for continuous production lines requiring rapid static neutralization.</p>
            </div>
            <div class="highlight-item">
              <h4>DC High Voltage ±5kV</h4>
              <p>Excellent static elimination performance with ±10V ion balance accuracy.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          The ST-F Series intelligent ion rod produces positive and negative ions through a DC high
          voltage (±5kV) generation device, delivering long-distance static elimination with powerful
          airflow — up to 400mm effective range. Its fast response makes it ideal for continuous
          production lines requiring rapid static neutralization.
        </p>
        <p>
          The self-diagnostic circuit continuously monitors operation with overcurrent protection
          for safe, reliable long-term use. With ±10V or better ion balance and CE certification,
          the ST-F Series is suited for electronics manufacturing, printing, optical film processing,
          SMT production, and high-speed production lines.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>Produces positive and negative ions via DC high voltage to eliminate surface static</li>
          <li>Long elimination distance with powerful airflow</li>
          <li>DC high voltage generation device with excellent static elimination performance</li>
          <li>Self-diagnostic circuit with overcurrent protection</li>
          <li>Fast response — ideal for continuous production lines requiring rapid static neutralization</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>400mm Range</h3>
            <p>Long elimination distance with powerful airflow covers larger production areas.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>Fast Response</h3>
            <p>Rapid neutralization supports high-speed continuous production line requirements.</p>
          </div>
          <div class="advantage-card green">
            <h3>±10V Balance</h3>
            <p>Precise ion balance prevents surface over-charging for consistent product quality.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr><td>Model</td><td>ST-F Series (multiple variants)</td></tr>
            <tr><td>Power Supply</td><td>DC 24V</td></tr>
            <tr><td>Output Voltage</td><td>±5kV (DC high voltage)</td></tr>
            <tr><td>Ion Balance</td><td>±10V or better</td></tr>
            <tr><td>Static Elimination Distance</td><td>Up to 400mm</td></tr>
            <tr><td>Working Temperature</td><td>0~50°C</td></tr>
            <tr><td>Working Humidity</td><td>35~85% RH</td></tr>
            <tr><td>Protection</td><td>Self-diagnostic circuit, overcurrent protection</td></tr>
            <tr><td>Certification</td><td>CE certified</td></tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>Electronics Manufacturing</span>
          <span>Printing</span>
          <span>Optical Film</span>
          <span>SMT Production</span>
          <span>High-Speed Production Lines</span>
        </div>
      </section>


      <section class="detail-block">
        <h2>Application Scenarios</h2>
        <div class="scenario-list">
          <div class="scenario-item">
            <h3>Wide-Gap Conveyor Installations</h3>
            <p>Some production lines cannot position an ion bar within the standard 30–200 mm range due to mechanical constraints — product height variation, safety guarding, or tooling clearance. The ST-F Series solves this with an effective elimination distance of up to 400 mm, allowing the bar to be installed at a safe distance while still delivering effective static neutralization across the full material width.</p>
          </div>
          <div class="scenario-item">
            <h3>Optical Film and Display Panel Lines</h3>
            <p>Optical films, polarizer sheets, and glass substrates in display manufacturing are highly sensitive to particulate contamination. Static charge builds up rapidly as these materials move at high speed. The ST-F Series provides long-distance ionization that neutralizes charge before the material reaches critical processing stations, without requiring the bar to be positioned uncomfortably close to delicate surfaces.</p>
          </div>
          <div class="scenario-item">
            <h3>High-Speed Web and Printing Processes</h3>
            <p>In web printing and coating, the bar must often be installed away from the substrate to avoid mechanical contact at high speeds. The ST-F Series' 400 mm reach means it can be mounted safely within the machine structure while still delivering full-width static control across the web.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>How to Choose the Right Ion Bar</h2>
        <p>Choose the ST-F Series when your installation gap exceeds the range of a standard ion bar or when mechanical constraints prevent close-proximity mounting. For standard distances (30–200 mm), the <a href="/products/static-eliminator/st-e-series">ST-E Series</a> is sufficient and more cost-effective. For applications requiring intelligent self-monitoring and auto-cleaning without production stops, upgrade to the <a href="/products/static-eliminator/st-g-series">ST-G Series</a>.</p>
      </section>

      <section class="detail-block faq-block">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-list">
          <div class="faq-item">
            <h3 class="faq-question">What makes the ST-F Series different from other ion bars?</h3>
            <p class="faq-answer">The ST-F Series is engineered for longer working distances, with effective static elimination up to 400 mm from the bar surface. This makes it the right choice when mechanical constraints prevent close-proximity mounting or when product clearance requires the bar to be set back from the material.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-question">What power supply does the ST-F Series require?</h3>
            <p class="faq-answer">The ST-F Series operates on DC 24V input and generates ±5kV output internally. A standard 24V DC power supply (typically included with the controller) is all that is needed — no specialized high-voltage supply is required at the installation point.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-question">How often does the ST-F Series need maintenance?</h3>
            <p class="faq-answer">Emitter tips require cleaning every 1–3 months to maintain ion balance within ±10V. The built-in self-diagnostic circuit alerts operators when performance degrades, so maintenance can be scheduled rather than reactive.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-question">Can the ST-F Series be integrated with PLC systems?</h3>
            <p class="faq-answer">Yes. The DC 24V interface is compatible with standard PLC-controlled production lines and automation systems, allowing the ion bar to be switched on or off in sync with machine operation.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-question">Is the ST-F Series suitable for printing and film industries?</h3>
            <p class="faq-answer">Yes. The ST-F Series is widely used in web printing, film coating, label manufacturing, and optical film lamination where high-speed material movement generates intense static charge and close-proximity installation is not always practical.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-question">What is the ion balance of the ST-F Series?</h3>
            <p class="faq-answer">The ST-F Series maintains an ion balance of ±10V or better, ensuring effective neutralization rather than creating a residual charge of the opposite polarity — a common issue with poorly balanced ionizers.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="st-f-series">
          <div class="related-slider-header">
            <h2>Related Products</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>

          <div class="related-slider-track">
            <a href="/products/static-eliminator/st-g-series" class="related-slide-card" data-key="st-g-series">
              <img src="/assets/img/static-eliminator/st-g.jpg" alt="ST-G Series" loading="lazy" />
              <h4>ST-G Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-e-series" class="related-slide-card" data-key="st-e-series">
              <img src="/assets/img/static-eliminator/st-e.jpg" alt="ST-E Series" loading="lazy" />
              <h4>ST-E Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-f-series" class="related-slide-card" data-key="st-f-series">
              <img src="/assets/img/static-eliminator/st-f.jpg" alt="ST-F Series" loading="lazy" />
              <h4>ST-F Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-s200" class="related-slide-card" data-key="st-s200">
              <img src="/assets/img/static-eliminator/st-s200.jpg" alt="ST-S200" loading="lazy" />
              <h4>ST-S200 Mini Ionizer Fan</h4>
            </a>
            <a href="/products/static-eliminator/st-101a" class="related-slide-card" data-key="st-101a">
              <img src="/assets/img/static-eliminator/st-101a.jpg" alt="ST101A" loading="lazy" />
              <h4>ST101A Table Ionizing Air Blower</h4>
            </a>
            <a href="/products/static-eliminator/st-104a" class="related-slide-card" data-key="st-104a">
              <img src="/assets/img/static-eliminator/st-104a.jpg" alt="ST104A" loading="lazy" />
              <h4>ST104A Horizontal Ion Blower</h4>
            </a>
            <a href="/products/static-eliminator/st-1200" class="related-slide-card" data-key="st-1200">
              <img src="/assets/img/static-eliminator/st-1200.jpg" alt="ST1200" loading="lazy" />
              <h4>ST1200 Horizontal Ion Fan</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>

