---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="ST104A Horizontal Ion Blower | DGSDK"
  description="ST104A desktop ionizing air blower with enhanced ion output for static elimination in cleanrooms, electronics manufacturing, and SMT production lines."
  image="/assets/img/static-eliminator/st-104a.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/static-eliminator">Static Eliminator</a>
        <span>/</span>
        <span>ST104A</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/static-eliminator/st-104a.jpg"
              alt="ST104A Horizontal Ion Blower"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/static-eliminator/st-104a.jpg"
              alt="ST104A Thumbnail"
              data-full="/assets/img/static-eliminator/st-104a.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>ST104A Horizontal Ion Blower</h1>
          <p class="product-short-desc">
            Horizontal ion blower designed for wider static elimination coverage,
            adjustable airflow, and reliable anti-static performance.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Wide Coverage</h4>
              <p>Suitable for broader anti-static zones and conveyor-side applications.</p>
            </div>
            <div class="highlight-item">
              <h4>Adjustable Airflow</h4>
              <p>Air volume can be adjusted to match different process conditions.</p>
            </div>
            <div class="highlight-item">
              <h4>Portable Design</h4>
              <p>Smaller structure based on ST105A design for easier installation.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          The ST104A horizontal ionizing air blower is developed on the basis of the ST105A
          model. It features a smaller and lighter structure while maintaining effective
          ionized airflow and electrostatic neutralization capability.
        </p>
        <p>
          It can be used for wider anti-static work areas and can support optional ion
          balance monitoring or alarm systems as required. It is suitable for production
          lines, packaging, inspection, and electronics-related applications.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>Horizontal blowing design for larger coverage area</li>
          <li>Adjustable airflow for flexible production needs</li>
          <li>Compact version derived from ST105A structure</li>
          <li>Supports practical installation in wider process areas</li>
          <li>Stable ion performance for industrial anti-static control</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Wide Area</h3>
            <p>Horizontal airflow design helps cover larger working surfaces.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>Flexible</h3>
            <p>Adjustable airflow and optional monitoring improve application flexibility.</p>
          </div>
          <div class="advantage-card green">
            <h3>Practical</h3>
            <p>Smaller and lighter body makes installation and use more convenient.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr><td>Operating Voltage</td><td>110V / 60Hz or 220V / 50Hz</td></tr>
            <tr><td>Current Consumption</td><td>3.0A or 1.5A</td></tr>
            <tr><td>Operating Temperature</td><td>-10℃ to 50℃</td></tr>
            <tr><td>Size</td><td>400mm(L) × 220mm(W) × 190mm(H)</td></tr>
            <tr><td>Weight</td><td>5.8Kg</td></tr>
            <tr><td>Air Volume</td><td>70–120CFM</td></tr>
            <tr><td>Ion Balance</td><td>0V ±10V</td></tr>
            <tr><td>Air Coverage</td><td>60cm × 120cm</td></tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>Packaging</span>
          <span>Electronics</span>
          <span>Printing</span>
          <span>Inspection Lines</span>
          <span>Conveyor Operations</span>
          <span>Assembly Areas</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="st-104a">
          <div class="related-slider-header">
            <h2>Related Products</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>

          <div class="related-slider-track">
            <a href="/products/static-eliminator/st-g-series" class="related-slide-card" data-key="st-g-series">
              <img src="/assets/img/static-eliminator/st-g.jpg" alt="ST-G Series" loading="lazy" />
              <h4>ST-G Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-e-series" class="related-slide-card" data-key="st-e-series">
              <img src="/assets/img/static-eliminator/st-e.jpg" alt="ST-E Series" loading="lazy" />
              <h4>ST-E Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-f-series" class="related-slide-card" data-key="st-f-series">
              <img src="/assets/img/static-eliminator/st-f.jpg" alt="ST-F Series" loading="lazy" />
              <h4>ST-F Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-s200" class="related-slide-card" data-key="st-s200">
              <img src="/assets/img/static-eliminator/st-s200.jpg" alt="ST-S200" loading="lazy" />
              <h4>ST-S200 Mini Ionizer Fan</h4>
            </a>
            <a href="/products/static-eliminator/st-101a" class="related-slide-card" data-key="st-101a">
              <img src="/assets/img/static-eliminator/st-101a.jpg" alt="ST101A" loading="lazy" />
              <h4>ST101A Table Ionizing Air Blower</h4>
            </a>
            <a href="/products/static-eliminator/st-104a" class="related-slide-card" data-key="st-104a">
              <img src="/assets/img/static-eliminator/st-104a.jpg" alt="ST104A" loading="lazy" />
              <h4>ST104A Horizontal Ion Blower</h4>
            </a>
            <a href="/products/static-eliminator/st-1200" class="related-slide-card" data-key="st-1200">
              <img src="/assets/img/static-eliminator/st-1200.jpg" alt="ST1200" loading="lazy" />
              <h4>ST1200 Horizontal Ion Fan</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ProductLayout>