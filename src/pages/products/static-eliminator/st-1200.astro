---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="ST1200 Horizontal Ion Fan | DGSDK">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/static-eliminator">Static Eliminator</a>
        <span>/</span>
        <span>ST1200</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/static-eliminator/ST-1200.jpg"
              alt="ST1200 Horizontal Ion Fan"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/static-eliminator/ST-1200.jpg"
              alt="ST1200 Thumbnail"
              data-full="/assets/img/static-eliminator/ST-1200.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>ST1200 Horizontal Ion Fan</h1>
          <p class="product-short-desc">
            Horizontal desktop ion fan with wide airflow coverage, suitable for larger
            anti-static zones and workstation-side installation.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Large Coverage</h4>
              <p>Air coverage reaches wide working areas for broader anti-static protection.</p>
            </div>
            <div class="highlight-item">
              <h4>Adjustable Airflow</h4>
              <p>Air volume can be adjusted according to process requirements.</p>
            </div>
            <div class="highlight-item">
              <h4>Built-in Generator</h4>
              <p>Integrated high-voltage generator supports stable ion output.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          The ST1200 horizontal ion fan provides a wide ionized air coverage area and is
          suitable for hanging horizontally or placing near workstations. It is developed
          for larger anti-static work zones requiring stable airflow and static control.
        </p>
        <p>
          It is commonly used in electronics manufacturing, workstation protection,
          packaging lines, and other industrial applications where wider electrostatic
          elimination coverage is needed.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>Wide-area horizontal anti-static airflow</li>
          <li>Adjustable air volume for different working needs</li>
          <li>Suitable for hanging or workstation-side installation</li>
          <li>Built-in high-voltage generator for stable performance</li>
          <li>Designed for broader industrial electrostatic protection</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Wide Reach</h3>
            <p>Extended air coverage helps protect larger working surfaces and lines.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>Adjustable</h3>
            <p>Airflow can be tuned according to product size and process speed.</p>
          </div>
          <div class="advantage-card green">
            <h3>Integrated</h3>
            <p>Built-in ion generation system simplifies installation and operation.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr><td>Operating Voltage</td><td>110V / 60Hz or 220V / 50Hz</td></tr>
            <tr><td>Power</td><td>40W to 80W</td></tr>
            <tr><td>Operating Temperature</td><td>-10℃ to 50℃</td></tr>
            <tr><td>Dimensions</td><td>1280mm(L) × 215mm(W) × 190mm(H)</td></tr>
            <tr><td>Weight</td><td>14.5Kg</td></tr>
            <tr><td>Air Coverage</td><td>140cm × 120cm</td></tr>
            <tr><td>Air Volume</td><td>150–360CFM</td></tr>
            <tr><td>Ion Balance</td><td>0V ±10V</td></tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>Electronics</span>
          <span>Workstations</span>
          <span>Packaging</span>
          <span>Inspection Lines</span>
          <span>Assembly Operations</span>
          <span>Wide-Area Static Control</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="st-1200">
          <div class="related-slider-header">
            <h2>Related Products</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>

          <div class="related-slider-track">
            <a href="/products/static-eliminator/st-g-series" class="related-slide-card" data-key="st-g-series">
              <img src="/assets/img/static-eliminator/ST-G.jpg" alt="ST-G Series" />
              <h4>ST-G Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-e-series" class="related-slide-card" data-key="st-e-series">
              <img src="/assets/img/static-eliminator/ST-E.jpg" alt="ST-E Series" />
              <h4>ST-E Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-f-series" class="related-slide-card" data-key="st-f-series">
              <img src="/assets/img/static-eliminator/ST-F.jpg" alt="ST-F Series" />
              <h4>ST-F Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-s200" class="related-slide-card" data-key="st-s200">
              <img src="/assets/img/static-eliminator/ST-S200.jpg" alt="ST-S200" />
              <h4>ST-S200 Mini Ionizer Fan</h4>
            </a>
            <a href="/products/static-eliminator/st-101a" class="related-slide-card" data-key="st-101a">
              <img src="/assets/img/static-eliminator/ST-101A.jpg" alt="ST101A" />
              <h4>ST101A Table Ionizing Air Blower</h4>
            </a>
            <a href="/products/static-eliminator/st-104a" class="related-slide-card" data-key="st-104a">
              <img src="/assets/img/static-eliminator/ST-104A.jpg" alt="ST104A" />
              <h4>ST104A Horizontal Ion Blower</h4>
            </a>
            <a href="/products/static-eliminator/st-1200" class="related-slide-card" data-key="st-1200">
              <img src="/assets/img/static-eliminator/ST-1200.jpg" alt="ST1200" />
              <h4>ST1200 Horizontal Ion Fan</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ProductLayout>