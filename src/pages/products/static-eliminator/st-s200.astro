---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="ST-S200 Mini Ionizer Fan | DGSDK"
  description="ST-S200 ionizing air snake for flexible static elimination in confined spaces, robotic arms, and precision assembly stations."
  image="/assets/img/static-eliminator/st-s200.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/static-eliminator">Static Eliminator</a>
        <span>/</span>
        <span>ST-S200</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/static-eliminator/st-s200.jpg"
              alt="ST-S200 Mini Ionizer Fan"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/static-eliminator/st-s200.jpg"
              alt="ST-S200 Thumbnail"
              data-full="/assets/img/static-eliminator/st-s200.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>ST-S200 Mini Ionizer Fan</h1>
          <p class="product-short-desc">
            ST-S200 mini ionizer fan — magnetic levitation airflow, AC 100–240V input,
            ±15V ion balance, 150~450mm effective range, low noise, CE certified
            for electronics workstations and precision assembly.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Magnetic Levitation Airflow</h4>
              <p>All-new magnetic levitation design delivers smooth, quiet airflow for workstation use.</p>
            </div>
            <div class="highlight-item">
              <h4>150~450mm Range</h4>
              <p>Effective emission distance covers typical workstation and benchtop applications.</p>
            </div>
            <div class="highlight-item">
              <h4>Universal AC Input</h4>
              <p>AC 100–240V, 50/60Hz input works worldwide without a transformer.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          The ST-S200 Mini Ionizer Fan features an all-new magnetic levitation airflow design for
          smooth, quiet operation. High-efficiency DC high voltage generates positive and negative
          air ions that neutralize static charges on work surfaces within a 150~450mm effective range.
        </p>
        <p>
          Its compact size makes it easy to install at workstations and benchtop applications. The
          self-diagnostic protection circuit with overcurrent protection ensures safe operation, while
          the low noise design and long service life make it ideal for cleanroom, precision assembly,
          semiconductor handling, and electronics inspection environments. CE certified and universally
          compatible with AC 100–240V input.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>All-new design with magnetic levitation airflow — smooth and quiet operation</li>
          <li>High-efficiency DC high voltage generating positive and negative air ions</li>
          <li>Compact size — easy to install in workstations and benchtop applications</li>
          <li>High-quality DC high voltage module for superior static elimination performance</li>
          <li>Self-diagnostic protection circuit with overcurrent protection</li>
          <li>CE certified — meets safety standards</li>
          <li>Low noise, long service life</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Magnetic Levitation Fan</h3>
            <p>Smooth, quiet airflow from magnetic levitation design — ideal for precision workstation environments.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>Wide Input Voltage</h3>
            <p>AC 100–240V universal input works in any country without additional power conversion.</p>
          </div>
          <div class="advantage-card green">
            <h3>CE Certified</h3>
            <p>Meets international safety standards for use in professional manufacturing and cleanroom environments.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr><td>Model</td><td>ST-S200</td></tr>
            <tr><td>Power Input</td><td>AC 100–240V, 50/60Hz</td></tr>
            <tr><td>Ion Output</td><td>Positive and negative air ions</td></tr>
            <tr><td>Ion Balance</td><td>±15V or better</td></tr>
            <tr><td>Emission Distance</td><td>150~450mm effective range</td></tr>
            <tr><td>Airflow</td><td>Adjustable</td></tr>
            <tr><td>Noise Level</td><td>Low noise design</td></tr>
            <tr><td>Working Temperature</td><td>0~40°C</td></tr>
            <tr><td>Working Humidity</td><td>20~85% RH</td></tr>
            <tr><td>Certification</td><td>CE certified</td></tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>Electronics Workstations</span>
          <span>PCB Inspection</span>
          <span>Semiconductor Handling</span>
          <span>Cleanroom</span>
          <span>Precision Assembly</span>
          <span>Testing Benches</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="st-s200">
          <div class="related-slider-header">
            <h2>Related Products</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>

          <div class="related-slider-track">
            <a href="/products/static-eliminator/st-g-series" class="related-slide-card" data-key="st-g-series">
              <img src="/assets/img/static-eliminator/st-g.jpg" alt="ST-G Series" loading="lazy" />
              <h4>ST-G Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-e-series" class="related-slide-card" data-key="st-e-series">
              <img src="/assets/img/static-eliminator/st-e.jpg" alt="ST-E Series" loading="lazy" />
              <h4>ST-E Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-f-series" class="related-slide-card" data-key="st-f-series">
              <img src="/assets/img/static-eliminator/st-f.jpg" alt="ST-F Series" loading="lazy" />
              <h4>ST-F Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-s200" class="related-slide-card" data-key="st-s200">
              <img src="/assets/img/static-eliminator/st-s200.jpg" alt="ST-S200" loading="lazy" />
              <h4>ST-S200 Mini Ionizer Fan</h4>
            </a>
            <a href="/products/static-eliminator/st-101a" class="related-slide-card" data-key="st-101a">
              <img src="/assets/img/static-eliminator/st-101a.jpg" alt="ST101A" loading="lazy" />
              <h4>ST101A Table Ionizing Air Blower</h4>
            </a>
            <a href="/products/static-eliminator/st-104a" class="related-slide-card" data-key="st-104a">
              <img src="/assets/img/static-eliminator/st-104a.jpg" alt="ST104A" loading="lazy" />
              <h4>ST104A Horizontal Ion Blower</h4>
            </a>
            <a href="/products/static-eliminator/st-1200" class="related-slide-card" data-key="st-1200">
              <img src="/assets/img/static-eliminator/st-1200.jpg" alt="ST1200" loading="lazy" />
              <h4>ST1200 Horizontal Ion Fan</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ProductLayout>