---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="ST-S200 Mini Ionizer Fan | DGSDK">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/static-eliminator">Static Eliminator</a>
        <span>/</span>
        <span>ST-S200</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/static-eliminator/ST-S200.jpg"
              alt="ST-S200 Mini Ionizer Fan"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/static-eliminator/ST-S200.jpg"
              alt="ST-S200 Thumbnail"
              data-full="/assets/img/static-eliminator/ST-S200.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>ST-S200 Mini Ionizer Fan</h1>
          <p class="product-short-desc">
            Compact ionizing fan designed for localized static elimination in electronics
            assembly, inspection stations, and workstation environments.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Compact Design</h4>
              <p>Small size for convenient installation in limited workspace areas.</p>
            </div>
            <div class="highlight-item">
              <h4>Low Noise</h4>
              <p>Quiet operation suitable for benches and light industrial workstations.</p>
            </div>
            <div class="highlight-item">
              <h4>Energy Efficient</h4>
              <p>Low power consumption with reliable ion output performance.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          The ST-S200 mini ionizer fan uses high-voltage ionization and airflow to neutralize
          static charges on localized work surfaces. It is suitable for point-to-point static
          control where flexible installation and convenient operation are required.
        </p>
        <p>
          It is ideal for electronics manufacturing, precision machinery, plastics, film,
          packaging, and small-area anti-static applications around manual workstations.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>Compact body for easy installation</li>
          <li>Effective localized electrostatic neutralization</li>
          <li>Low power use and long service life</li>
          <li>Reliable operation with safe performance</li>
          <li>Adjustable airflow for flexible work conditions</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Portable</h3>
            <p>Small footprint supports convenient anti-static control at workstation level.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>Targeted Control</h3>
            <p>Direct airflow helps neutralize static in localized production areas.</p>
          </div>
          <div class="advantage-card green">
            <h3>Efficient</h3>
            <p>Combines ion generation and airflow for stable small-area protection.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr><td>Operating Voltage</td><td>220V / 50Hz</td></tr>
            <tr><td>Power</td><td>≤10W</td></tr>
            <tr><td>Operating Temperature</td><td>0–50℃</td></tr>
            <tr><td>Dimensions</td><td>Approx. 190 × 95 × 260mm</td></tr>
            <tr><td>Weight</td><td>Approx. 2.5kg</td></tr>
            <tr><td>Air Volume</td><td>Adjustable</td></tr>
            <tr><td>Ion Balance</td><td>0V ±10V</td></tr>
            <tr><td>Application Range</td><td>Localized workstation static control</td></tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>Electronics Assembly</span>
          <span>Workstations</span>
          <span>Small Parts Inspection</span>
          <span>Packaging</span>
          <span>Printing</span>
          <span>Manual Operations</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="st-s200">
          <div class="related-slider-header">
            <h2>Related Products</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>

          <div class="related-slider-track">
            <a href="/products/static-eliminator/st-g-series" class="related-slide-card" data-key="st-g-series">
              <img src="/assets/img/static-eliminator/ST-G.jpg" alt="ST-G Series" />
              <h4>ST-G Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-e-series" class="related-slide-card" data-key="st-e-series">
              <img src="/assets/img/static-eliminator/ST-E.jpg" alt="ST-E Series" />
              <h4>ST-E Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-f-series" class="related-slide-card" data-key="st-f-series">
              <img src="/assets/img/static-eliminator/ST-F.jpg" alt="ST-F Series" />
              <h4>ST-F Series Intelligent Ion Rod</h4>
            </a>
            <a href="/products/static-eliminator/st-s200" class="related-slide-card" data-key="st-s200">
              <img src="/assets/img/static-eliminator/ST-S200.jpg" alt="ST-S200" />
              <h4>ST-S200 Mini Ionizer Fan</h4>
            </a>
            <a href="/products/static-eliminator/st-101a" class="related-slide-card" data-key="st-101a">
              <img src="/assets/img/static-eliminator/ST-101A.jpg" alt="ST101A" />
              <h4>ST101A Table Ionizing Air Blower</h4>
            </a>
            <a href="/products/static-eliminator/st-104a" class="related-slide-card" data-key="st-104a">
              <img src="/assets/img/static-eliminator/ST-104A.jpg" alt="ST104A" />
              <h4>ST104A Horizontal Ion Blower</h4>
            </a>
            <a href="/products/static-eliminator/st-1200" class="related-slide-card" data-key="st-1200">
              <img src="/assets/img/static-eliminator/ST-1200.jpg" alt="ST1200" />
              <h4>ST1200 Horizontal Ion Fan</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ProductLayout>