---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="Custom Precision Machined Parts | DGSDK"
  description="Custom precision CNC machined parts for industrial applications. Tight tolerance machining in aluminum, steel, and other materials with OEM/ODM support."
  image="/assets/img/precision-machined-parts/custom-precision-machined-parts.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/precision-machined-parts">Precision Machined Parts</a>
        <span>/</span>
        <span>Custom Precision Machined Parts</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/precision-machined-parts/precision-machined-parts.jpg"
              alt="Custom Precision Machined Parts"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/precision-machined-parts/precision-machined-parts.jpg"
              alt="Custom Precision Machined Parts Thumbnail"
              data-full="/assets/img/precision-machined-parts/precision-machined-parts.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>Custom Precision Machined Parts</h1>
          <p class="product-short-desc">
            Tailored CNC and lathe-machining solutions for custom drawings, prototypes,
            OEM projects, and precision industrial manufacturing requirements.
          </p>

          <div class="product-actions">
            <a href="/contact" class="quote-btn">Get a Quote</a>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Drawing-Based Production</h4>
              <p>Manufactured according to customer drawings, dimensions, and technical requirements.</p>
            </div>
            <div class="highlight-item">
              <h4>Prototype to Mass Production</h4>
              <p>Supports sample development, small batches, and stable long-term manufacturing.</p>
            </div>
            <div class="highlight-item">
              <h4>Flexible Machining Support</h4>
              <p>Suitable for CNC milling, turning, and customized precision part development.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          Custom Precision Machined Parts are developed for customers who require flexible,
          drawing-based manufacturing solutions for industrial components, automation parts,
          mechanical assemblies, and OEM equipment systems. DGSDK supports custom machining
          projects with stable production quality and reliable technical coordination.
        </p>
        <p>
          Whether for prototype verification, small-batch production, or long-term mass
          manufacturing, our custom machining service is designed to meet project-specific
          requirements for dimensions, tolerances, materials, and functional performance.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>Supports custom manufacturing based on drawings or samples</li>
          <li>Available for CNC milling, turning, and combined machining processes</li>
          <li>Suitable for prototypes, OEM parts, and industrial batch production</li>
          <li>Flexible material, tolerance, and surface finish options</li>
          <li>Stable production quality for repeat orders and long-term supply</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Project Flexibility</h3>
            <p>Supports a wide range of custom dimensions, structures, and technical requirements.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>Precision Control</h3>
            <p>Stable machining quality helps ensure accuracy, consistency, and reliable part fit.</p>
          </div>
          <div class="advantage-card green">
            <h3>Production Scalability</h3>
            <p>From prototypes to mass production, supports growing project demands efficiently.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr><td>Product Type</td><td>Custom Precision Machined Parts</td></tr>
            <tr><td>Process</td><td>CNC Milling / Turning / Precision Machining</td></tr>
            <tr><td>Application</td><td>OEM Projects / Automation Equipment / Mechanical Assemblies</td></tr>
            <tr><td>Material</td><td>Available according to drawing and project requirements</td></tr>
            <tr><td>Tolerance</td><td>Customized based on technical specification</td></tr>
            <tr><td>Surface Finish</td><td>Available according to functional and visual requirements</td></tr>
            <tr><td>Customization</td><td>Supported for OEM / ODM / Drawing-Based Projects</td></tr>
            <tr><td>Production</td><td>Prototype / Small Batch / Mass Production Available</td></tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>OEM Manufacturing</span>
          <span>Automation Equipment</span>
          <span>Mechanical Assemblies</span>
          <span>Custom Machinery</span>
          <span>Prototype Development</span>
          <span>Precision Industrial Parts</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="custom-precision-machined-parts">
          <div class="related-slider-header">
            <h2>Related Products</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>

          <div class="related-slider-track">
            <a
              href="/products/precision-machined-parts/lathe-machined-shaft-end-fixing-component"
              class="related-slide-card"
              data-key="lathe-machined-shaft-end-fixing-component"
            >
              <img
                src="/assets/img/precision-machined-parts/lathe-machined-shaft-end-fixing-component.jpg"
                alt="Lathe-Machined Shaft End Fixing Component"
              />
              <h4>Lathe-Machined Shaft End Fixing Component</h4>
            </a>

            <a
              href="/products/precision-machined-parts/lathe-machined-bearing-outer-retainer-plate"
              class="related-slide-card"
              data-key="lathe-machined-bearing-outer-retainer-plate"
            >
              <img
                src="/assets/img/precision-machined-parts/lathe-machined-bearing-outer-retainer-plate.jpg"
                alt="Lathe-Machined Bearing Outer Retainer Plate"
              />
              <h4>Lathe-Machined Bearing Outer Retainer Plate</h4>
            </a>

            <a
              href="/products/precision-machined-parts/cnc-milled-wing-connection-block"
              class="related-slide-card"
              data-key="cnc-milled-wing-connection-block"
            >
              <img
                src="/assets/img/precision-machined-parts/cnc-milled-wing-connection-block.jpg"
                alt="CNC-Milled Wing Connection Block"
              />
              <h4>CNC-Milled Wing Connection Block</h4>
            </a>

            <a
              href="/products/precision-machined-parts/precision-bearing-bracket-cnc-milled"
              class="related-slide-card"
              data-key="precision-bearing-bracket-cnc-milled"
            >
              <img
                src="/assets/img/precision-machined-parts/precision-bearing-bracket-cnc-milled.jpg"
                alt="Precision Bearing Bracket - CNC Milled"
              />
              <h4>Precision Bearing Bracket - CNC Milled</h4>
            </a>

            <a
              href="/products/precision-machined-parts/cnc-milled-front-panel-rubber-roller-assembly"
              class="related-slide-card"
              data-key="cnc-milled-front-panel-rubber-roller-assembly"
            >
              <img
                src="/assets/img/precision-machined-parts/cnc-milled-front-panel-rubber-roller-assembly.jpg"
                alt="CNC-Milled Front Panel for Rubber Roller Assembly"
              />
              <h4>CNC-Milled Front Panel for Rubber Roller Assembly</h4>
            </a>

            <a
              href="/products/precision-machined-parts/milled-front-inner-fixing-plate-paper-roll-guide-rail"
              class="related-slide-card"
              data-key="milled-front-inner-fixing-plate-paper-roll-guide-rail"
            >
              <img
                src="/assets/img/precision-machined-parts/milled-front-inner-fixing-plate-paper-roll-guide-rail.jpg"
                alt="Milled Front Inner Fixing Plate for Paper Roll Guide Rail"
              />
              <h4>Milled Front Inner Fixing Plate for Paper Roll Guide Rail</h4>
            </a>

            <a
              href="/products/precision-machined-parts/custom-precision-machined-parts"
              class="related-slide-card"
              data-key="custom-precision-machined-parts"
            >
              <img
                src="/assets/img/precision-machined-parts/precision-machined-parts.jpg"
                alt="Custom Precision Machined Parts"
              />
              <h4>Custom Precision Machined Parts</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ProductLayout>