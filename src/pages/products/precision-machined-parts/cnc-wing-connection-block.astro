                alt="Lathe-Machined Bearing Outer Retainer Plate"
              />
              <h4>Lathe-Machined Bearing Outer Retainer Plate</h4>
            </a>

            <a
              href="/products/precision-machined-parts/cnc-milled-wing-connection-block"
              class="related-slide-card"
              data-key="cnc-milled-wing-connection-block"
            >
              <img
                src="/assets/img/precision-machined-parts/cnc-milled-wing-connection-block.jpg"
                alt="CNC-Milled Wing Connection Block"
              />
              <h4>CNC-Milled Wing Connection Block</h4>
            </a>

            <a
