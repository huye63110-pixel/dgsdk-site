              <h4>Milled Front Inner Fixing Plate for Paper Roll Guide Rail</h4>
            </a>

            <a
              href="/products/precision-machined-parts/custom-precision-machined-parts"
              class="related-slide-card"
              data-key="custom-precision-machined-parts"
            >
              <img
                src="/assets/img/precision-machined-parts/precision-machined-parts.jpg"
                alt="Custom Precision Machined Parts"
              />
              <h4>Custom Precision Machined Parts</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ProductLayout>