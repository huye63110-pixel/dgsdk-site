              class="related-slide-card"
              data-key="precision-bearing-bracket-cnc-milled"
            >
              <img
                src="/assets/img/precision-machined-parts/precision-bearing-bracket-cnc-milled.jpg"
                alt="Precision Bearing Bracket - CNC Milled"
              />
              <h4>Precision Bearing Bracket - CNC Milled</h4>
            </a>

            <a
