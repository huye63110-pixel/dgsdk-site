---
import Layout from '../../../layouts/Layout.astro';

const products = [
  {
    name: 'Lathe-Machined Shaft End Fixing Component',
    image: '/assets/img/precision-machined-parts/lathe-machined-shaft-end-fixing-component.jpg',
    href: '/products/precision-machined-parts/lathe-machined-shaft-end-fixing-component',
    desc: 'Accurately machined shaft-end fixing part for stable industrial assembly performance.'
  },
  {
    name: 'Lathe-Machined Bearing Outer Retainer Plate',
    image: '/assets/img/precision-machined-parts/lathe-machined-bearing-outer-retainer-plate.jpg',
    href: '/products/precision-machined-parts/lathe-machined-bearing-outer-retainer-plate',
    desc: 'Precision retainer plate designed for secure bearing positioning and long-term reliability.'
  },
  {
    name: 'CNC-Milled Wing Connection Block',
    image: '/assets/img/precision-machined-parts/cnc-milled-wing-connection-block.jpg',
    href: '/products/precision-machined-parts/cnc-wing-connection-block',
    desc: 'High-accuracy CNC-milled block for structural connection and industrial equipment use.'
  },
  {
    name: 'Precision Bearing Bracket - CNC Milled',
    image: '/assets/img/precision-machined-parts/precision-bearing-bracket-cnc-milled.jpg',
    href: '/products/precision-machined-parts/precision-bearing-bracket-cnc-milled',
    desc: 'Robust bracket component manufactured for consistent alignment, support and precision.'
  },
  {
    name: 'CNC-Milled Front Panel for Rubber Roller Assembly',
    image: '/assets/img/precision-machined-parts/cnc-milled-front-panel-rubber-roller-assembly.jpg',
    href: '/products/precision-machined-parts/cnc-milled-front-panel-rubber-roller-assembly',
    desc: 'Machined front panel built for roller assembly systems and precision equipment integration.'
  },
  {
    name: 'Milled Front Inner Fixing Plate for Paper Roll Guide Rail',
    image: '/assets/img/precision-machined-parts/milled-front-inner-fixing-plate-paper-roll-guide-rail.jpg',
    href: '/products/precision-machined-parts/milled-front-inner-fixing-plate-paper-roll-guide-rail',
    desc: 'Inner fixing plate engineered for guide rail systems and smooth mechanical support.'
  },
  {
    name: 'Custom Precision Machined Parts',
    image: '/assets/img/precision-machined-parts/precision-machined-parts.jpg',
    href: '/products/precision-machined-parts/custom-precision-machined-parts',
    desc: 'Tailored CNC and lathe-machining solutions for custom drawings, prototypes and OEM projects.'
  }
];
---

<Layout title="Precision CNC Machined Parts | Custom Machining | DGSDK"
  description="Custom precision CNC machined parts: brackets, fixing plates, shaft ends, and OEM machined components for industrial automation and electronics manufacturing.">
  <section
    class="products-hero"
    style="background: linear-gradient(rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.18)), url('/assets/img/cleaning-machine/cnc-parts.jpg') center/cover no-repeat;"
  >
    <div class="container products-hero-inner">
      <span class="products-hero-kicker">DGSDK Product Portfolio</span>
      <h1>Precision Machined Parts</h1>
      <p>
        High-precision machined components for industrial equipment, automation systems,
        custom assemblies, brackets, shafts, fixing plates and OEM manufacturing applications.
      </p>
    </div>
  </section>

  <section class="products-overview-section">
    <div class="container products-overview-layout">
      <aside class="products-sidebar">
        <div class="products-sidebar-box">
          <h3>Browse Categories</h3>
          <a href="/products">All Products</a>
          <a href="/products/static-eliminator">Static Elimination Systems</a>
          <a href="/products/cleaning-machine">Cleaning Machine</a>
          <a href="/products/precision-machined-parts" class="active-category">Precision Machined Parts</a>
          <a href="/products/automation">Automation Equipment</a>
        </div>
      </aside>

      <div class="products-main">
        <section class="apple-product-section">
          <div class="apple-card-grid">
            {products.map((product) => (
              <a href={product.href} class="apple-product-card">
                <img src={product.image} alt={product.name} loading="lazy" />

                <div class="apple-product-card-body">
                  <span class="apple-card-tag">Precision Machined Parts</span>
                  <h3>{product.name}</h3>
                  <p>{product.desc}</p>
                </div>
              </a>
            ))}
          </div>
        </section>

        <section class="category-info-block">
          <h2>About DGSDK Precision Machined Parts</h2>
          <p>DGSDK manufactures precision machined components using CNC milling, CNC turning, and lathe machining processes. Our parts are produced to tight dimensional tolerances and are used in industrial automation equipment, cleaning machine frames, roller assembly systems, and guide rail mechanisms across electronics manufacturing and precision engineering applications.</p>
          <p>We supply both standard catalog components and fully custom-machined parts produced to customer drawings. Materials include aluminum alloy, carbon steel, and stainless steel. All components are inspected to verify dimensional accuracy before delivery.</p>

          <h3>CNC Machining Processes</h3>
          <p>DGSDK uses CNC milling and CNC turning as the primary machining methods for precision parts production. CNC milling is used for flat surfaces, pockets, holes, and complex profiles on structural components such as brackets, connection blocks, and mounting plates. CNC turning produces cylindrical parts including shaft-end fixing components and bearing retainer rings.</p>
          <p>Our machining centers hold tight tolerances consistently across production runs. Dimensional accuracy is verified using calibrated measuring equipment before parts are released. This ensures that every component fits correctly when assembled into the target machine or system.</p>

          <h3>Materials for Precision Machined Parts</h3>
          <p>We machine parts from a range of industrial materials depending on the application requirements:</p>
          <ul>
            <li><strong>Aluminum alloy</strong> — lightweight and corrosion-resistant. Used for brackets, panels, and structural components where weight matters.</li>
            <li><strong>Carbon steel</strong> — high strength for load-bearing components and structural connectors in heavy industrial equipment.</li>
            <li><strong>Stainless steel</strong> — corrosion and chemical resistance for cleanroom and food-adjacent production environments.</li>
          </ul>
          <p>Material selection is guided by the operating environment, load requirements, and surface finish specification. Contact us to discuss material options for your application.</p>

          <h3>Custom Precision Machined Parts</h3>
          <p>Most of our precision machined parts are produced to customer drawings or CAD files. We manufacture <a href="/products/precision-machined-parts/custom-precision-machined-parts">custom precision machined parts</a> for OEM equipment manufacturers, automation system integrators, and prototype developers. Customers provide 2D drawings or 3D models, and we return finished, inspected parts ready for assembly.</p>
          <p>We also manufacture catalog parts including <a href="/products/precision-machined-parts/precision-bearing-bracket-cnc-milled">precision bearing brackets</a>, <a href="/products/precision-machined-parts/lathe-machined-shaft-end-fixing-component">shaft-end fixing components</a>, and <a href="/products/precision-machined-parts/cnc-wing-connection-block">wing connection blocks</a> used in cleaning machines and automation equipment.</p>

          <h3>Common Applications</h3>
          <ul>
            <li>Bearing brackets and shaft-end fixing components for automated equipment</li>
            <li>Guide rail fixing plates and inner mounting components for roll-to-roll systems</li>
            <li>Wing connection blocks and structural connectors for machine frames</li>
            <li>Front panels and rubber roller assembly supports for cleaning machines</li>
            <li>OEM and prototype components machined from customer drawings</li>
          </ul>
          <p>Contact us with your drawings or specifications for a custom precision machined parts quote.</p>
        </section>
      </div>
    </div>
  </section>
</Layout>