        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr><td>Application</td><td>Backlight Panel and Display Component Cleaning</td></tr>
            <tr><td>Drive System</td><td>Magnetic Levitation</td></tr>
            <tr><td>Cleaning Method</td><td>Adhesive roller</td></tr>
            <tr><td>Material Compatibility</td><td>Backlight units, diffuser sheets, prism sheets, optical films</td></tr>
