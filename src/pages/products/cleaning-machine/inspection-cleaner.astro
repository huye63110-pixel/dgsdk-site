---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="Inspection Stage Cleaning Machine (STXT Series) | DGSDK">
  <section class="product-detail-page">
    <div class="container">

      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/cleaning-machine">Cleaning Machine</a>
        <span>/</span>
        <span>Inspection Stage Cleaning Machine (STXT Series)</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/cleaning-machine/inspection-cleaner.jpg"
              alt="Inspection Stage Cleaning Machine (STXT Series)"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/cleaning-machine/inspection-cleaner.jpg"
              alt="Inspection Stage Cleaning Machine (STXT Series) Thumbnail 1"
              data-full="/assets/img/cleaning-machine/inspection-cleaner.jpg"
            />
            <img
              class="thumb-image"
              src="/assets/img/cleaning-machine/inspection-cleaner-2.jpg"
              alt="Inspection Stage Cleaning Machine (STXT Series) Thumbnail 2"
              data-full="/assets/img/cleaning-machine/inspection-cleaner-2.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>Inspection Stage Cleaning Machine (STXT Series)</h1>
          <p class="product-short-desc">
            Cleaning system designed for inspection-stage surface preparation,
            helping remove dust, particles, fibers, and static contamination before
            visual inspection, AOI, CCD detection, and other quality-control processes.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Inspection Preparation</h4>
              <p>Improves surface quality before visual and automated inspection.</p>
            </div>
            <div class="highlight-item">
              <h4>Reduced False Defects</h4>
              <p>Helps reduce contamination that may interfere with inspection results.</p>
            </div>
            <div class="highlight-item">
              <h4>Stable Factory Operation</h4>
              <p>Designed for continuous use in production and QC environments.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          The Inspection Stage Cleaning Machine (STXT Series) is developed for production lines
          where high surface cleanliness is required before inspection, testing, or visual quality evaluation.
        </p>
        <p>
          It helps improve inspection consistency and reduce unnecessary defect judgments
          caused by dust, fibers, particles, and static contamination on the product surface.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>Designed for pre-inspection and quality-control cleaning applications</li>
          <li>Helps remove dust, particles, fibers, and static contamination</li>
          <li>Improves inspection accuracy and process consistency</li>
          <li>Suitable for display, optical, and electronics production environments</li>
          <li>Stable industrial structure for continuous operation</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Cleaner Inspection</h3>
            <p>Improves product surface condition before visual and automated checks.</p>
          </div>

          <div class="advantage-card yellow">
            <h3>Accurate</h3>
            <p>Helps reduce false defect signals caused by temporary contamination.</p>
          </div>

          <div class="advantage-card green">
            <h3>Reliable</h3>
            <p>Designed for stable integration into industrial quality-control processes.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr><td>Application</td><td>Inspection Stage Surface Cleaning</td></tr>
            <tr><td>Model</td><td>STXT Series</td></tr>
            <tr><td>Cleaning Target</td><td>Dust, particles, fibers, static contamination</td></tr>
            <tr><td>Suitable Material</td><td>Display parts, optical sheets, electronic components, precision surfaces</td></tr>
            <tr><td>Operation Mode</td><td>Automatic</td></tr>
            <tr><td>Production Stage</td><td>Before visual inspection / AOI / CCD detection</td></tr>
            <tr><td>Control System</td><td>Industrial Control</td></tr>
            <tr><td>Dimensions</td><td>Customized</td></tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>Inspection Lines</span>
          <span>AOI Systems</span>
          <span>CCD Detection</span>
          <span>Display Panels</span>
          <span>Optical Materials</span>
          <span>Precision QC</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="inspection-cleaner">
          <div class="related-slider-header">
            <h2>Related Products</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>

          <div class="related-slider-track">
            <a href="/products/cleaning-machine/polarizer-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="Polarizer Precision Cleaning Machine" /><h4>Polarizer Precision Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/fpc-4-axis-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/fpc-4-axis-cleaner.jpg" alt="FPC 4-Axis High Precision Cleaning Machine" /><h4>FPC 4-Axis High Precision Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/fpc-8-axis-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/fpc-8-axis-cleaner.jpg" alt="FPC 8-Axis Advanced Cleaning Machine" /><h4>FPC 8-Axis Advanced Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/optical-film-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/optical.jpg" alt="Large Size Optical Film Cleaning Machine" /><h4>Large Size Optical Film Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/lcm-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/lcm-cleaner.jpg" alt="LCM Module Industrial Cleaning Machine" /><h4>LCM Module Industrial Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/pcb-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/pcb-cleaner.jpg" alt="PCB Surface Cleaning Machine" /><h4>PCB Surface Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/pcb-vertical-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/stick-pcb-vertical-cleaning-machine.jpg" alt="PCB Vertical Cleaning System" /><h4>PCB Vertical Cleaning System</h4></a>
            <a href="/products/cleaning-machine/roll-chip-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/roll-chip-cleaner.jpg" alt="Roll Chip Universal Cleaning Machine" /><h4>Roll Chip Universal Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/smt-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/smt-cleaner.jpg" alt="SMT Inline Cleaning Machine (SMT600 Series)" /><h4>SMT Inline Cleaning Machine (SMT600 Series)</h4></a>
            <a href="/products/cleaning-machine/backlight-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/backlight-cleaner.jpg" alt="Backlight Panel Cleaning Machine" /><h4>Backlight Panel Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/ccl-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/ccl-cleaner.jpg" alt="Stick CCL Cleaning Machine ST DT1340" /><h4>Stick CCL Cleaning Machine ST DT1340</h4></a>
          </div>
        </div>
      </section>

    </div>
  </section>
</ProductLayout>