---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="Roll Chip Universal Cleaning Machine | DGSDK">
  <section class="product-detail-page">
    <div class="container">

      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/cleaning-machine">Cleaning Machine</a>
        <span>/</span>
        <span>Roll Chip Universal Cleaning Machine</span>
      </div>

      <div class="product-top">

        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img id="mainProductImage" src="/assets/img/cleaning-machine/roll-chip-cleaner.jpg" />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img class="thumb-image active-thumb" src="/assets/img/cleaning-machine/roll-chip-cleaner.jpg" data-full="/assets/img/cleaning-machine/roll-chip-cleaner.jpg" />
          </div>
        </div>

        <div class="product-summary">
          <h1>Roll Chip Universal Cleaning Machine</h1>
          <p class="product-short-desc">
            Universal cleaning system for roll materials and chip-based products,
            designed to remove particles, fibers, and surface contamination during production.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Universal Application</h4>
              <p>Supports multiple material types and formats.</p>
            </div>
            <div class="highlight-item">
              <h4>Efficient Cleaning</h4>
              <p>Removes dust and debris during continuous processing.</p>
            </div>
            <div class="highlight-item">
              <h4>Flexible Integration</h4>
              <p>Can be adapted to various production lines.</p>
            </div>
          </div>
        </div>

      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          This machine is designed for cleaning roll-based materials and chip components
          used in electronics and precision manufacturing.
        </p>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>Roll Materials</span>
          <span>Electronics</span>
          <span>Packaging</span>
          <span>Industrial Lines</span>
        </div>
      </section>

      <!-- Related -->
      <section class="detail-block">
        <div class="related-slider-wrap" data-current="roll-chip-cleaner">
          <h2>Related Products</h2>
          <div class="related-slider-track">
            <a href="/products/cleaning-machine/polarizer-cleaner"><img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" /><h4>Polarizer Cleaning</h4></a>
            <a href="/products/cleaning-machine/fpc-4-axis-cleaner"><img src="/assets/img/cleaning-machine/fpc-4-axis-cleaner.jpg" /><h4>FPC 4 Axis</h4></a>
            <a href="/products/cleaning-machine/fpc-8-axis-cleaner"><img src="/assets/img/cleaning-machine/fpc-8-axis-cleaner.jpg" /><h4>FPC 8 Axis</h4></a>
            <a href="/products/cleaning-machine/optical-film-cleaner"><img src="/assets/img/cleaning-machine/optical.jpg" /><h4>Optical Film</h4></a>
            <a href="/products/cleaning-machine/lcm-cleaner"><img src="/assets/img/cleaning-machine/lcm-cleaner.jpg" /><h4>LCM Cleaning</h4></a>
            <a href="/products/cleaning-machine/pcb-cleaner"><img src="/assets/img/cleaning-machine/pcb-cleaner.jpg" /><h4>PCB Cleaning</h4></a>
            <a href="/products/cleaning-machine/pcb-vertical-cleaner"><img src="/assets/img/cleaning-machine/stick-pcb-vertical-cleaning-machine.jpg" /><h4>PCB Vertical</h4></a>
            <a href="/products/cleaning-machine/smt-cleaner"><img src="/assets/img/cleaning-machine/smt-cleaner.jpg" /><h4>SMT</h4></a>
            <a href="/products/cleaning-machine/backlight-cleaner"><img src="/assets/img/cleaning-machine/backlight-cleaner.jpg" /><h4>Backlight</h4></a>
            <a href="/products/cleaning-machine/ccl-cleaner"><img src="/assets/img/cleaning-machine/ccl-cleaner.jpg" /><h4>CCL</h4></a>
            <a href="/products/cleaning-machine/inspection-cleaner"><img src="/assets/img/cleaning-machine/inspection-cleaner.jpg" /><h4>Inspection</h4></a>
          </div>
        </div>
      </section>

    </div>
  </section>
</ProductLayout>