---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="Stick CCL Cleaning Machine ST DT1340 | DGSDK">
  <section class="product-detail-page">
    <div class="container">

      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/cleaning-machine">Cleaning Machine</a>
        <span>/</span>
        <span>Stick CCL Cleaning Machine ST DT1340</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/cleaning-machine/ccl-cleaner.jpg"
              alt="Stick CCL Cleaning Machine ST DT1340"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/cleaning-machine/ccl-cleaner.jpg"
              alt="Stick CCL Cleaning Machine ST DT1340 Thumbnail 1"
              data-full="/assets/img/cleaning-machine/ccl-cleaner.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>Stick CCL Cleaning Machine ST DT1340</h1>
          <p class="product-short-desc">
            Industrial cleaning equipment designed for copper clad laminate surface preparation,
            helping remove dust, particles, fibers, and static contamination before downstream
            board and laminate processing.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>CCL Preparation</h4>
              <p>Designed for reliable surface cleaning before laminate processing.</p>
            </div>
            <div class="highlight-item">
              <h4>Contamination Control</h4>
              <p>Helps improve material cleanliness and reduce production defects.</p>
            </div>
            <div class="highlight-item">
              <h4>Factory-grade Stability</h4>
              <p>Stable structure supports continuous industrial operation.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          The Stick CCL Cleaning Machine ST DT1340 is developed for copper clad laminate cleaning
          applications where stable contamination control is required before downstream manufacturing.
        </p>
        <p>
          It improves surface cleanliness, reduces contamination-related quality risks,
          and supports better process stability in laminate and board production environments.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>Designed for copper clad laminate surface cleaning</li>
          <li>Helps remove dust, particles, fibers, and static contamination</li>
          <li>Improves material cleanliness before downstream processes</li>
          <li>Suitable for industrial continuous production lines</li>
          <li>Reliable structure for long-term factory use</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Specialized</h3>
            <p>Developed specifically for CCL and related laminate cleaning applications.</p>
          </div>

          <div class="advantage-card yellow">
            <h3>Effective</h3>
            <p>Improves cleanliness and helps reduce contamination-related defects.</p>
          </div>

          <div class="advantage-card green">
            <h3>Durable</h3>
            <p>Stable industrial machine structure supports long-term production use.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr><td>Application</td><td>CCL Surface Cleaning</td></tr>
            <tr><td>Model</td><td>ST DT1340</td></tr>
            <tr><td>Cleaning Target</td><td>Dust, particles, fibers, static contamination</td></tr>
            <tr><td>Suitable Material</td><td>Copper clad laminate (CCL)</td></tr>
            <tr><td>Operation Mode</td><td>Automatic</td></tr>
            <tr><td>Production Stage</td><td>Before board / laminate downstream processing</td></tr>
            <tr><td>Control System</td><td>Industrial Control</td></tr>
            <tr><td>Dimensions</td><td>Customized</td></tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>CCL Production</span>
          <span>Laminates</span>
          <span>Raw Board Materials</span>
          <span>Surface Preparation</span>
          <span>Industrial Manufacturing</span>
          <span>Precision Cleaning</span>
        </div>
      </section>

