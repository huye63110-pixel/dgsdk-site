---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="Stick CCL Cleaning Machine ST DT1340 | DGSDK"
  description="CCL cleaning machine for copper clad laminate surface preparation. Removes dust and contamination from CCL substrates before PCB manufacturing."
  image="/assets/img/cleaning-machine/ccl-cleaner.jpg">
  <section class="product-detail-page">
    <div class="container">

      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/cleaning-machine">Cleaning Machine</a>
        <span>/</span>
        <span>Stick CCL Cleaning Machine ST DT1340</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/cleaning-machine/ccl-cleaner.jpg"
              alt="Stick CCL Cleaning Machine ST DT1340"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/cleaning-machine/ccl-cleaner.jpg"
              alt="Stick CCL Cleaning Machine ST DT1340 Thumbnail 1"
              data-full="/assets/img/cleaning-machine/ccl-cleaner.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>Stick CCL Cleaning Machine ST DT1340</h1>
          <p class="product-short-desc">
            Model ST-DT1340 — CCL surface cleaning machine featuring all-new magnetic levitation
            drive design, special precision adhesive rollers, and integrated intelligent static
            elimination for high-yield copper clad laminate processing.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Magnetic Levitation Drive</h4>
              <p>All-new frictionless drive — smooth, stable, no noise, no vibration.</p>
            </div>
            <div class="highlight-item">
              <h4>Precision Adhesive Rollers</h4>
              <p>Special high-efficiency adhesive rollers improve post-cleaning CCL yield.</p>
            </div>
            <div class="highlight-item">
              <h4>Integrated Static Elimination</h4>
              <p>Intelligent static eliminator rapidly clears surface charge from copper foil materials.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          The Stick CCL Cleaning Machine ST-DT1340 is developed specifically for copper clad laminate
          (CCL) surface cleaning applications. Its all-new magnetic levitation drive delivers smooth,
          stable operation with no noise and no vibration, ensuring thin copper foil materials are
          never deformed or corner-folded during processing.
        </p>
        <p>
          Special precision adhesive cleaning rollers provide high dust removal efficiency, while
          the integrated intelligent static elimination unit rapidly neutralizes surface charge —
          together improving post-cleaning CCL yield for PCB manufacturing and electronics production.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>All-new magnetic levitation drive design — smooth, stable operation; no noise, no vibration</li>
          <li>Thin cleaning layer material — no deformation or corner folding of copper foil</li>
          <li>Special precision adhesive cleaning rollers — high dust removal efficiency, improves post-cleaning CCL yield</li>
          <li>Integrated intelligent static elimination unit — rapidly eliminates surface static from materials</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Magnetic Levitation</h3>
            <p>Frictionless drive system eliminates noise and vibration for gentle, stable material transport.</p>
          </div>

          <div class="advantage-card yellow">
            <h3>High Yield</h3>
            <p>Precision adhesive rollers and static elimination work together to reduce contamination defects.</p>
          </div>

          <div class="advantage-card green">
            <h3>Material Safe</h3>
            <p>Thin cleaning layer design prevents deformation of delicate copper foil substrates.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr><td>Model</td><td>ST-DT1340</td></tr>
            <tr><td>Application</td><td>CCL (Copper Clad Laminate) Surface Cleaning</td></tr>
            <tr><td>Cleaning Width (max)</td><td>1400mm</td></tr>
            <tr><td>Drive System</td><td>Magnetic Levitation (frictionless)</td></tr>
            <tr><td>Cleaning Method</td><td>Adhesive roller + static elimination</td></tr>
            <tr><td>Material Compatibility</td><td>CCL copper foil, thin film materials</td></tr>
            <tr><td>Control System</td><td>Intelligent PLC control</td></tr>
            <tr><td>Static Elimination</td><td>Integrated intelligent static eliminator</td></tr>
            <tr><td>Power Supply</td><td>220V / 50Hz</td></tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>CCL Processing</span>
          <span>PCB Manufacturing</span>
          <span>Electronics Manufacturing</span>
          <span>Copper Foil Processing</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="ccl-cleaner">
          <div class="related-slider-header">
            <h2>Related Products</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>

          <div class="related-slider-track">
            <a href="/products/cleaning-machine/polarizer-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="Polarizer Precision Cleaning Machine" loading="lazy" /><h4>Polarizer Precision Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/fpc-4-axis-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/fpc-4-axis-cleaner.jpg" alt="FPC 4-Axis High Precision Cleaning Machine" loading="lazy" /><h4>FPC 4-Axis High Precision Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/fpc-8-axis-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/fpc-8-axis-cleaner.jpg" alt="FPC 8-Axis Advanced Cleaning Machine" loading="lazy" /><h4>FPC 8-Axis Advanced Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/optical-film-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/optical.jpg" alt="Large Size Optical Film Cleaning Machine" loading="lazy" /><h4>Large Size Optical Film Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/lcm-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/lcm-cleaner.jpg" alt="LCM Module Industrial Cleaning Machine" loading="lazy" /><h4>LCM Module Industrial Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/pcb-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/pcb-cleaner.jpg" alt="PCB Surface Cleaning Machine" loading="lazy" /><h4>PCB Surface Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/pcb-vertical-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/stick-pcb-vertical-cleaning-machine.jpg" alt="PCB Vertical Cleaning System" loading="lazy" /><h4>PCB Vertical Cleaning System</h4></a>
            <a href="/products/cleaning-machine/roll-chip-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/roll-chip-cleaner.jpg" alt="Roll Chip Universal Cleaning Machine" loading="lazy" /><h4>Roll Chip Universal Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/smt-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/smt-cleaner.jpg" alt="SMT Inline Cleaning Machine (SMT600 Series)" loading="lazy" /><h4>SMT Inline Cleaning Machine (SMT600 Series)</h4></a>
            <a href="/products/cleaning-machine/backlight-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/backlight-cleaner.jpg" alt="Backlight Panel Cleaning Machine" loading="lazy" /><h4>Backlight Panel Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/inspection-cleaner" class="related-slide-card"><img src="/assets/img/cleaning-machine/inspection-cleaner.jpg" alt="Inspection Stage Cleaning Machine (STXT Series)" loading="lazy" /><h4>Inspection Stage Cleaning Machine (STXT Series)</h4></a>
          </div>
        </div>
      </section>

    </div>
  </section>
</ProductLayout>