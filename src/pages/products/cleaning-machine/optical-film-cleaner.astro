---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="Large Size Optical Film Cleaning Machine | DGSDK">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/cleaning-machine">Cleaning Machine</a>
        <span>/</span>
        <span>Large Size Optical Film Cleaning Machine</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img id="mainProductImage" src="/assets/img/cleaning-machine/optical.jpg" alt="Large Size Optical Film Cleaning Machine" />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

        </div>

        <div class="product-summary">
          <h1>Large Size Optical Film Cleaning Machine</h1>
          <p class="product-short-desc">
            Industrial cleaning equipment designed for large-format optical film materials,
            helping remove dust, fibers, particles, and static contamination before lamination,
            inspection, and downstream processing.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Large Format Processing</h4>
              <p>Suitable for wide optical film and sheet material cleaning applications.</p>
            </div>
            <div class="highlight-item">
              <h4>High Surface Cleanliness</h4>
              <p>Helps reduce dust and particles before critical manufacturing steps.</p>
            </div>
            <div class="highlight-item">
              <h4>Stable Industrial Use</h4>
              <p>Designed for reliable long-term production line operation.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          The Large Size Optical Film Cleaning Machine is designed for cleaning wide optical films,
          display films, and sheet materials used in precision manufacturing applications.
        </p>
        <p>
          It helps improve surface cleanliness before inspection, coating, lamination, and packaging,
          reducing contamination-related defects and improving overall process stability.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>Designed for large-size optical film and sheet cleaning</li>
          <li>Helps remove dust, fibers, particles, and static contamination</li>
          <li>Suitable for display, optical, and precision sheet materials</li>
          <li>Improves cleanliness before lamination, inspection, and packaging</li>
          <li>Stable industrial structure for continuous production use</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Wide Coverage</h3>
            <p>Supports cleaning of larger-width optical materials and sheet products.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>High Efficiency</h3>
            <p>Improves cleaning consistency before downstream high-precision processes.</p>
          </div>
          <div class="advantage-card green">
            <h3>Professional</h3>
            <p>Designed for industrial optical film and display-related manufacturing environments.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr><td>Application</td><td>Large Size Optical Film Cleaning</td></tr>
            <tr><td>Cleaning Target</td><td>Dust, fibers, particles, static contamination</td></tr>
            <tr><td>Suitable Material</td><td>Optical films, display sheets, large-format film materials</td></tr>
            <tr><td>Operation Mode</td><td>Automatic</td></tr>
            <tr><td>Cleaning Width</td><td>Customized</td></tr>
            <tr><td>Control System</td><td>Industrial Control</td></tr>
            <tr><td>Production Stage</td><td>Before lamination / coating / inspection / packaging</td></tr>
            <tr><td>Dimensions</td><td>Customized</td></tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>Optical Film</span>
          <span>Display Film</span>
          <span>Large Sheet Materials</span>
          <span>Inspection Preparation</span>
          <span>Lamination</span>
          <span>Packaging</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="optical-film-cleaner">
