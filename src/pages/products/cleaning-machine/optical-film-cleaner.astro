---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="Large Size Optical Film Cleaning Machine | DGSDK"
  description="Large-format optical film cleaning machine for display and optical manufacturing. Removes particles and static from wide optical film substrates."
  image="/assets/img/cleaning-machine/optical.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/cleaning-machine">Cleaning Machine</a>
        <span>/</span>
        <span>Large Size Optical Film Cleaning Machine</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img id="mainProductImage" src="/assets/img/cleaning-machine/optical.jpg" alt="Large Size Optical Film Cleaning Machine" loading="lazy" />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

        </div>

        <div class="product-summary">
          <h1>Large Size Optical Film Cleaning Machine</h1>
          <p class="product-short-desc">
            STFK Series (STFK338 / STFK448 / STFK738 / STFK948) — large size optical film cleaning
            machine with magnetic levitation drive, precision adhesive rollers, and integrated intelligent
            static elimination for display and optical film manufacturing.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Multiple Width Options</h4>
              <p>Available in 338mm, 448mm, 738mm, and 948mm cleaning widths for various film sizes.</p>
            </div>
            <div class="highlight-item">
              <h4>Magnetic Levitation Drive</h4>
              <p>Smooth, stable, no noise or vibration — optical film surfaces stay intact.</p>
            </div>
            <div class="highlight-item">
              <h4>Integrated Static Elimination</h4>
              <p>Removes static charge from optical film surfaces to prevent contamination defects.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          The Large Size Optical Film Cleaning Machine STFK Series is designed for cleaning optical films,
          diffuser sheets, prism sheets, polarizers, and other large-format display materials. Available in
          four width configurations (STFK338, STFK448, STFK738, STFK948), the series covers a wide range
          of film sizes used in display and optical manufacturing.
        </p>
        <p>
          The all-new magnetic levitation drive provides smooth, stable operation with no noise or vibration,
          ensuring delicate optical film materials are never deformed or creased. Special precision adhesive
          cleaning rollers deliver high efficiency cleaning that improves optical film yield rate, while the
          integrated intelligent static eliminator removes static charge from film surfaces.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>All-new magnetic levitation drive design — smooth, stable operation; no noise, no vibration</li>
          <li>Thin cleaning layer — does not deform or crease optical film materials</li>
          <li>Special precision adhesive cleaning rollers — high efficiency cleaning, improves optical film yield rate</li>
          <li>Integrated intelligent static elimination — removes static charge from optical film surfaces</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Multiple Widths</h3>
            <p>Four model variants cover 338mm to 948mm optical film widths for display manufacturing.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>Film-Safe</h3>
            <p>Magnetic levitation and thin cleaning layer prevent optical film deformation or scratching.</p>
          </div>
          <div class="advantage-card green">
            <h3>Static-Free</h3>
            <p>Integrated intelligent static eliminator keeps optical film surfaces charge-free.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr><td>Model Series</td><td>STFK338 / STFK448 / STFK738 / STFK948</td></tr>
            <tr><td>Application</td><td>Large size optical film surface cleaning</td></tr>
            <tr><td>Drive System</td><td>Magnetic Levitation</td></tr>
            <tr><td>Cleaning Method</td><td>Adhesive roller</td></tr>
            <tr><td>Material Compatibility</td><td>Optical films, diffuser sheets, prism sheets, polarizers</td></tr>
            <tr><td>Static Elimination</td><td>Integrated intelligent static eliminator</td></tr>
            <tr><td>Available Widths</td><td>338mm / 448mm / 738mm / 948mm</td></tr>
            <tr><td>Power Supply</td><td>220V / 50Hz</td></tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>Optical Film Processing</span>
          <span>Display Manufacturing</span>
          <span>Polarizer Production</span>
          <span>Diffuser Sheet Cleaning</span>
        </div>
      </section>

