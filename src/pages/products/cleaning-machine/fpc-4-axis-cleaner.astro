---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="FPC 4-Axis High Precision Cleaning Machine | DGSDK">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/cleaning-machine">Cleaning Machine</a>
        <span>/</span>
        <span>FPC 4-Axis High Precision Cleaning Machine</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img id="mainProductImage" src="/assets/img/cleaning-machine/Stick FPC 4-axis cleaning machine.jpg" alt="FPC 4-Axis High Precision Cleaning Machine" />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img class="thumb-image active-thumb" src="/assets/img/cleaning-machine/Stick FPC 4-axis cleaning machine.jpg" alt="FPC 4-Axis High Precision Cleaning Machine Thumbnail 1" data-full="/assets/img/cleaning-machine/Stick FPC 4-axis cleaning machine.jpg" />
          </div>
        </div>

        <div class="product-summary">
          <h1>FPC 4-Axis High Precision Cleaning Machine</h1>
          <p class="product-short-desc">
            Precision 4-axis cleaning solution developed for flexible circuit materials, helping improve surface cleanliness
            before printing, bonding, inspection, and other high-precision manufacturing steps.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>4-Axis Motion System</h4>
              <p>Supports stable transport and precise cleaning control.</p>
            </div>
            <div class="highlight-item">
              <h4>Flexible Material Ready</h4>
              <p>Suitable for delicate FPC and thin-film type materials.</p>
            </div>
            <div class="highlight-item">
              <h4>High Precision Cleaning</h4>
              <p>Improves product cleanliness before critical downstream processes.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          The FPC 4-Axis High Precision Cleaning Machine is designed for cleaning flexible printed circuits
          and other sensitive materials that require reliable contamination control.
        </p>
        <p>
          It helps remove dust, fibers, particles, and static contamination while maintaining stable handling,
          making it suitable for high-precision electronics production environments.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>4-axis motion structure for precise and stable cleaning</li>
          <li>Suitable for FPC and delicate flexible materials</li>
          <li>Improves cleanliness before printing, bonding, and inspection</li>
          <li>Stable industrial cleaning performance</li>
          <li>Designed for advanced electronics manufacturing lines</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Precise</h3>
            <p>Optimized for high-precision material handling and cleaning.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>Gentle</h3>
            <p>Suitable for thin and flexible materials that require careful processing.</p>
          </div>
          <div class="advantage-card green">
            <h3>Stable</h3>
            <p>Reliable machine structure supports continuous industrial production.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr><td>Application</td><td>FPC / Flexible Material Cleaning</td></tr>
            <tr><td>Axis System</td><td>4-Axis</td></tr>
            <tr><td>Cleaning Target</td><td>Dust, fibers, particles, static contamination</td></tr>
            <tr><td>Suitable Material</td><td>FPC, thin flexible electronic materials</td></tr>
            <tr><td>Operation Mode</td><td>Automatic</td></tr>
            <tr><td>Control System</td><td>Industrial Motion Control</td></tr>
            <tr><td>Production Stage</td><td>Before printing / bonding / inspection</td></tr>
            <tr><td>Dimensions</td><td>Customized</td></tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>FPC Manufacturing</span>
          <span>Flexible Electronics</span>
          <span>Precision Cleaning</span>
          <span>Inspection Preparation</span>
          <span>Bonding</span>
          <span>Automation Lines</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="fpc-4-axis-cleaner">
          <div class="related-slider-header">
            <h2>Related Products</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/products/cleaning-machine/polarizer-cleaner" class="related-slide-card" data-key="polarizer-cleaner"><img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="Polarizer Precision Cleaning Machine" /><h4>Polarizer Precision Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/fpc-4-axis-cleaner" class="related-slide-card" data-key="fpc-4-axis-cleaner"><img src="/assets/img/cleaning-machine/Stick FPC 4-axis cleaning machine.jpg" alt="FPC 4-Axis High Precision Cleaning Machine" /><h4>FPC 4-Axis High Precision Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/fpc-8-axis-cleaner" class="related-slide-card" data-key="fpc-8-axis-cleaner"><img src="/assets/img/cleaning-machine/Stick FPC8 Axis Cleaning Machine.jpg" alt="FPC 8-Axis Advanced Cleaning Machine" /><h4>FPC 8-Axis Advanced Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/optical-film-cleaner" class="related-slide-card" data-key="optical-film-cleaner"><img src="/assets/img/cleaning-machine/optical.jpg" alt="Large Size Optical Film Cleaning Machine" /><h4>Large Size Optical Film Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/lcm-cleaner" class="related-slide-card" data-key="lcm-cleaner"><img src="/assets/img/cleaning-machine/Stick LCM Cleaning Machine.jpg" alt="LCM Module Industrial Cleaning Machine" /><h4>LCM Module Industrial Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/pcb-cleaner" class="related-slide-card" data-key="pcb-cleaner"><img src="/assets/img/cleaning-machine/Stick PCB cleaning machine.jpg" alt="PCB Surface Cleaning Machine" /><h4>PCB Surface Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/pcb-vertical-cleaner" class="related-slide-card" data-key="pcb-vertical-cleaner"><img src="/assets/img/cleaning-machine/stick-pcb-vertical-cleaning-machine.jpg" alt="PCB Vertical Cleaning System" /><h4>PCB Vertical Cleaning System</h4></a>
            <a href="/products/cleaning-machine/roll-chip-cleaner" class="related-slide-card" data-key="roll-chip-cleaner"><img src="/assets/img/cleaning-machine/Stick Roll Chip Universal Cleaning Machine .jpg" alt="Roll Chip Universal Cleaning Machine" /><h4>Roll Chip Universal Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/smt-cleaner" class="related-slide-card" data-key="smt-cleaner"><img src="/assets/img/cleaning-machine/Stick SMT cleaning machine-SMT600.jpg" alt="SMT Inline Cleaning Machine (SMT600 Series)" /><h4>SMT Inline Cleaning Machine (SMT600 Series)</h4></a>
            <a href="/products/cleaning-machine/backlight-cleaner" class="related-slide-card" data-key="backlight-cleaner"><img src="/assets/img/cleaning-machine/backlight-cleaner.jpg" alt="Backlight Panel Cleaning Machine" /><h4>Backlight Panel Cleaning Machine</h4></a>
            <a href="/products/cleaning-machine/ccl-cleaner" class="related-slide-card" data-key="ccl-cleaner"><img src="/assets/img/cleaning-machine/ccl-cleaner.jpg" alt="Stick CCL Cleaning Machine ST DT1340" /><h4>Stick CCL Cleaning Machine ST DT1340</h4></a>
            <a href="/products/cleaning-machine/inspection-cleaner" class="related-slide-card" data-key="inspection-cleaner"><img src="/assets/img/cleaning-machine/inspection-cleaner.jpg" alt="Inspection Stage Cleaning Machine (STXT Series)" /><h4>Inspection Stage Cleaning Machine (STXT Series)</h4></a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ProductLayout>