---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="Robotic Automatic Loading and Unloading Cleaning Machine | DGSDK">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/automation">Automation Equipment</a>
        <span>/</span>
        <span>Robotic Automatic Loading and Unloading Cleaning Machine</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>

            <img
              id="mainProductImage"
              src="/assets/img/automation/product-b.jpg"
              alt="Robotic Automatic Loading and Unloading Cleaning Machine"
            />

            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/automation/product-b.jpg"
              alt="Robotic Automatic Loading and Unloading Cleaning Machine Thumbnail 1"
              data-full="/assets/img/automation/product-b.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>Robotic Automatic Loading and Unloading Cleaning Machine</h1>
          <p class="product-short-desc">
            Automated cleaning equipment with mechanical loading and unloading support,
            designed to improve production efficiency, reduce manual handling, and maintain stable cleaning quality.
          </p>

          <div class="product-actions">
            <button class="quote-btn" id="openQuoteModal" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Automatic Handling</h4>
              <p>Supports mechanical automatic loading and unloading to reduce manual work.</p>
            </div>
            <div class="highlight-item">
              <h4>Stable Cleaning</h4>
              <p>Designed for repeatable cleaning quality in industrial production environments.</p>
            </div>
            <div class="highlight-item">
              <h4>Higher Efficiency</h4>
              <p>Improves workflow continuity and supports automated manufacturing operation.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          The Robotic Automatic Loading and Unloading Cleaning Machine is designed for
          industrial production environments that require efficient handling, stable cleaning,
          and reduced labor dependence. It combines cleaning functions with automatic loading
          and unloading support to improve process continuity.
        </p>
        <p>
          This equipment is suitable for customers seeking a practical automation solution
          that improves consistency, reduces operating errors, and supports scalable production.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>Integrated automatic loading and unloading support</li>
          <li>Stable cleaning performance for industrial products</li>
          <li>Reduced manual handling and improved workflow consistency</li>
          <li>Suitable for automated and semi-automated production lines</li>
          <li>Supports customized process logic according to project needs</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Automation</h3>
            <p>Helps reduce labor intensity and supports continuous equipment operation.</p>
          </div>

          <div class="advantage-card yellow">
            <h3>Process Stability</h3>
            <p>Improves repeatability and cleaning consistency in production.</p>
          </div>

          <div class="advantage-card green">
            <h3>Custom Integration</h3>
            <p>Can be adapted for different product sizes, handling logic, and line layouts.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr>
              <td>Product Type</td>
              <td>Automation Cleaning Equipment</td>
            </tr>
            <tr>
              <td>Main Function</td>
              <td>Automatic Loading / Cleaning / Unloading</td>
            </tr>
            <tr>
              <td>Application</td>
              <td>Industrial automation and cleaning process integration</td>
            </tr>
            <tr>
              <td>Control Mode</td>
              <td>Automatic / Semi-automatic</td>
            </tr>
            <tr>
              <td>Structure</td>
              <td>Customized Automation Equipment</td>
            </tr>
            <tr>
              <td>Installation</td>
              <td>Production Line / Workstation</td>
            </tr>
            <tr>
              <td>Material Handling</td>
              <td>Automatic Loading and Unloading Support</td>
            </tr>
            <tr>
              <td>Customization</td>
              <td>Available According to Process Requirements</td>
            </tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>Automation Production</span>
          <span>Cleaning Systems</span>
          <span>Industrial Handling</span>
          <span>Mechanical Loading</span>
          <span>OEM Projects</span>
          <span>Custom Machinery</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="product-b">
          <div class="related-slider-header">
            <h2>Related Products</h2>

            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>

          <div class="related-slider-track">
            <a href="/products/automation/product-a" class="related-slide-card" data-key="product-a">
              <img src="/assets/img/automation/product-a.jpg" alt="Diffusion Plate Cleaning and Inspection Production Line" loading="lazy" />
              <h4>Diffusion Plate Cleaning and Inspection Production Line</h4>
            </a>

            <a href="/products/automation/product-b" class="related-slide-card" data-key="product-b">
              <img src="/assets/img/automation/product-b.jpg" alt="Robotic Automatic Loading and Unloading Cleaning Machine" loading="lazy" />
              <h4>Robotic Automatic Loading and Unloading Cleaning Machine</h4>
            </a>

            <a href="/products/automation/product-c" class="related-slide-card" data-key="product-c">
              <img src="/assets/img/automation/product-c.jpg" alt="Polarizer Absorption Axis Angle Measuring System" loading="lazy" />
              <h4>Polarizer Absorption Axis Angle Measuring System</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>

  <div class="quote-modal" id="quoteModal">
    <div class="quote-modal-overlay" id="closeQuoteModal"></div>

    <div class="quote-modal-content">
      <button class="quote-modal-close" id="closeQuoteModalBtn" type="button">×</button>

      <h2>Get a Quote</h2>
      <p>
        If you have any questions about this product, please leave your contact
        details and we will get back to you as soon as possible.
      </p>

      <form class="quote-form">
        <input type="text" placeholder="Your Name" required />
        <input type="email" placeholder="Your Email" required />
        <input type="text" placeholder="Your Phone" />
        <textarea rows="5" placeholder="Your Message"></textarea>
        <button type="submit">Send Message</button>
      </form>
    </div>
  </div>

  <script is:inline>
    const openBtn = document.getElementById('openQuoteModal');
    const modal = document.getElementById('quoteModal');
    const closeOverlay = document.getElementById('closeQuoteModal');
    const closeBtn = document.getElementById('closeQuoteModalBtn');

    if (openBtn && modal) {
      openBtn.addEventListener('click', () => modal.classList.add('active'));
    }

    if (closeOverlay && modal) {
      closeOverlay.addEventListener('click', () => modal.classList.remove('active'));
    }

    if (closeBtn && modal) {
      closeBtn.addEventListener('click', () => modal.classList.remove('active'));
    }

    const mainImage = document.getElementById('mainProductImage');
    const thumbs = document.querySelectorAll('.thumb-image');
    const prevBtn = document.getElementById('prevImage');
    const nextBtn = document.getElementById('nextImage');

    let currentIndex = 0;
    const imageList = Array.from(thumbs).map((thumb) => thumb.dataset.full);

    function updateMainImage(index) {
      if (!mainImage || !thumbs.length) return;
      currentIndex = index;
      mainImage.src = imageList[index];

      thumbs.forEach((thumb, i) => {
        thumb.classList.toggle('active-thumb', i === index);
      });
    }

    thumbs.forEach((thumb, index) => {
      thumb.addEventListener('click', () => updateMainImage(index));
    });

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        const newIndex = currentIndex === 0 ? imageList.length - 1 : currentIndex - 1;
        updateMainImage(newIndex);
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        const newIndex = currentIndex === imageList.length - 1 ? 0 : currentIndex + 1;
        updateMainImage(newIndex);
      });
    }
  </script>
</ProductLayout>