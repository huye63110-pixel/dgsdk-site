---
import ProductLayout from '../../../layouts/ProductLayout.astro';
---

<ProductLayout title="Robotic Automatic Loading and Unloading Cleaning Machine | DGSDK"
  description="Industrial automation equipment for precision manufacturing integration. Custom-built automation solutions for electronics, optical, and mechanical production lines."
  image="/assets/img/automation/product-b.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/products">Products</a>
        <span>/</span>
        <a href="/products/automation">Automation Equipment</a>
        <span>/</span>
        <span>Robotic Automatic Loading and Unloading Cleaning Machine</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>

            <img
              id="mainProductImage"
              src="/assets/img/automation/product-b.jpg"
              alt="Robotic Automatic Loading and Unloading Cleaning Machine"
            />

            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/automation/product-b.jpg"
              alt="Robotic Automatic Loading and Unloading Cleaning Machine Thumbnail 1"
              data-full="/assets/img/automation/product-b.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>Robotic Automatic Loading and Unloading Cleaning Machine</h1>
          <p class="product-short-desc">
            Automated cleaning equipment with mechanical loading and unloading support,
            designed to improve production efficiency, reduce manual handling, and maintain stable cleaning quality.
          </p>

          <div class="product-actions">
            <button class="quote-btn" id="openQuoteModal" type="button">Get a Quote</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Automatic Handling</h4>
              <p>Supports mechanical automatic loading and unloading to reduce manual work.</p>
            </div>
            <div class="highlight-item">
              <h4>Stable Cleaning</h4>
              <p>Designed for repeatable cleaning quality in industrial production environments.</p>
            </div>
            <div class="highlight-item">
              <h4>Higher Efficiency</h4>
              <p>Improves workflow continuity and supports automated manufacturing operation.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Product Description</h2>
        <p>
          The Robotic Automatic Loading and Unloading Cleaning Machine is designed for
          industrial production environments that require efficient handling, stable cleaning,
          and reduced labor dependence. It combines cleaning functions with automatic loading
          and unloading support to improve process continuity.
        </p>
        <p>
          This equipment is suitable for customers seeking a practical automation solution
          that improves consistency, reduces operating errors, and supports scalable production.
        </p>
      </section>

      <section class="detail-block">
        <h2>Product Features</h2>
        <ul class="feature-list">
          <li>Integrated automatic loading and unloading support</li>
          <li>Stable cleaning performance for industrial products</li>
          <li>Reduced manual handling and improved workflow consistency</li>
          <li>Suitable for automated and semi-automated production lines</li>
          <li>Supports customized process logic according to project needs</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Technical Advantages</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Automation</h3>
            <p>Helps reduce labor intensity and supports continuous equipment operation.</p>
          </div>

          <div class="advantage-card yellow">
            <h3>Process Stability</h3>
            <p>Improves repeatability and cleaning consistency in production.</p>
          </div>

          <div class="advantage-card green">
            <h3>Custom Integration</h3>
            <p>Can be adapted for different product sizes, handling logic, and line layouts.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Technical Specifications</h2>
        <div class="spec-table-wrap">
          <table class="spec-table">
            <tr>
              <td>Product Type</td>
              <td>Automation Cleaning Equipment</td>
            </tr>
            <tr>
              <td>Main Function</td>
              <td>Automatic Loading / Cleaning / Unloading</td>
            </tr>
            <tr>
              <td>Application</td>
              <td>Industrial automation and cleaning process integration</td>
            </tr>
            <tr>
              <td>Control Mode</td>
              <td>Automatic / Semi-automatic</td>
            </tr>
            <tr>
              <td>Structure</td>
              <td>Customized Automation Equipment</td>
            </tr>
            <tr>
              <td>Installation</td>
              <td>Production Line / Workstation</td>
            </tr>
            <tr>
              <td>Material Handling</td>
              <td>Automatic Loading and Unloading Support</td>
            </tr>
            <tr>
              <td>Customization</td>
              <td>Available According to Process Requirements</td>
            </tr>
          </table>
        </div>
      </section>

      <section class="detail-block">
        <h2>Industry Applications</h2>
        <div class="application-tags">
          <span>Automation Production</span>
          <span>Cleaning Systems</span>
          <span>Industrial Handling</span>
          <span>Mechanical Loading</span>
          <span>OEM Projects</span>
          <span>Custom Machinery</span>
        </div>
      </section>


      <section class="detail-block">
        <h2>Application Scenarios</h2>
        <div class="scenario-list">
          <div class="scenario-item">
            <h3>Automated Cleaning Line Loading and Unloading</h3>
            <p>Manual loading and unloading of cleaning machines is a labor-intensive process that introduces contamination risk from operator handling and creates throughput variability based on operator speed. Robotic automatic loading and unloading integrates with the cleaning machine to provide consistent, high-speed material handling that eliminates these variables and allows the cleaning machine to run at its designed throughput without a manual bottleneck.</p>
          </div>
          <div class="scenario-item">
            <h3>Electronics Component Handling Automation</h3>
            <p>PCBs, display panels, FPCs, and optical components are ESD-sensitive and easily scratched by manual handling. Robotic handling with appropriate end-effectors (vacuum cups, edge grippers) eliminates the risk of ESD damage, fingerprints, and scratches from operator contact, while also providing the consistent positioning accuracy that automated cleaning systems require for correct material alignment through the cleaning station.</p>
          </div>
          <div class="scenario-item">
            <h3>Lights-Out Manufacturing Integration</h3>
            <p>Manufacturers aiming for unattended or minimally attended production shifts use robotic loading and unloading systems to operate cleaning stages without full-time operators. The system handles the complete material transfer cycle — picking from the input magazine, loading the cleaning machine, unloading cleaned parts, and placing to the output magazine — without operator presence between setup and magazine changes.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Integration with Your Cleaning Process</h2>
        <p>The Robotic Automatic Loading and Unloading Cleaning Machine is configured around your specific product, cleaning machine, and production layout. Robot selection, end-effector design, input/output magazine design, and control system integration depend on the part dimensions, weight, fragility, and throughput requirement. Contact us with your product and process specifications to begin the design discussion.</p>
      </section>

      <section class="detail-block faq-block">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-list">
          <div class="faq-item">
            <h3 class="faq-question">What does the robotic loading and unloading system do?</h3>
            <p class="faq-answer">The system automates the material handling around a cleaning machine — picking parts from an input magazine or conveyor, loading them into the cleaning machine, unloading cleaned parts, and placing them to an output magazine or downstream conveyor. This eliminates manual handling steps that introduce contamination and throughput variability.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-question">What types of products can the robotic system handle?</h3>
            <p class="faq-answer">The system can be configured for PCBs, display panels, optical films, FPCs, precision components, and other flat or sheet-type products. End-effector design (vacuum cups, edge grippers, custom tooling) is matched to the product's dimensions, weight, and fragility requirements.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-question">Can the system handle ESD-sensitive components?</h3>
            <p class="faq-answer">Yes. ESD-safe end-effectors and ionizing systems can be incorporated into the robotic handling system for ESD-sensitive products. Specify your ESD requirements during the design phase.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-question">Is the system fully automatic or semi-automatic?</h3>
            <p class="faq-answer">Both modes are available. Fully automatic operation runs the complete load/clean/unload cycle without operator intervention between magazine changes. Semi-automatic mode requires an operator to initiate each cycle or to handle exceptional conditions. The control mode is configured to your operational requirement.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-question">How is the system integrated with the cleaning machine?</h3>
            <p class="faq-answer">The robotic system communicates with the cleaning machine's PLC via standard industrial interfaces (digital I/O, Profibus, EtherNet/IP, or similar) for synchronized operation. Integration specifications are confirmed during the design phase based on your cleaning machine's control system.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-question">What is the process for ordering a custom robotic system?</h3>
            <p class="faq-answer">Contact us with your product dimensions and weight, cleaning machine model, required throughput, and facility layout. We provide a design proposal covering robot selection, end-effector design, magazine design, and control integration, followed by a quotation and lead time.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="product-b">
          <div class="related-slider-header">
            <h2>Related Products</h2>

            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>

          <div class="related-slider-track">
            <a href="/products/automation/product-a" class="related-slide-card" data-key="product-a">
              <img src="/assets/img/automation/product-a.jpg" alt="Diffusion Plate Cleaning and Inspection Production Line" loading="lazy" />
              <h4>Diffusion Plate Cleaning and Inspection Production Line</h4>
            </a>

            <a href="/products/automation/product-b" class="related-slide-card" data-key="product-b">
              <img src="/assets/img/automation/product-b.jpg" alt="Robotic Automatic Loading and Unloading Cleaning Machine" loading="lazy" />
              <h4>Robotic Automatic Loading and Unloading Cleaning Machine</h4>
            </a>

            <a href="/products/automation/product-c" class="related-slide-card" data-key="product-c">
              <img src="/assets/img/automation/product-c.jpg" alt="Polarizer Absorption Axis Angle Measuring System" loading="lazy" />
              <h4>Polarizer Absorption Axis Angle Measuring System</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>

  <div class="quote-modal" id="quoteModal">
    <div class="quote-modal-overlay" id="closeQuoteModal"></div>

    <div class="quote-modal-content">
      <button class="quote-modal-close" id="closeQuoteModalBtn" type="button">×</button>

      <h2>Get a Quote</h2>
      <p>
        If you have any questions about this product, please leave your contact
        details and we will get back to you as soon as possible.
      </p>

      <form class="quote-form" id="quoteFormProduct" action="https://formspree.io/f/mvzlpdwy" method="POST">
        <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />
        <input type="text" name="name" placeholder="Your Name" required />
        <input type="email" name="email" placeholder="Your Email" required />
        <input type="text" name="phone" placeholder="Your Phone" />
        <textarea name="message" rows="5" placeholder="Your Message"></textarea>
        <button type="submit">Send Message</button>
      </form>
    </div>
  </div>

  <script is:inline>
    const openBtn = document.getElementById('openQuoteModal');
    const modal = document.getElementById('quoteModal');
    const closeOverlay = document.getElementById('closeQuoteModal');
    const closeBtn = document.getElementById('closeQuoteModalBtn');

    if (openBtn && modal) {
      openBtn.addEventListener('click', () => modal.classList.add('active'));
    }

    if (closeOverlay && modal) {
      closeOverlay.addEventListener('click', () => modal.classList.remove('active'));
    }

    if (closeBtn && modal) {
      closeBtn.addEventListener('click', () => modal.classList.remove('active'));
    }

    const quoteForm = document.getElementById('quoteFormProduct');
    if (quoteForm) {
      quoteForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const honeypot = quoteForm.querySelector('input[name="website"]');
        if (honeypot && honeypot.value !== '') return;
        const btn = quoteForm.querySelector('button[type="submit"]');
        if (btn) btn.disabled = true;
        try {
          const res = await fetch('https://formspree.io/f/mvzlpdwy', {
            method: 'POST',
            body: new FormData(quoteForm),
            headers: { 'Accept': 'application/json' }
          });
          if (res.ok) {
            alert('Message sent! We will contact you shortly.');
            if (modal) modal.classList.remove('active');
            quoteForm.reset();
          } else {
            alert('Error sending message. Please try again.');
          }
        } catch(err) {
          alert('Error sending message. Please try again.');
        } finally {
          if (btn) btn.disabled = false;
        }
      });
    }

    const mainImage = document.getElementById('mainProductImage');
    const thumbs = document.querySelectorAll('.thumb-image');
    const prevBtn = document.getElementById('prevImage');
    const nextBtn = document.getElementById('nextImage');

    let currentIndex = 0;
    const imageList = Array.from(thumbs).map((thumb) => thumb.dataset.full);

    function updateMainImage(index) {
      if (!mainImage || !thumbs.length) return;
      currentIndex = index;
      mainImage.src = imageList[index];

      thumbs.forEach((thumb, i) => {
        thumb.classList.toggle('active-thumb', i === index);
      });
    }

    thumbs.forEach((thumb, index) => {
      thumb.addEventListener('click', () => updateMainImage(index));
    });

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        const newIndex = currentIndex === 0 ? imageList.length - 1 : currentIndex - 1;
        updateMainImage(newIndex);
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        const newIndex = currentIndex === imageList.length - 1 ? 0 : currentIndex + 1;
        updateMainImage(newIndex);
      });
    }
  </script>

