---
import KoLayout from '../../layouts/KoLayout.astro';

const faqItems = [
  {
    question: '최소 주문 수량은 얼마인가요? 소량 시제품 주문도 가능한가요?',
    answer: '표준 최소 주문 수량은 제품에 따라 일반적으로 500개이지만, 일부 제품 카테고리는 100개부터 주문 가능합니다. 시제품용 소량 주문도 지원하며, 샘플 비용이 발생할 수 있지만 이후 대량 주문 시 차감되는 것이 일반적입니다. 일정 수량 이상의 혼합 주문에 대해서는 추가 취급 비용이 면제될 수 있습니다.'
  },
  {
    question: '결제 방법에는 어떤 것이 있나요?',
    answer: '전신환(T/T)을 주요 결제 수단으로 받으며, 일반적으로 30% 선불을 받고 나머지는 출하 전에 결제해 주십니다. 대량 주문의 경우 신용장(L/C) 협의도 가능합니다. 소액 샘플 주문에는 PayPal도 이용하실 수 있습니다. 거래 안전을 위해 견적 송장, 회사 등록 서류, 수출 관련 증빙 서류를 제공해 드립니다.'
  },
  {
    question: '납기는 얼마나 걸리나요? 긴급 주문도 가능한가요?',
    answer: '표준 생산 리드타임은 제품 종류와 주문 수량에 따라 다르지만, 샘플 확인 후 약 25~35 영업일입니다. 긴급 프로젝트의 경우 일정이 허용하는 범위 내에서 특급 생산을 협의할 수 있으며, 추가 비용이 발생할 수 있습니다. 일부 주문은 분할 납품 협의도 가능합니다.'
  },
  {
    question: '제품 품질은 어떻게 보증되나요?',
    answer: '원자재 검사, 제조 공정 중 검사, 출하 전 최종 검사를 포함한 포괄적인 품질 관리 프로세스를 실시합니다. 품질 관리 절차는 제품 성능의 일관성을 보장하기 위한 것입니다. 확인된 품질 문제가 발생한 경우 보충, 교체, 보상 등 상황에 맞는 해결책을 고객과 성실히 협의합니다.'
  },
  {
    question: 'OEM 또는 ODM 서비스를 제공하나요?',
    answer: '네, OEM과 ODM 서비스 모두 제공합니다. OEM 프로젝트에서는 고객이 도면, 사양 또는 브랜딩 요구 사항을 제공해 주시면 됩니다. ODM 프로젝트에서는 응용 요구 사항에 기반한 제품 개발 및 설계 지원이 가능합니다. 필요에 따라 비밀 유지 계약(NDA) 체결도 지원합니다.'
  },
  {
    question: '제품이 국제 인증 기준을 충족하나요?',
    answer: '제품 카테고리와 대상 시장에 따라 관련 국제 표준 적합성 증명을 제공할 수 있습니다. 일반적인 인증에는 ISO, CE, FCC, RoHS, REACH 등이 포함됩니다. 특별한 인증 요구 사항에 대해서는 프로젝트 필요에 맞는 절차를 협의할 수 있습니다.'
  },
  {
    question: '어떤 배송 방법을 지원하나요?',
    answer: '해상 운송, 항공 운송, 특급 배송, 철도 운송(목적지 및 화물 요건에 따라) 등 다양한 배송 방법을 지원합니다. 비용과 리드타임에 기반한 운송 제안이 가능하며, 고객이 지정하는 화물 대리인을 통한 발송도 지원합니다.'
  },
  {
    question: '관세 및 수입세 처리를 지원해 주나요?',
    answer: '상업 인보이스, 포장 명세서, 원산지 증명서(해당 시) 등 필요한 수출 서류 제공이 가능합니다. 수입 관세, 부가가치세, 통관 비용은 목적국과 제품의 HS 코드에 따라 다릅니다. 필요에 따라 일부 시장을 대상으로 DDP 또는 DDU 배송 협의도 가능합니다.'
  },
  {
    question: '샘플을 받을 수 있나요?',
    answer: '네, 평가용 제품 샘플을 제공해 드릴 수 있습니다. 샘플 비용과 배송 협의는 제품 종류 및 맞춤화 필요 여부에 따라 다릅니다. 대부분의 경우 샘플 비용은 이후 양산 주문 시 차감됩니다. 맞춤형 샘플의 제작 리드타임은 요구 사항의 복잡성에 따라 다릅니다.'
  },
  {
    question: '환율 변동에 어떻게 대응하나요?',
    answer: '견적에는 일반적으로 유효 기간이 있으며, 최종 가격은 주문 확인 시점의 환율에 따라 달라질 수 있습니다. 대형 프로젝트의 경우 적절한 상황에서 환율 리스크를 줄이기 위한 단계적 결제 또는 기타 실용적인 해결책을 협의할 수 있습니다.'
  }
];
---

<KoLayout
  title="자주 묻는 질문 | DGSDK"
  description="DGSDK 제품에 관한 자주 묻는 질문. 정전기 제거기, 세정기, 자동화 설비, 정밀 CNC 부품의 주문, 품질, 납기 등에 대한 정보."
  canonical="https://www.dg-sdk.com/ko/faq"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  })} />

  <section
    class="faq-hero"
    style="background: linear-gradient(rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.18)), url('/assets/img/faq/faq-bg.jpg') center/cover no-repeat;"
  >
    <div class="faq-hero-overlay"></div>
    <div class="container faq-hero-content">
      <span class="faq-hero-kicker">자주 묻는 질문</span>
      <h1>제품·응용·서비스에 관한 자주 묻는 질문 답변.</h1>
      <p>
        DGSDK 솔루션에 관한 자주 묻는 질문을 확인하세요. 산업 응용, 제품 카테고리, 맞춤 제조, 자동화 지원, 거래 방법 등을 다루고 있습니다.
      </p>
    </div>
  </section>

  <section class="faq-intro-section">
    <div class="container">
      <div class="faq-intro-box">
        <span class="faq-section-label">지원 및 정보</span>
        <h2>명확하고 실용적인 질문에 대한 답변.</h2>
        <p>이 페이지는 거래 시작 전에 고객이 저희 제품, 서비스, 산업 응용 역량을 충분히 이해하실 수 있도록 마련되었습니다.</p>
      </div>
    </div>
  </section>

  <section class="faq-main-section">
    <div class="container">
      <div class="faq-layout">
        <aside class="faq-side-panel">
          <div class="faq-side-card">
            <span class="faq-side-label">빠른 안내</span>
            <h3>최적의 솔루션을 찾는 데 도움이 필요하신가요?</h3>
            <p>
              이 페이지의 질문을 살펴보시거나, DGSDK에 직접 문의하여 제품 제안과 맞춤 산업 지원을 받으세요.
            </p>
            <div class="faq-side-actions">
              <a href="/ko/contact" class="faq-primary-btn">문의하기</a>
              <a href="/ko/products" class="faq-text-link">제품 보기</a>
            </div>
          </div>
        </aside>

        <div class="faq-content">
          <div class="faq-heading-block">
            <span class="faq-section-label">자주 묻는 질문</span>
            <h2>고객 및 파트너에게 자주 받는 질문.</h2>
            <p>제품 선정과 비즈니스 커뮤니케이션을 더 원활하게.</p>
          </div>

          <div class="faq-list">
            {faqItems.map((item, index) => (
              <details class="faq-item" open={index === 0}>
                <summary class="faq-question">
                  <span>{item.question}</span>
                  <span class="faq-icon"></span>
                </summary>
                <div class="faq-answer">
                  <p>{item.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-bottom-section">
    <div class="container">
      <div class="faq-bottom-panel">
        <div class="faq-bottom-copy">
          <span class="faq-section-label dark">아직 질문이 있으신가요?</span>
          <h2>응용 분야나 제품 요구 사항에 대해 상담하세요.</h2>
          <p>
            여기에 없는 질문이 있으시면, 저희 팀이 제품 선정, 응용 매칭, 맞춤형 산업 솔루션에 대해 도움 드립니다.
          </p>
        </div>

        <div class="faq-bottom-actions">
          <a href="/ko/contact" class="faq-primary-btn">문의하기</a>
          <a href="/ko/applications" class="faq-secondary-btn">응용 분야 보기</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .faq-hero {
      position: relative;
      min-height: 680px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 125px 0 60px;
      background:
        linear-gradient(rgba(15, 23, 42, 0.18), rgba(15, 23, 42, 0.10)),
        url('/assets/img/header-bg.jpg') center/cover no-repeat;
      overflow: hidden;
      text-align: center;
    }
    .faq-hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(rgba(255,255,255,0.06), rgba(255,255,255,0.03));
    }
    .faq-hero-content {
      position: relative;
      z-index: 2;
      max-width: 960px;
    }
    .faq-hero-kicker,
    .faq-section-label,
    .faq-side-label {
      display: inline-block;
      margin-bottom: 16px;
      padding: 6px 14px;
      border-radius: 999px;
      background: #fff4cc;
      color: #8a6a00;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .faq-section-label.dark {
      background: rgba(255,255,255,0.12);
      color: #fff4cc;
    }
    .faq-hero h1 {
      margin-bottom: 18px;
      font-size: clamp(2.4rem, 5vw, 4.6rem);
      line-height: 1.06;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #111;
    }
    .faq-hero p {
      max-width: 820px;
      margin: 0 auto;
      font-size: 1.04rem;
      line-height: 1.85;
      color: rgba(17,17,17,0.72);
    }
    .faq-intro-section { padding: 70px 0 32px; background: #fff; }
    .faq-intro-box, .faq-heading-block { max-width: 860px; margin: 0 auto; text-align: center; }
    .faq-intro-box h2, .faq-heading-block h2, .faq-bottom-copy h2 {
      margin-bottom: 16px;
      font-size: clamp(2rem, 3.4vw, 3rem);
      line-height: 1.1;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #111;
    }
    .faq-intro-box p, .faq-heading-block p, .faq-bottom-copy p, .faq-side-card p {
      margin: 0;
      font-size: 1rem;
      line-height: 1.85;
      color: #666;
    }
    .faq-main-section { padding: 40px 0 95px; background: #fff; }
    .faq-layout {
      display: grid;
      grid-template-columns: 300px minmax(0, 1fr);
      gap: 30px;
      align-items: start;
    }
    .faq-side-panel { position: sticky; top: 110px; margin-left: -16px; }
    .faq-side-card {
      padding: 28px;
      border-radius: 28px;
      background: linear-gradient(180deg, #ffffff 0%, #f8f9fb 100%);
      border: 1px solid #ececec;
      box-shadow: 0 18px 45px rgba(15,23,42,0.06);
    }
    .faq-side-card h3 { margin-bottom: 14px; font-size: 1.5rem; line-height: 1.25; font-weight: 800; color: #111; }
    .faq-side-actions { display: flex; flex-direction: column; gap: 12px; margin-top: 22px; }
    .faq-primary-btn, .faq-secondary-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 150px;
      padding: 14px 22px;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 700;
      transition: all 0.28s ease;
    }
    .faq-primary-btn { background: #ffcc00; color: #111; }
    .faq-primary-btn:hover { background: #ffd633; }
    .faq-secondary-btn { background: rgba(255,255,255,0.12); color: #fff; border: 1px solid rgba(255,255,255,0.18); }
    .faq-secondary-btn:hover { background: rgba(255,255,255,0.18); }
    .faq-text-link { display: inline-block; text-decoration: none; color: #0071e3; font-weight: 600; font-size: 0.96rem; }
    .faq-content { display: flex; flex-direction: column; gap: 26px; align-items: flex-start; width: 100%; max-width: 860px; }
    .faq-list { display: grid; gap: 18px; width: 100%; }
    .faq-item {
      background: #fff;
      border: 1px solid #ececec;
      border-radius: 26px;
      overflow: hidden;
      box-shadow: 0 16px 40px rgba(15,23,42,0.05);
      transition: box-shadow 0.28s ease, transform 0.28s ease;
    }
    .faq-item:hover { transform: translateY(-3px); box-shadow: 0 22px 50px rgba(15,23,42,0.10); }
    .faq-question {
      list-style: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 24px 26px;
      font-size: 1.14rem;
      line-height: 1.5;
      font-weight: 700;
      color: #111;
      user-select: none;
    }
    .faq-question::-webkit-details-marker { display: none; }
    .faq-icon { position: relative; width: 22px; height: 22px; flex-shrink: 0; }
    .faq-icon::before, .faq-icon::after {
      content: '';
      position: absolute;
      left: 50%;
      top: 50%;
      width: 16px;
      height: 2px;
      background: #111;
      border-radius: 999px;
      transform: translate(-50%, -50%);
      transition: transform 0.25s ease, opacity 0.25s ease;
    }
    .faq-icon::after { transform: translate(-50%, -50%) rotate(90deg); }
    .faq-item[open] .faq-icon::after { opacity: 0; transform: translate(-50%, -50%) rotate(90deg) scaleX(0.2); }
    .faq-answer { padding: 0 26px 24px; }
    .faq-answer p { margin: 0; font-size: 1rem; line-height: 1.85; color: #666; }
    .faq-bottom-section { padding: 0 0 95px; background: #fff; }
    .faq-bottom-panel {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 28px;
      padding: 40px 42px;
      border-radius: 32px;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      box-shadow: 0 28px 70px rgba(15,23,42,0.16);
    }
    .faq-bottom-copy { max-width: 720px; }
    .faq-bottom-copy h2 { color: #fff; }
    .faq-bottom-copy p { color: rgba(255,255,255,0.82); }
    .faq-bottom-actions { display: flex; gap: 14px; flex-wrap: wrap; }
    .faq-heading-block { width: 100%; max-width: 860px; margin: 0; text-align: left; }
    .faq-heading-block h2, .faq-heading-block p { width: 100%; max-width: 100%; margin-left: 0; margin-right: 0; }
    .faq-heading-block .faq-section-label { margin-left: 0; margin-right: auto; }
    @media (max-width: 991px) {
      .faq-layout { grid-template-columns: 1fr; }
      .faq-side-panel { position: sticky; top: 120px; margin-left: 0; }
      .faq-bottom-panel { flex-direction: column; align-items: flex-start; }
      .faq-heading-block { width: 100%; max-width: 860px; margin: 0 auto; text-align: center; }
      .faq-content { align-items: stretch; width: 100%; }
      .faq-heading-block .faq-section-label { margin-left: auto; margin-right: auto; }
    }
    @media (max-width: 768px) {
      .faq-hero { min-height: 260px; padding: 105px 0 45px; }
      .faq-hero h1 { font-size: clamp(2rem, 8vw, 2.9rem); }
      .faq-side-card, .faq-item, .faq-bottom-panel { border-radius: 24px; }
      .faq-question { padding: 20px; font-size: 1rem; }
      .faq-answer { padding: 0 20px 20px; }
      .faq-bottom-panel { padding: 28px 22px; }
    }
  </style>
</KoLayout>
