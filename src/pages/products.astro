---
import Layout from '../layouts/Layout.astro';
---

<Layout title="All Products | DGSDK">
  <section
    class="products-hero"
    style="background: linear-gradient(rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.18)), url('/assets/img/all-products/all-products.jpg') center/cover no-repeat;"
  >
    <div class="container products-hero-inner">
      <span class="products-hero-kicker">DGSDK Product Portfolio</span>
      <h1>Industrial products built for precision, stability, and performance.</h1>
      <p>
        Explore our full range of static elimination systems, cleaning machines,
        automation equipment, and precision machined parts for modern industrial production.
      </p>
    </div>
  </section>

  <section class="products-overview-section">
    <div class="container products-overview-layout">
      <aside class="products-sidebar">
        <div class="products-sidebar-box">
          <h3>Browse Categories</h3>
          <a href="/products" class="active-category">All Products</a>
          <a href="/products/static-eliminator">Static Elimination Systems</a>
          <a href="/products/cleaning-machine">Cleaning Machine</a>
          <a href="/products/precision-machined-parts">Precision Machined Parts</a>
          <a href="/products/automation">Automation Equipment</a>
        </div>
      </aside>

      <div class="products-main">
        <section class="apple-product-section">
          <div class="apple-product-showcase unified-panel">
            <div class="apple-product-copy">
              <span class="apple-product-label">Static Elimination Systems</span>
              <h2>Stable electrostatic control for high-precision production.</h2>
              <p>
                Designed for electronics, SMT, packaging, printing, textile, and automated
                manufacturing lines where static control directly affects product quality.
              </p>
              <div class="apple-product-actions">
                <a href="/products/static-eliminator" class="apple-link">Explore Category</a>
              </div>
            </div>

            <div class="apple-product-visual">
              <img src="/assets/img/static-white-bg.png" alt="Static Elimination Systems" />
            </div>
          </div>

          <div class="apple-card-grid">
            <a href="/products/static-eliminator/st-g-series" class="apple-product-card">
              <img src="/assets/img/static-eliminator/st-g.jpg" alt="ST-G Intelligent Static Elimination Bar" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST-G Intelligent Static Elimination Bar</h3>
              <p>High-performance ion bar for stable and efficient static removal.</p>
            </a>

            <a href="/products/static-eliminator/st-e-series" class="apple-product-card">
              <img src="/assets/img/static-eliminator/st-e.jpg" alt="ST-E Intelligent Ion Rod" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST-E Intelligent Ion Rod</h3>
              <p>Reliable electrostatic control for compact industrial integration.</p>
            </a>

            <a href="/products/static-eliminator/st-f-series" class="apple-product-card">
              <img src="/assets/img/static-eliminator/st-f.jpg" alt="ST-F Intelligent Ion Rod" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST-F Intelligent Ion Rod</h3>
              <p>Fast-response ionizing solution for continuous production lines.</p>
            </a>

            <a href="/products/static-eliminator/st-s200" class="apple-product-card">
              <img src="/assets/img/static-eliminator/st-s200.jpg" alt="ST-S200 Mini Ionizer Fan" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST-S200 Mini Ionizer Fan</h3>
              <p>Compact anti-static fan for workstations and sensitive applications.</p>
            </a>

            <a href="/products/static-eliminator/st-101a" class="apple-product-card">
              <img src="/assets/img/static-eliminator/st-101a.jpg" alt="ST101A Desktop Ion Fan" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST101A Desktop Ion Fan</h3>
              <p>Desktop anti-static fan solution for stable workstation performance.</p>
            </a>

            <a href="/products/static-eliminator/st-104a" class="apple-product-card">
              <img src="/assets/img/static-eliminator/st-104a.jpg" alt="ST104A Horizontal Ion Blower" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST104A Horizontal Ion Blower</h3>
              <p>Horizontal ion blowing support for larger anti-static coverage zones.</p>
            </a>

            <a href="/products/static-eliminator/st-1200" class="apple-product-card">
              <img src="/assets/img/static-eliminator/st-1200.jpg" alt="ST1200 Horizontal Ion Fan" />
              <span class="apple-card-tag">Static Elimination</span>
              <h3>ST1200 Horizontal Ion Fan</h3>
              <p>Wide-area electrostatic control for industrial workstations and lines.</p>
            </a>
          </div>
        </section>

        <section class="apple-product-section">
          <div class="apple-product-showcase unified-panel glow-panel">
            <div class="apple-product-copy">
              <span class="apple-product-label">Cleaning Machine</span>
              <h2>Precision cleaning for advanced manufacturing surfaces.</h2>
              <p>
                Professional cleaning equipment for PCB, FPC, SMT, polarizer,
                backlight, optical film, LCM, and other precision industrial applications.
              </p>
              <div class="apple-product-actions">
                <a href="/products/cleaning-machine" class="apple-link">Explore Category</a>
              </div>
            </div>

            <div class="apple-product-visual glow-visual">
              <img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="Cleaning Machine" />
            </div>
          </div>

          <div class="apple-card-grid">
            <a href="/products/cleaning-machine/polarizer-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="Polarizer Precision Cleaning Machine" />
              <span class="apple-card-tag">Cleaning Machine</span>
              <h3>Polarizer Precision Cleaning Machine</h3>
              <p>Designed for clean, stable handling of sensitive polarizer surfaces.</p>
            </a>

            <a href="/products/cleaning-machine/fpc-4-axis-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/fpc-4-axis-cleaner.jpg" alt="FPC 4-Axis High Precision Cleaning Machine" />
              <span class="apple-card-tag">Cleaning Machine</span>
              <h3>FPC 4-Axis High Precision Cleaning Machine</h3>
              <p>High-precision cleaning system for flexible printed circuit applications.</p>
            </a>

            <a href="/products/cleaning-machine/fpc-8-axis-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/fpc-8-axis-cleaner.jpg" alt="FPC 8-Axis Advanced Cleaning Machine" />
              <span class="apple-card-tag">Cleaning Machine</span>
              <h3>FPC 8-Axis Advanced Cleaning Machine</h3>
              <p>Advanced multi-axis cleaning platform for demanding production workflows.</p>
            </a>

            <a href="/products/cleaning-machine/optical-film-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/optical.jpg" alt="Large Size Optical Film Cleaning Machine" />
              <span class="apple-card-tag">Cleaning Machine</span>
              <h3>Large Size Optical Film Cleaning Machine</h3>
              <p>Industrial surface cleaning for large optical film applications.</p>
            </a>

            <a href="/products/cleaning-machine/lcm-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/lcm-cleaner.jpg" alt="LCM Module Industrial Cleaning Machine" />
              <span class="apple-card-tag">Cleaning Machine</span>
              <h3>LCM Module Industrial Cleaning Machine</h3>
              <p>Industrial cleaning system for module handling and display assembly lines.</p>
            </a>

            <a href="/products/cleaning-machine/pcb-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/pcb-cleaner.jpg" alt="PCB Surface Cleaning Machine" />
              <span class="apple-card-tag">Cleaning Machine</span>
              <h3>PCB Surface Cleaning Machine</h3>
              <p>Stable surface cleaning for PCB manufacturing and inspection stages.</p>
            </a>

            <a href="/products/cleaning-machine/pcb-vertical-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/stick-pcb-vertical-cleaning-machine.jpg" alt="PCB Vertical Cleaning System" />
              <span class="apple-card-tag">Cleaning Machine</span>
              <h3>PCB Vertical Cleaning System</h3>
              <p>Vertical cleaning design for efficient PCB process support.</p>
            </a>

            <a href="/products/cleaning-machine/roll-chip-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/roll-chip-cleaner.jpg" alt="Roll Chip Universal Cleaning Machine" />
              <span class="apple-card-tag">Cleaning Machine</span>
              <h3>Roll Chip Universal Cleaning Machine</h3>
              <p>Universal cleaning solution for roll chip and precision material handling.</p>
            </a>

            <a href="/products/cleaning-machine/smt-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/smt-cleaner.jpg" alt="SMT Inline Cleaning Machine" />
              <span class="apple-card-tag">Cleaning Machine</span>
              <h3>SMT Inline Cleaning Machine</h3>
              <p>Inline cleaning support for SMT processes and precision assembly lines.</p>
            </a>

            <a href="/products/cleaning-machine/backlight-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/backlight-cleaner.jpg" alt="Backlight Panel Cleaning Machine" />
              <span class="apple-card-tag">Cleaning Machine</span>
              <h3>Backlight Panel Cleaning Machine</h3>
              <p>Precision cleaning for backlight panel production environments.</p>
            </a>

            <a href="/products/cleaning-machine/ccl-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/ccl-cleaner.jpg" alt="Stick CCL Cleaning Machine ST DT1340" />
              <span class="apple-card-tag">Cleaning Machine</span>
              <h3>Stick CCL Cleaning Machine ST DT1340</h3>
              <p>Stable cleaning support for CCL-related industrial manufacturing lines.</p>
            </a>

            <a href="/products/cleaning-machine/inspection-cleaner" class="apple-product-card">
              <img src="/assets/img/cleaning-machine/inspection-cleaner.jpg" alt="Inspection Stage Cleaning Machine (STXT Series)" />
              <span class="apple-card-tag">Cleaning Machine</span>
              <h3>Inspection Stage Cleaning Machine (STXT Series)</h3>
              <p>Integrated inspection and cleaning support for precision production workflows.</p>
            </a>
          </div>
        </section>

        <section class="apple-product-section">
          <div class="apple-product-showcase unified-panel small-showcase">
            <div class="apple-product-copy">
              <span class="apple-product-label">Precision Machined Parts</span>
              <h2>Precision CNC components for reliable industrial performance.</h2>
              <p>
                High-precision machined parts with tight tolerances, strong consistency,
                and dependable manufacturing quality.
              </p>
              <div class="apple-product-actions">
                <a href="/products/precision-machined-parts" class="apple-link">Explore Category</a>
              </div>
            </div>

            <div class="apple-product-visual">
              <img src="/assets/img/precision-machined-parts/precision-machined-parts.jpg" alt="Precision CNC Parts" />
            </div>
          </div>

          <div class="apple-card-grid">
            <a href="/products/precision-machined-parts/lathe-machined-shaft-end-fixing-component" class="apple-product-card">
              <img src="/assets/img/precision-machined-parts/lathe-machined-shaft-end-fixing-component.jpg" alt="Lathe-Machined Shaft End Fixing Component" />
              <span class="apple-card-tag">Precision Machined Parts</span>
              <h3>Lathe-Machined Shaft End Fixing Component</h3>
              <p>Accurately machined shaft-end fixing part for stable industrial assembly performance.</p>
            </a>

            <a href="/products/precision-machined-parts/lathe-machined-bearing-outer-retainer-plate" class="apple-product-card">
              <img src="/assets/img/precision-machined-parts/lathe-machined-bearing-outer-retainer-plate.jpg" alt="Lathe-Machined Bearing Outer Retainer Plate" />
              <span class="apple-card-tag">Precision Machined Parts</span>
              <h3>Lathe-Machined Bearing Outer Retainer Plate</h3>
              <p>Precision retainer plate designed for secure bearing positioning and long-term reliability.</p>
            </a>

            <a href="/products/precision-machined-parts/cnc-milled-wing-connection-block" class="apple-product-card">
              <img src="/assets/img/precision-machined-parts/cnc-milled-wing-connection-block.jpg" alt="CNC-Milled Wing Connection Block" />
              <span class="apple-card-tag">Precision Machined Parts</span>
              <h3>CNC-Milled Wing Connection Block</h3>
              <p>High-accuracy CNC-milled block for structural connection and industrial equipment use.</p>
            </a>

            <a href="/products/precision-machined-parts/precision-bearing-bracket-cnc-milled" class="apple-product-card">
              <img src="/assets/img/precision-machined-parts/precision-bearing-bracket-cnc-milled.jpg" alt="Precision Bearing Bracket - CNC Milled" />
              <span class="apple-card-tag">Precision Machined Parts</span>
              <h3>Precision Bearing Bracket - CNC Milled</h3>
              <p>Robust bracket component manufactured for consistent alignment, support and precision.</p>
            </a>

            <a href="/products/precision-machined-parts/cnc-milled-front-panel-rubber-roller-assembly" class="apple-product-card">
              <img src="/assets/img/precision-machined-parts/cnc-milled-front-panel-rubber-roller-assembly.jpg" alt="CNC-Milled Front Panel for Rubber Roller Assembly" />
              <span class="apple-card-tag">Precision Machined Parts</span>
              <h3>CNC-Milled Front Panel for Rubber Roller Assembly</h3>
              <p>Machined front panel built for roller assembly systems and precision equipment integration.</p>
            </a>

            <a href="/products/precision-machined-parts/milled-front-inner-fixing-plate-paper-roll-guide-rail" class="apple-product-card">
              <img src="/assets/img/precision-machined-parts/milled-front-inner-fixing-plate-paper-roll-guide-rail.jpg" alt="Milled Front Inner Fixing Plate for Paper Roll Guide Rail" />
              <span class="apple-card-tag">Precision Machined Parts</span>
              <h3>Milled Front Inner Fixing Plate for Paper Roll Guide Rail</h3>
              <p>Inner fixing plate engineered for guide rail systems and smooth mechanical support.</p>
            </a>

            <a href="/products/precision-machined-parts/custom-precision-machined-parts" class="apple-product-card">
              <img src="/assets/img/precision-machined-parts/precision-machined-parts.jpg" alt="Custom Precision Machined Parts" />
              <span class="apple-card-tag">Precision Machined Parts</span>
              <h3>Custom Precision Machined Parts</h3>
              <p>Tailored CNC and lathe-machining solutions for custom drawings, prototypes and OEM projects.</p>
            </a>
          </div>
        </section>

        <section class="apple-product-section">
          <div class="apple-product-showcase unified-panel small-showcase">
            <div class="apple-product-copy">
              <span class="apple-product-label">Automation Equipment</span>
              <h2>Custom automation solutions that improve efficiency.</h2>
              <p>
                Industrial automation systems designed to optimize workflow,
                reduce manual intervention, and support scalable production.
              </p>
              <div class="apple-product-actions">
                <a href="/products/automation" class="apple-link">Explore Category</a>
              </div>
            </div>

            <div class="apple-product-visual">
              <img src="/assets/img/automation/product-a.jpg" alt="Automation Equipment" />
            </div>
          </div>

          <div class="apple-card-grid">
            <a href="/products/automation/product-a" class="apple-product-card">
              <img src="/assets/img/automation/product-a.jpg" alt="Diffusion Plate Cleaning and Inspection Production Line" />
              <span class="apple-card-tag">Automation Equipment</span>
              <h3>Diffusion Plate Cleaning and Inspection Production Line</h3>
              <p>Integrated production line for diffusion plate cleaning, inspection, and continuous conveying with stable industrial workflow.</p>
            </a>

            <a href="/products/automation/product-b" class="apple-product-card">
              <img src="/assets/img/automation/product-b.jpg" alt="Robotic Automatic Loading and Unloading Cleaning Machine" />
              <span class="apple-card-tag">Automation Equipment</span>
              <h3>Robotic Automatic Loading and Unloading Cleaning Machine</h3>
              <p>Automated cleaning equipment with mechanical loading and unloading support for improved efficiency and reduced manual handling.</p>
            </a>

            <a href="/products/automation/product-c" class="apple-product-card">
              <img src="/assets/img/automation/product-c.jpg" alt="Polarizer Absorption Axis Angle Measuring System" />
              <span class="apple-card-tag">Automation Equipment</span>
              <h3>Polarizer Absorption Axis Angle Measuring System</h3>
              <p>High-precision measuring system for polarizer absorption axis angle, retardation, chromaticity, and transmittance analysis.</p>
            </a>
          </div>
        </section>
      </div>
    </div>
  </section>
</Layout>