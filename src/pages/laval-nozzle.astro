---
// Laval Nozzle 3D Visualization with Accelerating Airflow
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>拉瓦尔喷口 3D 可视化 | DGSDK</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #060c18;
      color: #d0dff5;
      font-family: 'Segoe UI', system-ui, sans-serif;
      overflow: hidden;
      width: 100vw;
      height: 100vh;
    }
    canvas { display: block; }
    #canvas-container { width: 100vw; height: 100vh; position: relative; }

    .ui-overlay {
      position: absolute; inset: 0;
      pointer-events: none;
      z-index: 10;
    }

    .title-bar {
      position: absolute; top: 0; left: 0; right: 0;
      padding: 14px 24px;
      background: linear-gradient(to bottom, rgba(6,12,24,0.96), transparent);
      pointer-events: none;
    }
    .title-bar h1 { font-size: 1.05rem; font-weight: 600; color: #6aa8e8; letter-spacing: 0.04em; }
    .title-bar p  { font-size: 0.72rem; color: #3a5a88; margin-top: 2px; }

    .panel {
      position: absolute;
      background: rgba(8,16,32,0.88);
      border: 1px solid rgba(60,110,200,0.22);
      border-radius: 10px;
      padding: 12px 16px;
      backdrop-filter: blur(10px);
    }
    .panel h3 {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #3a6aaa;
      margin-bottom: 9px;
    }
    .row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 3.5px 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      font-size: 0.76rem;
    }
    .row:last-child { border: none; }
    .lbl { color: #6888a8; }
    .val { color: #90c4ff; font-weight: 600; font-variant-numeric: tabular-nums; }
    .val.hot { color: #ff7030; }
    .val.warn { color: #ffc040; }

    .dims { top: 62px; left: 18px; min-width: 195px; }
    .flow { top: 62px; right: 18px; min-width: 185px; }

    /* Velocity legend */
    .legend { bottom: 28px; left: 18px; }
    .grad-bar {
      width: 180px; height: 9px; border-radius: 5px; margin: 2px 0 5px;
      background: linear-gradient(to right,
        #0044ff 0%, #00aaff 20%, #00ffaa 40%,
        #aaff00 55%, #ffcc00 70%, #ff6600 85%, #ff0022 100%);
    }
    .grad-labels { display: flex; justify-content: space-between; font-size: 0.65rem; color: #3a5a88; }

    /* Mach indicator */
    .mach-bar { bottom: 28px; right: 18px; min-width: 160px; }
    .mach-track {
      width: 100%; height: 6px;
      background: rgba(255,255,255,0.07);
      border-radius: 3px; margin: 6px 0 3px;
      overflow: hidden;
    }
    .mach-fill {
      height: 100%; width: 0%;
      background: linear-gradient(to right, #0088ff, #ff4400);
      border-radius: 3px;
      transition: width 0.1s;
    }
    .mach-val { font-size: 1.3rem; font-weight: 700; color: #ff6622; text-align: center; margin: 4px 0 2px; }
    .mach-label { font-size: 0.65rem; color: #3a5a88; text-align: center; }

    .hint {
      position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%);
      font-size: 0.68rem; color: #2a4060;
      text-align: center;
      pointer-events: none;
    }
  </style>
</head>
<body>
<div id="canvas-container">
  <div class="ui-overlay">
    <div class="title-bar">
      <h1>拉瓦尔喷口（De Laval Nozzle）— 气流加速 3D 动画</h1>
      <p>收敛段加速 → 喉部 Ma=1 → 扩散段超音速膨胀　·　B-B 截面 · 按 CAD 样条曲线车削</p>
    </div>

    <div class="panel dims">
      <h3>零件尺寸</h3>
      <div class="row"><span class="lbl">总长</span><span class="val">72.5 mm</span></div>
      <div class="row"><span class="lbl">外径（主体）</span><span class="val">Φ 54 mm</span></div>
      <div class="row"><span class="lbl">入口内径</span><span class="val">Φ 40 mm</span></div>
      <div class="row"><span class="lbl">喉部直径</span><span class="val warn">Φ 9.1 mm</span></div>
      <div class="row"><span class="lbl">出口内径</span><span class="val">Φ 15 mm</span></div>
      <div class="row"><span class="lbl">出口外径</span><span class="val">Φ 19 mm</span></div>
      <div class="row"><span class="lbl">扩张比 ε</span><span class="val">2.72</span></div>
    </div>

    <div class="panel flow">
      <h3>流场参数（等熵估算）</h3>
      <div class="row"><span class="lbl">入口 Ma</span><span class="val">0.12</span></div>
      <div class="row"><span class="lbl">喉部 Ma</span><span class="val warn">1.00 ★</span></div>
      <div class="row"><span class="lbl">出口 Ma</span><span class="val hot">≈ 1.85</span></div>
      <div class="row"><span class="lbl">入口流速（估）</span><span class="val">~42 m/s</span></div>
      <div class="row"><span class="lbl">出口流速（估）</span><span class="val hot">~630 m/s</span></div>
      <div class="row"><span class="lbl">工况</span><span class="val hot">超音速</span></div>
    </div>

    <div class="panel legend">
      <h3>粒子颜色 = 流速</h3>
      <div class="grad-bar"></div>
      <div class="grad-labels"><span>低速（入口）</span><span>音速（喉）</span><span>超音速</span></div>
    </div>

    <div class="panel mach-bar">
      <h3>当前 Mach 数</h3>
      <div class="mach-val" id="machDisplay">0.12</div>
      <div class="mach-track"><div class="mach-fill" id="machFill"></div></div>
      <div class="mach-label">亚音速 ←　喉部(1.0)　→ 超音速</div>
    </div>

    <div class="hint">🖱 拖动旋转　· 右键平移　· 滚轮缩放</div>
  </div>
</div>

<script type="module">
import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js';
import { OrbitControls } from 'https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/controls/OrbitControls.js';

// ── Renderer ────────────────────────────────────────────────────
const container = document.getElementById('canvas-container');
const renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setSize(container.clientWidth, container.clientHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.toneMapping = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.15;
container.appendChild(renderer.domElement);

const scene = new THREE.Scene();
scene.background = new THREE.Color(0x040810);
scene.fog = new THREE.FogExp2(0x040810, 0.007);

const camera = new THREE.PerspectiveCamera(44, container.clientWidth / container.clientHeight, 0.1, 800);
camera.position.set(55, 30, 95);
camera.lookAt(0, 0, 0);

const controls = new OrbitControls(camera, renderer.domElement);
controls.enableDamping = true; controls.dampingFactor = 0.06;
controls.minDistance = 25; controls.maxDistance = 280;

// ── Lights ───────────────────────────────────────────────────────
scene.add(new THREE.AmbientLight(0x0d1a30, 1.0));
const key = new THREE.DirectionalLight(0x5080d0, 2.8);
key.position.set(70, 80, 60); scene.add(key);
const fill = new THREE.DirectionalLight(0x102040, 1.2);
fill.position.set(-60, -20, 40); scene.add(fill);
const rim = new THREE.PointLight(0x3080d0, 4, 220);
rim.position.set(-90, 40, -50); scene.add(rim);
// warm exit glow
const exitGlow = new THREE.PointLight(0xff5500, 0, 60);
exitGlow.position.set(42, 0, 0); scene.add(exitGlow);

// ── Nozzle profile data ─────────────────────────────────────────
// [z_mm, inner_radius_mm]  (z: 0=inlet, 72.5=exit)
const INNER = [
  [0,    20.0],
  [4,    19.5],
  [10,   17.8],
  [17,   14.2],
  [23,   10.5],
  [28,    6.8],
  [32,    4.55],  // ← throat Φ9.1
  [37,    5.1],
  [43,    5.9],
  [50,    6.6],
  [57.5,  7.5],
  [72.5,  7.5],
];
const OUTER = [
  [0,    27.0],
  [3,    27.0],
  [8,    26.6],
  [18,   24.5],
  [30,   19.0],
  [43,   13.8],
  [57.5,  9.5],
  [72.5,  9.5],
];

function lerp1D(table, z) {
  if (z <= table[0][0]) return table[0][1];
  if (z >= table[table.length-1][0]) return table[table.length-1][1];
  for (let i = 0; i < table.length - 1; i++) {
    if (z >= table[i][0] && z <= table[i+1][0]) {
      const t = (z - table[i][0]) / (table[i+1][0] - table[i][0]);
      return table[i][1] + t * (table[i+1][1] - table[i][1]);
    }
  }
}

// Normalized flow speed: continuity A·v = const → v ∝ 1/A ∝ 1/r²
const THROAT_R = 4.55;
const THROAT_A = Math.PI * THROAT_R * THROAT_R;
function flowSpeed(z) {   // returns [0,1], peaks at 1.0 at throat
  const r = lerp1D(INNER, z);
  return Math.min(1.0, THROAT_A / (Math.PI * r * r));
}
// Mach number approximation (isentropic, γ=1.4)
function approxMach(z) {
  const r = lerp1D(INNER, z);
  const eps = (r / THROAT_R) ** 2;
  if (z <= 32) return Math.min(1.0, 1.0 / eps);   // subsonic approx
  // supersonic: rough guess
  return 1.0 + (eps - 1.0) * 0.9;
}

// ── Build lathe geometry ─────────────────────────────────────────
function buildLathe(table, segments = 96) {
  const pts = [];
  for (let i = 0; i < table.length; i++) {
    const [z, r] = table[i];
    if (i > 0) {
      // Extra midpoint for smoother curve
      const [pz, pr] = table[i-1];
      pts.push(new THREE.Vector2(r*0.5 + pr*0.5, (z+pz)/2 - 36.25));
    }
    pts.push(new THREE.Vector2(r, z - 36.25));
  }
  return new THREE.LatheGeometry(pts, segments);
}

// Metallic nozzle body
const bodyGeom = buildLathe(OUTER);
const bodyMat = new THREE.MeshStandardMaterial({
  color: 0x7090b8, metalness: 0.88, roughness: 0.15,
});
const body = new THREE.Mesh(bodyGeom, bodyMat);
body.rotation.x = Math.PI / 2;
scene.add(body);

// Inner bore (backside, dark)
const boreGeom = buildLathe(INNER);
const boreMat = new THREE.MeshStandardMaterial({
  color: 0x0e1c2e, metalness: 0.5, roughness: 0.5, side: THREE.BackSide,
});
const bore = new THREE.Mesh(boreGeom, boreMat);
bore.rotation.x = Math.PI / 2;
scene.add(bore);

// End-caps (annular faces)
function ringCap(rIn, rOut, xPos) {
  const g = new THREE.RingGeometry(rIn, rOut, 64);
  const m = new THREE.MeshStandardMaterial({ color: 0x6080a0, metalness: 0.8, roughness: 0.2, side: THREE.DoubleSide });
  const mesh = new THREE.Mesh(g, m);
  mesh.rotation.y = Math.PI / 2; mesh.position.x = xPos;
  scene.add(mesh);
}
ringCap(20, 27, -36.25);   // inlet face
ringCap(7.5, 9.5, 36.25);  // exit face

// ── Throat glow ring ────────────────────────────────────────────
const throatRingG = new THREE.TorusGeometry(THROAT_R, 0.35, 16, 80);
const throatRingM = new THREE.MeshBasicMaterial({ color: 0xff8800, transparent: true, opacity: 0.6 });
const throatRing = new THREE.Mesh(throatRingG, throatRingM);
throatRing.rotation.y = Math.PI / 2;
throatRing.position.x = 32 - 36.25;
scene.add(throatRing);

// ── Grid ────────────────────────────────────────────────────────
const grid = new THREE.GridHelper(240, 48, 0x0a1824, 0x0a1824);
grid.position.y = -34;
scene.add(grid);

// ─────────────────────────────────────────────────────────────────
// PARTICLE SYSTEM — split into 3 zones for clear acceleration
// ─────────────────────────────────────────────────────────────────

// Color mapping: velocity 0→1 → blue → cyan → green → yellow → orange → red
function velColor(v) {
  // 5-stop gradient
  const stops = [
    [0.00, new THREE.Color(0.00, 0.18, 1.00)],  // blue
    [0.25, new THREE.Color(0.00, 0.80, 1.00)],  // cyan
    [0.50, new THREE.Color(0.00, 1.00, 0.35)],  // green
    [0.72, new THREE.Color(1.00, 0.85, 0.00)],  // yellow
    [0.88, new THREE.Color(1.00, 0.30, 0.00)],  // orange
    [1.00, new THREE.Color(1.00, 0.02, 0.10)],  // red
  ];
  for (let i = 0; i < stops.length - 1; i++) {
    if (v <= stops[i+1][0]) {
      const t = (v - stops[i][0]) / (stops[i+1][0] - stops[i][0]);
      return stops[i][1].clone().lerp(stops[i+1][1], t);
    }
  }
  return stops[stops.length-1][1].clone();
}

// Shared shader material for all particle sets
const ptShader = new THREE.ShaderMaterial({
  vertexColors: true, transparent: true,
  depthWrite: false, blending: THREE.AdditiveBlending,
  vertexShader: `
    attribute float size;
    varying vec3 vColor;
    varying float vAlpha;
    uniform float uTime;
    void main(){
      vColor = color;
      vec4 mv = modelViewMatrix * vec4(position,1.0);
      gl_PointSize = size * (280.0 / -mv.z);
      gl_Position = projectionMatrix * mv;
      vAlpha = 1.0;
    }`,
  fragmentShader: `
    varying vec3 vColor;
    uniform float uTime;
    void main(){
      float d = length(gl_PointCoord - vec2(0.5));
      if(d > 0.5) discard;
      float a = smoothstep(0.5, 0.08, d) * 0.9;
      // soft core glow
      float core = smoothstep(0.18, 0.0, d) * 0.6;
      gl_FragColor = vec4(vColor + vec3(core), a);
    }`,
  uniforms: { uTime: { value: 0 } },
});

// ── Zone 1: INNER FLOW PARTICLES ────────────────────────────────
const N = 5000;
const iPos = new Float32Array(N * 3);
const iCol = new Float32Array(N * 3);
const iSz  = new Float32Array(N);

const iData = new Array(N);
for (let i = 0; i < N; i++) {
  const z = Math.random() * 72.5;
  const r = lerp1D(INNER, z);
  const frac = Math.sqrt(Math.random()) * 0.90;
  const ang = Math.random() * Math.PI * 2;
  const v = flowSpeed(z);
  iData[i] = { z, frac, ang };

  iPos[i*3]   = z - 36.25;
  iPos[i*3+1] = r * frac * Math.cos(ang);
  iPos[i*3+2] = r * frac * Math.sin(ang);
  const c = velColor(v);
  iCol[i*3]=c.r; iCol[i*3+1]=c.g; iCol[i*3+2]=c.b;
  // Size: large/slow at inlet, tiny/fast at throat, medium at exit
  iSz[i] = 0.15 + (1.0 - v) * 0.55;
}

const iGeom = new THREE.BufferGeometry();
iGeom.setAttribute('position', new THREE.BufferAttribute(iPos, 3));
iGeom.setAttribute('color',    new THREE.BufferAttribute(iCol, 3));
iGeom.setAttribute('size',     new THREE.BufferAttribute(iSz,  1));
scene.add(new THREE.Points(iGeom, ptShader));

// ── Zone 2: EXIT PLUME (supersonic expansion) ───────────────────
const NP = 1200;
const pPos = new Float32Array(NP * 3);
const pCol = new Float32Array(NP * 3);
const pSz  = new Float32Array(NP);
const pData = new Array(NP);

for (let i = 0; i < NP; i++) {
  pData[i] = {
    x:   36.25 + Math.random() * 2,
    ang: Math.random() * Math.PI * 2,
    r:   Math.random() * 7.5,
    spd: 0.6 + Math.random() * 0.8,
    rSpd: 0.4 + Math.random() * 0.6,
  };
  pPos[i*3]=pData[i].x; pPos[i*3+1]=pData[i].r * Math.cos(pData[i].ang); pPos[i*3+2]=pData[i].r * Math.sin(pData[i].ang);
  // Plume: deep orange-red
  const t = Math.random();
  pCol[i*3]=1.0; pCol[i*3+1]=0.2+t*0.3; pCol[i*3+2]=t*0.05;
  pSz[i] = 0.25 + Math.random() * 0.4;
}

const pGeom = new THREE.BufferGeometry();
pGeom.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
pGeom.setAttribute('color',    new THREE.BufferAttribute(pCol, 3));
pGeom.setAttribute('size',     new THREE.BufferAttribute(pSz,  1));
scene.add(new THREE.Points(pGeom, ptShader.clone()));

// ── Zone 3: SHOCK DIAMONDS (Mach disks in supersonic plume) ─────
const ND = 300;
const dPos = new Float32Array(ND * 3);
const dCol = new Float32Array(ND * 3);
const dSz  = new Float32Array(ND);
const dData = new Array(ND);

// Shock diamond spacing ~1.2× nozzle exit diameter apart
const DIAMOND_SPACING = 9.5;
for (let i = 0; i < ND; i++) {
  const diskIdx = Math.floor(Math.random() * 4); // 4 shock diamonds
  const xBase = 36.25 + 5 + diskIdx * DIAMOND_SPACING;
  const maxR = 6 + diskIdx * 1.2;
  dData[i] = {
    x: xBase + (Math.random() - 0.5) * 1.5,
    ang: Math.random() * Math.PI * 2,
    r: Math.random() * maxR,
    phase: Math.random() * Math.PI * 2,
  };
  dPos[i*3]=dData[i].x; dPos[i*3+1]=dData[i].r * Math.cos(dData[i].ang); dPos[i*3+2]=dData[i].r * Math.sin(dData[i].ang);
  dCol[i*3]=0.9; dCol[i*3+1]=0.7; dCol[i*3+2]=1.0; // violet-white
  dSz[i] = 0.35;
}
const dGeom = new THREE.BufferGeometry();
dGeom.setAttribute('position', new THREE.BufferAttribute(dPos, 3));
dGeom.setAttribute('color',    new THREE.BufferAttribute(dCol, 3));
dGeom.setAttribute('size',     new THREE.BufferAttribute(dSz,  1));
scene.add(new THREE.Points(dGeom, ptShader.clone()));

// ── HUD Mach display ────────────────────────────────────────────
const machDisplay = document.getElementById('machDisplay');
const machFill    = document.getElementById('machFill');
let hudZ = 0;
let hudMach = 0;

// ── Animation ──────────────────────────────────────────────────
const clock = new THREE.Clock();
let T = 0;

function updateInnerFlow(dt) {
  const pos = iGeom.attributes.position.array;
  const col = iGeom.attributes.color.array;
  const sz  = iGeom.attributes.size.array;

  for (let i = 0; i < N; i++) {
    const d = iData[i];
    const v = flowSpeed(d.z);

    // Axial speed proportional to velocity (fast through throat)
    // At throat: max speed → fast dt advance
    // At inlet:  slow speed → slow dt advance
    // This makes particles visibly bunch up at slow zones and streak through throat
    const axialSpeed = 5.5 + v * 52.0;  // 5.5–57.5 units/s
    d.z += axialSpeed * dt;

    // Slight swirl angle offset
    d.ang += (0.2 + v * 0.6) * dt;

    // Radial: converge toward center before throat, expand after
    const converging = d.z < 32;
    if (converging) {
      d.frac = Math.max(0.05, d.frac - 0.015 * dt * 60 * (1.0 - d.z / 32));
    } else {
      d.frac = Math.min(0.95, d.frac + 0.005 * dt * 60 * ((d.z - 32) / 40.5));
    }

    if (d.z > 72.5) {
      // Respawn at inlet with slight stagger
      d.z = Math.random() * 8;
      d.frac = 0.3 + Math.random() * 0.65;
      d.ang = Math.random() * Math.PI * 2;
    }

    const r = lerp1D(INNER, d.z) * d.frac;
    pos[i*3]   = d.z - 36.25;
    pos[i*3+1] = r * Math.cos(d.ang);
    pos[i*3+2] = r * Math.sin(d.ang);

    const vv = flowSpeed(d.z);
    const c = velColor(vv);
    col[i*3]=c.r; col[i*3+1]=c.g; col[i*3+2]=c.b;
    sz[i] = Math.max(0.1, 0.15 + (1.0 - vv) * 0.55);
  }
  iGeom.attributes.position.needsUpdate = true;
  iGeom.attributes.color.needsUpdate = true;
  iGeom.attributes.size.needsUpdate = true;
}

function updatePlume(dt) {
  const pos = pGeom.attributes.position.array;
  for (let i = 0; i < NP; i++) {
    const d = pData[i];
    d.x   += d.spd  * dt * 18;
    d.r   += d.rSpd * dt * 8;
    d.ang += 0.4 * dt;
    if (d.x > 120 || d.r > 38) {
      d.x   = 36.25 + Math.random() * 3;
      d.r   = Math.random() * 7.5;
      d.ang = Math.random() * Math.PI * 2;
    }
    pos[i*3]   = d.x;
    pos[i*3+1] = d.r * Math.cos(d.ang);
    pos[i*3+2] = d.r * Math.sin(d.ang);
  }
  pGeom.attributes.position.needsUpdate = true;
}

function updateShockDiamonds(dt) {
  const pos = dGeom.attributes.position.array;
  const sz  = dGeom.attributes.size.array;
  for (let i = 0; i < ND; i++) {
    const d = dData[i];
    d.ang += 0.8 * dt;
    d.phase += dt * 2;
    // Pulsate
    const pulse = 0.9 + 0.1 * Math.sin(d.phase);
    pos[i*3]   = d.x;
    pos[i*3+1] = d.r * pulse * Math.cos(d.ang);
    pos[i*3+2] = d.r * pulse * Math.sin(d.ang);
    sz[i] = (0.3 + 0.15 * Math.sin(d.phase + i)) * pulse;
  }
  dGeom.attributes.position.needsUpdate = true;
  dGeom.attributes.size.needsUpdate = true;
}

function updateHUD() {
  // Animate HUD mach readout through the nozzle
  hudZ = (hudZ + 0.25) % 72.5;
  const mach = approxMach(hudZ);
  hudMach += (mach - hudMach) * 0.08;
  machDisplay.textContent = hudMach.toFixed(2);
  // Fill bar: 0→Ma1 = 0→50%, Ma1→Ma2 = 50→100%
  const pct = hudMach < 1.0
    ? hudMach * 50
    : 50 + (hudMach - 1.0) / 1.2 * 50;
  machFill.style.width = Math.min(100, pct) + '%';

  // Heat color: exit glow intensity
  const exitPhase = Math.sin(T * 1.5) * 0.5 + 0.5;
  exitGlow.intensity = 3 + exitPhase * 4;
}

function animate() {
  requestAnimationFrame(animate);
  const dt = Math.min(clock.getDelta(), 0.05);
  T += dt;

  updateInnerFlow(dt);
  updatePlume(dt);
  updateShockDiamonds(dt);
  updateHUD();

  // Throat glow pulse
  throatRing.material.opacity = 0.35 + 0.35 * Math.sin(T * 4);

  ptShader.uniforms.uTime.value = T;
  controls.update();
  renderer.render(scene, camera);
}
animate();

window.addEventListener('resize', () => {
  camera.aspect = container.clientWidth / container.clientHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(container.clientWidth, container.clientHeight);
});
</script>
</body>
</html>
