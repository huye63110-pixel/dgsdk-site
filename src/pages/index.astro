---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="DGSDK | Static Eliminators & Industrial Cleaning Machines"
  description="DGSDK (Dongguan Shidike) manufactures static eliminators, ionizing bars, industrial film cleaning machines, and precision CNC parts for global electronics, SMT, and automation industries."
  image="/assets/img/header-bg.webp"
>

  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["Organization", "LocalBusiness"],
    "name": "DGSDK",
    "alternateName": "Dongguan Shidike Automation Equipment Co., Ltd.",
    "url": "https://www.dg-sdk.com",
    "logo": { "@type": "ImageObject", "url": "https://www.dg-sdk.com/logo.png", "width": 600, "height": 168 },
    "image": "https://www.dg-sdk.com/assets/img/header-bg.webp",
    "description": "Professional manufacturer specializing in static elimination systems, industrial cleaning machines, automation equipment, and precision CNC parts.",
    "foundingDate": "2013",
    "address": { "@type": "PostalAddress", "streetAddress": "Binhai Road 33", "addressLocality": "Dongguan", "addressRegion": "Guangdong", "postalCode": "523000", "addressCountry": "CN" },
    "contactPoint": { "@type": "ContactPoint", "telephone": "+86-13602342003", "contactType": "sales", "availableLanguage": ["English", "Chinese"], "areaServed": "Worldwide" }
  }
  </script>

  <main id="main-content">

    <!-- HERO SECTION 1 — Main -->
    <section class="parallax-hero parallax-hero-1">
      <div class="parallax-overlay"></div>
      <div class="container parallax-content" data-aos="fade-up" data-aos-duration="900">
        <p class="parallax-sub">Dongguan Shidike Automation Equipment Co., Ltd.</p>
        <h1 class="parallax-heading">Static Eliminator · Cleaning Machine · CNC Manufacturing</h1>
        <p class="parallax-desc">Professional industrial solutions for electronics, SMT, optical film, automation equipment, and precision manufacturing.</p>
        <a class="parallax-btn" href="/contact">Request a Quote</a>
      </div>
    </section>

    <!-- Products -->
    <section class="page-section" id="services">
      <div class="container">
        <div class="text-center" data-aos="fade-up">
          <h2 class="section-heading text-uppercase">Our Core Products</h2>
          <h3 class="section-subheading text-muted">Advanced automation solutions designed to improve efficiency, reduce defects, and optimize your production process.</h3>
        </div>
        <div class="row text-center">
          <div class="col-lg-3 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="0">
            <a href="/products/static-eliminator" class="product-card">
              <span class="fa-stack fa-4x product-icon"><i class="fas fa-circle fa-stack-2x text-primary"></i><i class="fas fa-bolt fa-stack-1x fa-inverse"></i></span>
              <h4>Static Elimination</h4>
              <p>High-performance ionizing equipment for eliminating static electricity and improving production stability.</p>
            </a>
          </div>
          <div class="col-lg-3 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="100">
            <a href="/products/automation" class="product-card">
              <span class="fa-stack fa-4x product-icon"><i class="fas fa-circle fa-stack-2x text-primary"></i><i class="fas fa-gears fa-stack-1x fa-inverse"></i></span>
              <h4>Automation Systems</h4>
              <p>Custom automation solutions designed to streamline workflows and increase production efficiency.</p>
            </a>
          </div>
          <div class="col-lg-3 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="200">
            <a href="/products/precision-machined-parts" class="product-card">
              <span class="fa-stack fa-4x product-icon"><i class="fas fa-circle fa-stack-2x text-primary"></i><i class="fas fa-industry fa-stack-1x fa-inverse"></i></span>
              <h4>Precision CNC Parts</h4>
              <p>High-precision CNC machining with strict quality control and reliable performance.</p>
            </a>
          </div>
          <div class="col-lg-3 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="300">
            <a href="/products/cleaning-machine" class="product-card">
              <span class="fa-stack fa-4x product-icon"><i class="fas fa-circle fa-stack-2x text-primary"></i><i class="fas fa-soap fa-stack-1x fa-inverse"></i></span>
              <h4>Cleaning Machine</h4>
              <p>Precision cleaning equipment for PCB, FPC, SMT, polarizer, backlight, and optical film manufacturing.</p>
            </a>
          </div>
        </div>
        <div class="text-center mt-4" data-aos="fade-up">
          <a href="/products" class="btn btn-warning text-uppercase px-4 py-2">View All Products</a>
        </div>
      </div>
    </section>

    <!-- PARALLAX SECTION 2 — Products Banner -->
    <section class="parallax-hero parallax-hero-2">
      <div class="parallax-overlay"></div>
      <div class="container parallax-content" data-aos="zoom-in" data-aos-duration="800">
        <p class="parallax-label">What We Make</p>
        <h2 class="parallax-banner-text">PRECISION.<br/>RELIABILITY.<br/>INNOVATION.</h2>
      </div>
    </section>

    <!-- Applications -->
    <section class="page-section bg-light" id="portfolio">
      <div class="container">
        <div class="text-center" data-aos="fade-up">
          <h2 class="section-heading text-uppercase">Applications</h2>
          <h3 class="section-subheading text-muted">Discover how our solutions improve efficiency, reduce defects, and optimize your production line.</h3>
        </div>
        <div class="row">
          <div class="col-lg-4 col-sm-6 mb-4" data-aos="fade-up" data-aos-delay="0">
            <a href="/applications" class="portfolio-item app-card">
              <div class="portfolio-link">
                <picture>
                  <source srcset="/assets/img/portfolio/1-700.webp 700w, /assets/img/portfolio/1.webp 1180w" sizes="(max-width: 768px) 100vw, 679px" type="image/webp" />
                  <picture><source srcset="/assets/img/portfolio/1.webp" type="image/webp" /><img class="img-fluid" src="/assets/img/portfolio/1.jpg" alt="Electronics Manufacturing" loading="lazy" width="679" height="509" /></picture>
                </picture>
              </div>
              <div class="portfolio-caption">
                <div class="portfolio-caption-heading">Electronics Manufacturing</div>
                <div class="portfolio-caption-subheading text-muted">Static control & cleaning solutions</div>
              </div>
            </a>
          </div>
          <div class="col-lg-4 col-sm-6 mb-4" data-aos="fade-up" data-aos-delay="100">
            <a href="/applications" class="portfolio-item app-card">
              <div class="portfolio-link">
                <picture>
                  <source srcset="/assets/img/portfolio/2-700.webp 700w, /assets/img/portfolio/2-900.webp 900w, /assets/img/portfolio/2.webp 1180w" sizes="(max-width: 768px) 100vw, 679px" type="image/webp" />
                  <picture><source srcset="/assets/img/portfolio/2.webp" type="image/webp" /><img class="img-fluid" src="/assets/img/portfolio/2.jpg" alt="SMT Production" loading="lazy" width="679" height="509" /></picture>
                </picture>
              </div>
              <div class="portfolio-caption">
                <div class="portfolio-caption-heading">SMT Production</div>
                <div class="portfolio-caption-subheading text-muted">Industrial automation & equipment support</div>
              </div>
            </a>
          </div>
          <div class="col-lg-4 col-sm-6 mb-4" data-aos="fade-up" data-aos-delay="200">
            <a href="/applications" class="portfolio-item app-card">
              <div class="portfolio-link">
                <picture>
                  <source srcset="/assets/img/portfolio/3-700.webp 700w, /assets/img/portfolio/3.webp 1180w" sizes="(max-width: 768px) 100vw, 679px" type="image/webp" />
                  <picture><source srcset="/assets/img/portfolio/3.webp" type="image/webp" /><img class="img-fluid" src="/assets/img/portfolio/3.jpg" alt="Precision Machining" loading="lazy" width="679" height="509" /></picture>
                </picture>
              </div>
              <div class="portfolio-caption">
                <div class="portfolio-caption-heading">Precision Machining</div>
                <div class="portfolio-caption-subheading text-muted">High-precision CNC component solutions</div>
              </div>
            </a>
          </div>
        </div>
        <div class="text-center mt-4" data-aos="fade-up">
          <a href="/contact" class="btn btn-warning text-uppercase px-4 py-2">Discuss Your Application</a>
        </div>
      </div>
    </section>

    <!-- PARALLAX SECTION 3 — Manufacturing Banner -->
    <section class="parallax-hero parallax-hero-3">
      <div class="parallax-overlay"></div>
      <div class="container parallax-content" data-aos="fade-up" data-aos-duration="800">
        <p class="parallax-label">Since 2013</p>
        <h2 class="parallax-banner-text">BUILT IN<br/>DONGGUAN.</h2>
        <p class="parallax-desc" style="max-width:560px;margin:0 auto 28px;">Over a decade of manufacturing expertise in static control, precision machining, and industrial automation.</p>
        <a class="parallax-btn" href="/about">Learn About Us</a>
      </div>
    </section>

    <!-- About -->
    <section class="page-section" id="about">
      <div class="container">
        <div class="text-center" data-aos="fade-up">
          <h2 class="section-heading text-uppercase">About DGSDK</h2>
          <h3 class="section-subheading text-muted">Dongguan Shidike Automation Equipment Co., Ltd.</h3>
        </div>
        <ul class="timeline">
          <li data-aos="fade-right">
            <div class="timeline-image"><picture><source srcset="/assets/img/about/1.webp" type="image/webp" /><img class="rounded-circle img-fluid" src="/assets/img/about/1.jpg" alt="Company Foundation" loading="lazy" /></picture></div>
            <div class="timeline-panel">
              <div class="timeline-heading"><h4>Founded in 2013</h4><h4 class="subheading">Professional Industrial Manufacturer</h4></div>
              <div class="timeline-body"><p class="text-muted">DGSDK was established in Dongguan, focusing on industrial automation, static elimination systems, and precision manufacturing solutions.</p></div>
            </div>
          </li>
          <li class="timeline-inverted" data-aos="fade-left">
            <div class="timeline-image"><picture><source srcset="/assets/img/about/2.webp" type="image/webp" /><img class="rounded-circle img-fluid" src="/assets/img/about/2.jpg" alt="Technology Development" loading="lazy" /></picture></div>
            <div class="timeline-panel">
              <div class="timeline-heading"><h4>Technology Expansion</h4><h4 class="subheading">Static Control & Cleaning Solutions</h4></div>
              <div class="timeline-body"><p class="text-muted">We expanded our product range to include static eliminators and industrial cleaning machines for electronics, SMT, and optical film industries.</p></div>
            </div>
          </li>
          <li data-aos="fade-right">
            <div class="timeline-image"><picture><source srcset="/assets/img/about/3.webp" type="image/webp" /><img class="rounded-circle img-fluid" src="/assets/img/about/3.jpg" alt="Precision Manufacturing" loading="lazy" /></picture></div>
            <div class="timeline-panel">
              <div class="timeline-heading"><h4>Advanced Manufacturing</h4><h4 class="subheading">Automation, Static Control, CNC</h4></div>
              <div class="timeline-body"><p class="text-muted">Our core business now covers automation systems, static control equipment, cleaning machines, precision CNC parts, and OEM manufacturing services.</p></div>
            </div>
          </li>
          <li class="timeline-inverted" data-aos="fade-left">
            <div class="timeline-image"><picture><source srcset="/assets/img/about/4.webp" type="image/webp" /><img class="rounded-circle img-fluid" src="/assets/img/about/4.jpg" alt="Global Cooperation" loading="lazy" /></picture></div>
            <div class="timeline-panel">
              <div class="timeline-heading"><h4>Global Service</h4><h4 class="subheading">Long-Term Industrial Cooperation</h4></div>
              <div class="timeline-body"><p class="text-muted">DGSDK serves global customers with stable quality, engineering support, and practical industrial solutions for long-term cooperation.</p></div>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <!-- Certifications -->
    <section id="certifications" class="page-section bg-light">
      <div class="container">
        <div class="text-center" data-aos="fade-up">
          <h2 class="section-heading text-uppercase">Certifications</h2>
          <h3 class="section-subheading text-muted">Certified quality and international compliance</h3>
        </div>
        <div class="cert-grid">
          <div class="cert-card" data-aos="zoom-in" data-aos-delay="0"><picture><source srcset="/assets/img/cert/cert1.webp" type="image/webp" /><img src="/assets/img/cert/cert1.png" alt="Certificate 1" loading="lazy" width="300" height="212" /></picture></div>
          <div class="cert-card" data-aos="zoom-in" data-aos-delay="60"><picture><source srcset="/assets/img/cert/cert2.webp" type="image/webp" /><img src="/assets/img/cert/cert2.png" alt="Certificate 2" loading="lazy" width="300" height="212" /></picture></div>
          <div class="cert-card" data-aos="zoom-in" data-aos-delay="120"><picture><source srcset="/assets/img/cert/cert3.webp" type="image/webp" /><img src="/assets/img/cert/cert3.png" alt="Certificate 3" loading="lazy" width="300" height="212" /></picture></div>
          <div class="cert-card" data-aos="zoom-in" data-aos-delay="180"><picture><source srcset="/assets/img/cert/cert4.webp" type="image/webp" /><img src="/assets/img/cert/cert4.png" alt="Certificate 4" loading="lazy" width="300" height="212" /></picture></div>
          <div class="cert-card" data-aos="zoom-in" data-aos-delay="240"><picture><source srcset="/assets/img/cert/cert5.webp" type="image/webp" /><img src="/assets/img/cert/cert5.png" alt="Certificate 5" loading="lazy" width="300" height="212" /></picture></div>
          <div class="cert-card" data-aos="zoom-in" data-aos-delay="300"><picture><source srcset="/assets/img/cert/cert6.webp" type="image/webp" /><img src="/assets/img/cert/cert6.png" alt="Certificate 6" loading="lazy" width="300" height="212" /></picture></div>
          <div class="cert-card" data-aos="zoom-in" data-aos-delay="360"><picture><source srcset="/assets/img/cert/cert7.webp" type="image/webp" /><img src="/assets/img/cert/cert7.png" alt="Certificate 7" loading="lazy" width="300" height="212" /></picture></div>
          <div class="cert-card" data-aos="zoom-in" data-aos-delay="420"><picture><source srcset="/assets/img/cert/cert8.webp" type="image/webp" /><img src="/assets/img/cert/cert8.png" alt="Certificate 8" loading="lazy" width="300" height="212" /></picture></div>
        </div>
      </div>
    </section>

    <!-- Blog Preview -->
    <section class="page-section" style="background:#f5f6f7;padding:70px 20px;">
      <div class="container">
        <div class="text-center" style="margin-bottom:40px;" data-aos="fade-up">
          <h2 class="section-heading text-uppercase">Technical Blog</h2>
          <h3 class="section-subheading text-muted">Operation guides and industry insights for industrial cleaning and automation equipment.</h3>
        </div>

        <style>
          .blog-carousel-outer{position:relative;max-width:960px;margin:0 auto;}
          .blog-carousel-track{display:flex;gap:24px;overflow-x:auto;scroll-snap-type:x mandatory;scroll-behavior:smooth;padding-bottom:4px;scrollbar-width:none;-ms-overflow-style:none;}
          .blog-carousel-track::-webkit-scrollbar{display:none;}
          .blog-carousel-track .blog-index-card{flex:0 0 calc(50% - 12px);scroll-snap-align:start;min-width:280px;grid-template-columns:1fr!important;align-content:start;}
          .blog-carousel-track .blog-index-img{height:200px;}
          .blog-carousel-btn{position:absolute;top:50%;transform:translateY(-50%);width:40px;height:40px;border-radius:50%;border:none;background:#111827;color:#fff;font-size:20px;line-height:1;cursor:pointer;z-index:3;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(0,0,0,.18);transition:background .2s;}
          .blog-carousel-btn:hover{background:#f5c400;color:#111;}
          .blog-carousel-btn.prev{left:-20px;}
          .blog-carousel-btn.next{right:-20px;}
          .blog-carousel-dots{display:flex;justify-content:center;gap:8px;margin-top:18px;}
          .blog-carousel-dots span{width:8px;height:8px;border-radius:50%;background:#ccc;cursor:pointer;transition:background .2s;}
          .blog-carousel-dots span.active{background:#111827;}
          @media(max-width:640px){
            .blog-carousel-track .blog-index-card{flex:0 0 88%;}
            .blog-carousel-btn.prev{left:-10px;}
            .blog-carousel-btn.next{right:-10px;}
          }
        </style>

        <div class="blog-carousel-outer" data-aos="fade-up" data-aos-delay="100">
          <button class="blog-carousel-btn prev" id="blogPrevEN" aria-label="Previous article">&#8249;</button>
          <div class="blog-carousel-track" id="blogTrackEN">
            <a href="/blog/polarizer-cleaner-selection-guide" class="blog-index-card">
              <div class="blog-index-img"><picture><source srcset="/assets/img/cleaning-machine/polarizer-cleaner.webp" type="image/webp" /><img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="Polarizer cleaning machine selection guide" loading="lazy" /></picture></div>
              <div class="blog-index-content">
                <div class="blog-index-tags"><span class="blog-tag">Cleaning Machine</span><span class="blog-tag">Selection Guide</span></div>
                <h2>Polarizer Cleaning Machine Buyer's Guide: Technical Selection Criteria and Production Line Fit</h2>
                <p>Not all polarizer cleaners are equal. Learn which parameters matter for OLED, high-warp, and AOI inline applications — and how to match equipment to your actual line pain points.</p>
                <div class="blog-index-meta">
                  <span><i class="fas fa-calendar-alt"></i> May 15, 2026</span>
                  <span><i class="fas fa-clock"></i> 12 min read</span>
                </div>
                <span class="blog-read-more">Read Article <i class="fas fa-arrow-right"></i></span>
              </div>
            </a>
            <a href="/blog/optical-film-cleaner-tutorial" class="blog-index-card">
              <div class="blog-index-img"><picture><source srcset="/assets/img/cleaning-machine/optical.webp" type="image/webp" /><img src="/assets/img/cleaning-machine/optical.jpg" alt="Optical film cleaning machine tutorial" loading="lazy" /></picture></div>
              <div class="blog-index-content">
                <div class="blog-index-tags"><span class="blog-tag">Cleaning Machine</span><span class="blog-tag">Tutorial</span></div>
                <h2>Optical Film Cleaning Machine: 9-Step Operating Guide for Zero-Defect Results</h2>
                <p>Learn how to operate an optical film cleaning machine step by step — roller pressure, speed settings, static elimination, troubleshooting, and how to achieve defect-free lamination.</p>
                <div class="blog-index-meta">
                  <span><i class="fas fa-calendar-alt"></i> May 14, 2026</span>
                  <span><i class="fas fa-clock"></i> 12 min read</span>
                </div>
                <span class="blog-read-more">Read Article <i class="fas fa-arrow-right"></i></span>
              </div>
            </a>
            <a href="/blog/polarizer-cleaner-tutorial" class="blog-index-card">
              <div class="blog-index-img"><picture><source srcset="/assets/img/cleaning-machine/polarizer-cleaner.webp" type="image/webp" /><img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="Polarizer cleaning machine tutorial" loading="lazy" /></picture></div>
              <div class="blog-index-content">
                <div class="blog-index-tags"><span class="blog-tag">Cleaning Machine</span><span class="blog-tag">Tutorial</span></div>
                <h2>Polarizer Cleaning Machine: 8-Step Operating Guide for Zero-Defect Results</h2>
                <p>Learn how to operate a polarizer cleaning machine step by step — parameter setup, consumable installation, troubleshooting, and how to achieve 99%+ cleaning yield.</p>
                <div class="blog-index-meta">
                  <span><i class="fas fa-calendar-alt"></i> May 13, 2026</span>
                  <span><i class="fas fa-clock"></i> 10 min read</span>
                </div>
                <span class="blog-read-more">Read Article <i class="fas fa-arrow-right"></i></span>
              </div>
            </a>
          </div>
          <button class="blog-carousel-btn next" id="blogNextEN" aria-label="Next article">&#8250;</button>
          <div class="blog-carousel-dots" id="blogDotsEN">
            <span class="active"></span><span></span><span></span>
          </div>
        </div>

        <script>
          (function(){
            const track = document.getElementById('blogTrackEN');
            const dots = document.querySelectorAll('#blogDotsEN span');
            function getCardWidth(){
              const card = track.querySelector('.blog-index-card');
              return card ? card.offsetWidth + 24 : 340;
            }
            document.getElementById('blogPrevEN').addEventListener('click',()=>track.scrollBy({left:-getCardWidth(),behavior:'smooth'}));
            document.getElementById('blogNextEN').addEventListener('click',()=>track.scrollBy({left:getCardWidth(),behavior:'smooth'}));
            track.addEventListener('scroll',()=>{
              const idx = Math.round(track.scrollLeft / getCardWidth());
              dots.forEach((d,i)=>d.classList.toggle('active',i===idx));
            },{passive:true});
            dots.forEach((d,i)=>d.addEventListener('click',()=>track.scrollTo({left:i*getCardWidth(),behavior:'smooth'})));
          })();
        </script>

        <div style="text-align:center;margin-top:32px;" data-aos="fade-up" data-aos-delay="150">
          <a href="/blog" style="display:inline-block;padding:12px 28px;border-radius:10px;background:#111827;color:#fff;font-weight:700;text-decoration:none;font-size:15px;">View All Articles</a>
        </div>
      </div>
    </section>

    <!-- Get a Free Quote -->
    <section class="quote-section" id="contact">
      <div class="quote-overlay"></div>
      <div class="container quote-content">
        <div class="text-center" data-aos="fade-up">
          <h2 class="quote-title">GET A FREE QUOTE</h2>
          <p class="quote-desc">If you are searching for information about our products, please submit your inquiry by filling out the form below.</p>
        </div>
        <form action="https://formspree.io/f/mvzlpdwy" method="POST" class="quote-form" data-aos="fade-up" data-aos-delay="100">
          <input type="text" name="name" placeholder="Your name (Required)" required />
          <input type="email" name="email" placeholder="Your email address (Required)" required />
          <input type="text" name="phone" placeholder="Your phone number" />
          <textarea name="message" rows="5" placeholder="Please enter your message information" required></textarea>
          <button type="submit">Send message</button>
        </form>
      </div>
    </section>

  </main>

  <!-- Footer CTA -->
  <section class="home-bottom-cta">
    <div class="container" data-aos="fade-up">
      <h2>Ready to Start Your Project?</h2>
      <p>Contact DGSDK for industrial automation solutions, static eliminators, cleaning machines, and precision CNC parts.</p>
      <a href="/contact" class="home-bottom-btn">Get a Free Quote</a>
    </div>
  </section>

</Layout>
