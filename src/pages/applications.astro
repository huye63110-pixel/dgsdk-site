---
import Layout from '../layouts/Layout.astro';

const applicationItems = [
  {
    title: 'Electronics Manufacturing',
    image: '/assets/img/static-white-bg.png',
    desc: 'Static control and precision cleaning solutions for PCB, FPC, SMT, and electronics production lines.',
    href: '/products/static-eliminator'
  },
  {
    title: 'SMT Production',
    image: '/assets/img/cleaning-machine/Stick SMT cleaning machine-SMT600.jpg',
    desc: 'Reliable cleaning and process support for SMT assembly, inspection, and stable inline production.',
    href: '/products/cleaning-machine'
  },
  {
    title: 'Display & Optical Film',
    image: '/assets/img/cleaning-machine/optical.jpg',
    desc: 'Industrial cleaning equipment for optical film, polarizer, backlight, and LCM manufacturing environments.',
    href: '/products/cleaning-machine'
  },
  {
    title: 'Precision Machining',
    image: '/assets/img/about/about-cnc-process.jpg',
    desc: 'Precision CNC machined parts and industrial components built for stable tolerance and long-term reliability.',
    href: '/products/precision-machined-parts'
  },
  {
    title: 'Automation Integration',
    image: '/assets/img/about/about-machining-center.jpg',
    desc: 'Custom automation systems designed to improve workflow, reduce manual handling, and increase efficiency.',
    href: '/products/automation'
  },
  {
    title: 'Industrial Packaging & Handling',
    image: '/assets/img/cleaning-machine/Stick Roll Chip Universal Cleaning Machine .jpg',
    desc: 'Production support equipment for material handling, surface cleaning, and practical industrial process improvement.',
    href: '/products/cleaning-machine'
  }
];

const supportBlocks = [
  {
    label: 'Static Control',
    title: 'Reduce electrostatic risk in sensitive production areas.',
    desc: 'Ion bars, ion fans, and anti-static systems help improve quality stability in electronics, packaging, textile, and automated production lines.',
    href: '/products/static-eliminator'
  },
  {
    label: 'Cleaning Solutions',
    title: 'Keep surfaces clean for precision manufacturing.',
    desc: 'Cleaning machines support PCB, FPC, polarizer, optical film, SMT, and backlight workflows where contamination directly affects product quality.',
    href: '/products/cleaning-machine'
  },
  {
    label: 'Custom Manufacturing',
    title: 'Match equipment and parts to real production needs.',
    desc: 'From CNC components to automation equipment, DGSDK provides practical industrial solutions for customized manufacturing projects.',
    href: '/products'
  }
];
---

<Layout title="Applications | DGSDK">
  <section class="applications-hero">
    <div class="applications-hero-overlay"></div>
    <div class="container applications-hero-content">
      <span class="applications-hero-kicker">Application Solutions</span>
      <h1>Industrial applications built around efficiency, cleanliness, and production reliability.</h1>
      <p>
        DGSDK solutions are used across electronics manufacturing, SMT production,
        display processing, optical film applications, automation integration, and
        precision machining environments.
      </p>
    </div>
  </section>

  <section class="applications-intro-section">
    <div class="container">
      <div class="applications-intro-box">
        <span class="applications-section-label">Where We Create Value</span>
        <h2>Built for real industrial workflows, not just product display.</h2>
        <p>
          Our solutions are designed for manufacturing environments where static,
          contamination, manual handling, and unstable component quality directly affect
          efficiency, yield, and long-term production reliability.
        </p>
      </div>
    </div>
  </section>

  <section class="applications-grid-section">
    <div class="container">
      <div class="applications-section-heading text-center">
        <span class="applications-section-label">Application Areas</span>
        <h2>Where our solutions are used.</h2>
        <p>
          Practical industrial support for production lines that need stable performance,
          cleaner surfaces, lower static risk, and reliable process integration.
        </p>
      </div>

      <div class="applications-grid">
        {applicationItems.map((item) => (
          <a href={item.href} class="application-card">
            <div class="application-card-image-wrap">
              <img src={item.image} alt={item.title} class="application-card-image" />
            </div>

            <div class="application-card-body">
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
              <span class="application-card-link">View related products</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="applications-support-section">
    <div class="container">
      <div class="applications-section-heading text-center">
        <span class="applications-section-label">Core Solution Support</span>
        <h2>Three practical directions that support production quality.</h2>
        <p>
          Our application capability is built around electrostatic control, precision cleaning,
          and customized manufacturing support for industrial customers.
        </p>
      </div>

      <div class="applications-support-grid">
        {supportBlocks.map((item) => (
          <a href={item.href} class="applications-support-card">
            <span class="applications-support-label">{item.label}</span>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
            <span class="applications-support-link">Learn more</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="applications-highlight-section">
    <div class="container">
      <div class="applications-highlight-panel">
        <div class="applications-highlight-copy">
          <span class="applications-section-label dark">Integrated Manufacturing Value</span>
          <h2>From process problems to practical industrial solutions.</h2>
          <p>
            Whether your production line needs static elimination, precision cleaning,
            automation assistance, or custom machined components, DGSDK helps connect
            products with real manufacturing needs.
          </p>
          <div class="applications-highlight-actions">
            <a href="/products" class="applications-primary-btn">Explore Products</a>
            <a href="/contact" class="applications-secondary-btn">Contact Us</a>
          </div>
        </div>

        <div class="applications-highlight-visual">
          <div class="applications-highlight-card">
            <strong>Applications</strong>
            <span>Electronics, SMT, optical film, automation, CNC manufacturing</span>
          </div>
          <div class="applications-highlight-card">
            <strong>Focus</strong>
            <span>Cleaner surfaces, less static risk, stable workflow, efficient production</span>
          </div>
          <div class="applications-highlight-card">
            <strong>Support</strong>
            <span>Product matching, practical communication, long-term industrial cooperation</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="applications-cta-section">
    <div class="container">
      <div class="applications-cta-box">
        <div class="applications-cta-copy">
          <span class="applications-section-label">Discuss Your Project</span>
          <h2>Need a solution for your production line?</h2>
          <p>
            Talk with DGSDK about your application scenario, production process,
            or customized industrial equipment requirements.
          </p>
        </div>

        <div class="applications-cta-actions">
          <a href="/contact" class="applications-primary-btn">Contact Us</a>
          <a href="/about" class="applications-secondary-btn dark-outline">About DGSDK</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .applications-hero {
      position: relative;
      min-height: 380px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 150px 0 95px;
      background:
        linear-gradient(rgba(15, 23, 42, 0.18), rgba(15, 23, 42, 0.10)),
        url('/assets/img/header-bg.jpg') center/cover no-repeat;
      overflow: hidden;
      text-align: center;
    }

    .applications-hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        rgba(255, 255, 255, 0.06),
        rgba(255, 255, 255, 0.03)
      );
    }

    .applications-hero-content {
      position: relative;
      z-index: 2;
      max-width: 980px;
    }

    .applications-hero-kicker,
    .applications-section-label {
      display: inline-block;
      margin-bottom: 16px;
      padding: 6px 14px;
      border-radius: 999px;
      background: #fff4cc;
      color: #8a6a00;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .applications-section-label.dark {
      background: rgba(255,255,255,0.12);
      color: #fff4cc;
    }

    .applications-hero h1 {
      margin-bottom: 18px;
      font-size: clamp(2.5rem, 5vw, 4.8rem);
      line-height: 1.05;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #111;
    }

    .applications-hero p {
      max-width: 820px;
      margin: 0 auto;
      font-size: 1.06rem;
      line-height: 1.85;
      color: rgba(17, 17, 17, 0.72);
    }

    .applications-intro-section {
      padding: 70px 0 30px;
      background: #fff;
    }

    .applications-intro-box {
      max-width: 880px;
      margin: 0 auto;
      text-align: center;
    }

    .applications-intro-box h2,
    .applications-section-heading h2,
    .applications-highlight-copy h2,
    .applications-cta-copy h2 {
      margin-bottom: 16px;
      font-size: clamp(2rem, 3.6vw, 3.2rem);
      line-height: 1.1;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #111;
    }

    .applications-intro-box p,
    .applications-section-heading p,
    .applications-highlight-copy p,
    .applications-cta-copy p {
      margin: 0 auto;
      max-width: 820px;
      font-size: 1rem;
      line-height: 1.85;
      color: #666;
    }

    .applications-grid-section {
      padding: 45px 0 90px;
      background: #fff;
    }

    .applications-section-heading {
      max-width: 820px;
      margin: 0 auto 40px;
    }

    .applications-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 24px;
    }

    .application-card {
      display: block;
      text-decoration: none;
      color: inherit;
      background: #fff;
      border-radius: 28px;
      overflow: hidden;
      border: 1px solid #ececec;
      box-shadow: 0 18px 45px rgba(15, 23, 42, 0.06);
      transition: transform 0.35s ease, box-shadow 0.35s ease;
    }

    .application-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 28px 60px rgba(15, 23, 42, 0.12);
    }

    .application-card-image-wrap {
      position: relative;
      background: linear-gradient(180deg, #f7f8fa 0%, #ffffff 100%);
      padding: 24px;
      min-height: 250px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .application-card-image {
      width: 100%;
      max-width: 280px;
      max-height: 200px;
      object-fit: contain;
      display: block;
      filter: drop-shadow(0 18px 28px rgba(15, 23, 42, 0.10));
    }

    .application-card-body {
      padding: 24px 24px 26px;
    }

    .application-card-body h3 {
      margin-bottom: 12px;
      font-size: 1.35rem;
      line-height: 1.35;
      font-weight: 700;
      color: #111;
    }

    .application-card-body p {
      margin-bottom: 18px;
      font-size: 0.95rem;
      line-height: 1.8;
      color: #666;
    }

    .application-card-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: #0071e3;
      font-weight: 600;
      font-size: 0.95rem;
    }

    .applications-support-section {
      padding: 95px 0;
      background: #f7f8fa;
    }

    .applications-support-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 24px;
    }

    .applications-support-card {
      display: block;
      text-decoration: none;
      color: inherit;
      background: linear-gradient(180deg, #ffffff 0%, #fafafa 100%);
      border-radius: 30px;
      padding: 30px;
      box-shadow: 0 20px 46px rgba(15, 23, 42, 0.06);
      border: 1px solid #ececec;
      transition: transform 0.35s ease, box-shadow 0.35s ease;
    }

    .applications-support-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 28px 60px rgba(15, 23, 42, 0.12);
    }

    .applications-support-label {
      display: inline-block;
      margin-bottom: 14px;
      padding: 4px 12px;
      border-radius: 999px;
      background: #fff4cc;
      color: #8a6a00;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .applications-support-card h3 {
      margin-bottom: 14px;
      font-size: 1.5rem;
      line-height: 1.25;
      font-weight: 800;
      color: #111;
    }

    .applications-support-card p {
      margin-bottom: 18px;
      font-size: 0.96rem;
      line-height: 1.85;
      color: #666;
    }

    .applications-support-link {
      color: #0071e3;
      font-weight: 600;
      font-size: 0.95rem;
    }

    .applications-highlight-section {
      padding: 95px 0;
      background: #fff;
    }

    .applications-highlight-panel {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 28px;
      align-items: stretch;
      border-radius: 34px;
      padding: 42px;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      box-shadow: 0 28px 70px rgba(15, 23, 42, 0.16);
    }

    .applications-highlight-copy h2 {
      color: #fff;
    }

    .applications-highlight-copy p {
      color: rgba(255,255,255,0.82);
      margin: 0 0 24px;
    }

    .applications-highlight-actions,
    .applications-cta-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .applications-primary-btn,
    .applications-secondary-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 152px;
      padding: 14px 22px;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 700;
      transition: all 0.28s ease;
    }

    .applications-primary-btn {
      background: #ffcc00;
      color: #111;
    }

    .applications-primary-btn:hover {
      background: #ffd633;
    }

    .applications-secondary-btn {
      background: rgba(255,255,255,0.10);
      color: #fff;
      border: 1px solid rgba(255,255,255,0.18);
    }

    .applications-secondary-btn:hover {
      background: rgba(255,255,255,0.16);
    }

    .applications-secondary-btn.dark-outline {
      background: transparent;
      color: #111;
      border: 1px solid rgba(17,17,17,0.12);
    }

    .applications-secondary-btn.dark-outline:hover {
      background: #f7f8fa;
    }

    .applications-highlight-visual {
      display: grid;
      gap: 16px;
      align-content: center;
    }

    .applications-highlight-card {
      padding: 20px 22px;
      border-radius: 22px;
      background: rgba(255,255,255,0.10);
      border: 1px solid rgba(255,255,255,0.08);
      backdrop-filter: blur(8px);
    }

    .applications-highlight-card strong {
      display: block;
      margin-bottom: 8px;
      font-size: 1rem;
      color: #fff;
    }

    .applications-highlight-card span {
      display: block;
      font-size: 0.94rem;
      line-height: 1.75;
      color: rgba(255,255,255,0.80);
    }

    .applications-cta-section {
      padding: 0 0 95px;
      background: #fff;
    }

    .applications-cta-box {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 28px;
      padding: 38px 40px;
      border-radius: 30px;
      background: linear-gradient(180deg, #f7f8fa 0%, #ffffff 100%);
      border: 1px solid #ececec;
      box-shadow: 0 18px 45px rgba(15, 23, 42, 0.06);
    }

    .applications-cta-copy {
      max-width: 720px;
    }

    @media (max-width: 1200px) {
      .applications-grid,
      .applications-support-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .applications-highlight-panel {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 991px) {
      .applications-hero {
        min-height: 500px;
        padding: 135px 0 80px;
      }

      .applications-cta-box {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (max-width: 768px) {
      .applications-grid,
      .applications-support-grid {
        grid-template-columns: 1fr;
      }

.applications-hero {
  position: relative;
  min-height: 300px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0px 0 70px;
  background:
    linear-gradient(rgba(15, 23, 42, 0.18), rgba(15, 23, 42, 0.10)),
    url('/assets/img/header-bg.jpg') center/cover no-repeat;
  overflow: hidden;
  text-align: center;
}

      .applications-hero h1 {
        font-size: clamp(2.1rem, 8vw, 3rem);
      }

      .applications-highlight-panel,
      .applications-cta-box {
        padding: 28px 22px;
        border-radius: 24px;
      }

      .application-card,
      .applications-support-card {
        border-radius: 24px;
      }

      .application-card-image-wrap {
        min-height: 220px;
      }
    }
  </style>
</Layout>