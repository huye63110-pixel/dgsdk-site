---
import ZhProductLayout from '../../../../layouts/ZhProductLayout.astro';
---

<ZhProductLayout title="ST1200 卧式离子风机 | DGSDK 史帝克"
  description="大风量卧式离子风机，宽幅静电控制，适用于大型工作台、工业包装和显示屏制造。"
  image="/assets/img/static-eliminator/st-1200.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/zh/">首页</a>
        <span>/</span>
        <a href="/zh/products">产品</a>
        <span>/</span>
        <a href="/zh/products/static-eliminator">静电消除</a>
        <span>/</span>
        <span>ST1200 卧式离子风机</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/static-eliminator/st-1200.jpg"
              alt="ST1200 卧式离子风机"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/static-eliminator/st-1200.jpg"
              alt="ST1200 Thumbnail 1"
              data-full="/assets/img/static-eliminator/st-1200.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>ST1200 卧式离子风机</h1>
          <p class="product-short-desc">
            大风量卧式离子风机，宽幅静电控制，适用于大型工作台、工业包装和显示屏制造。
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">获取报价</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>大幅面覆盖</h4>
              <p>宽幅离子气流，覆盖更大工作区域。</p>
            </div>
            <div class="highlight-item">
              <h4>强劲风量</h4>
              <p>大风量输出，适合对消静范围要求较高的应用。</p>
            </div>
            <div class="highlight-item">
              <h4>工业级耐用</h4>
              <p>坚固设计，适合工业生产线的长期稳定使用。</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>产品描述</h2>
        <p>
          ST1200卧式离子风机专为需要大范围静电控制的工业工作台和生产线而设计，宽幅离子气流能有效覆盖较大工作面积。
        </p>
        <p>
          适用于大型工作台面、工业包装、显示屏制造和其他对静电控制覆盖范围要求较高的应用场景。
        </p>
      </section>

      <section class="detail-block">
        <h2>产品特点</h2>
        <ul class="feature-list">
          <li>大幅面宽覆盖，适合大型工作台和生产线</li>
          <li>强劲风量输出，消静效率高</li>
          <li>工业级耐用设计，稳定长期运行</li>
          <li>适用于显示屏制造和工业包装</li>
          <li>安装灵活，维护方便</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>技术优势</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>宽幅覆盖</h3>
            <p>大范围有效覆盖，满足工业工作台和大型生产线需求。</p>
          </div>
          <div class="advantage-card yellow">
            <h3>强劲风量</h3>
            <p>大风量输出设计，提升大面积消静效率。</p>
          </div>
          <div class="advantage-card green">
            <h3>工业耐用</h3>
            <p>坚固可靠的工业级设计，支持长期稳定生产运行。</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>应用行业</h2>
        <div class="application-tags">
          <span>显示屏制造</span>
          <span>工业包装</span>
          <span>工作台</span>
          <span>SMT生产</span>
          <span>电子制造</span>
          <span>自动化生产线</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="st-1200">
          <div class="related-slider-header">
            <h2>相关产品</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/zh/products/static-eliminator/st-g-series" class="related-slide-card" data-key="st-g-series">
              <img src="/assets/img/static-eliminator/st-g.jpg" alt="ST-G 系列智能离子棒" loading="lazy" />
              <h4>ST-G 系列智能离子棒</h4>
            </a>
            <a href="/zh/products/static-eliminator/st-e-series" class="related-slide-card" data-key="st-e-series">
              <img src="/assets/img/static-eliminator/st-e.jpg" alt="ST-E 系列智能离子棒" loading="lazy" />
              <h4>ST-E 系列智能离子棒</h4>
            </a>
            <a href="/zh/products/static-eliminator/st-f-series" class="related-slide-card" data-key="st-f-series">
              <img src="/assets/img/static-eliminator/st-f.jpg" alt="ST-F 系列智能离子棒" loading="lazy" />
              <h4>ST-F 系列智能离子棒</h4>
            </a>
            <a href="/zh/products/static-eliminator/st-s200" class="related-slide-card" data-key="st-s200">
              <img src="/assets/img/static-eliminator/st-s200.jpg" alt="ST-S200 迷你离子风机" loading="lazy" />
              <h4>ST-S200 迷你离子风机</h4>
            </a>
            <a href="/zh/products/static-eliminator/st-101a" class="related-slide-card" data-key="st-101a">
              <img src="/assets/img/static-eliminator/st-101a.webp" alt="ST101A 台式离子鼓风机" loading="lazy" />
              <h4>ST101A 台式离子鼓风机</h4>
            </a>
            <a href="/zh/products/static-eliminator/st-104a" class="related-slide-card" data-key="st-104a">
              <img src="/assets/img/static-eliminator/st-104a.jpg" alt="ST104A 卧式离子鼓风机" loading="lazy" />
              <h4>ST104A 卧式离子鼓风机</h4>
            </a>
            <a href="/zh/products/static-eliminator/st-1200" class="related-slide-card" data-key="st-1200">
              <img src="/assets/img/static-eliminator/st-1200.jpg" alt="ST1200 卧式离子风机" loading="lazy" />
              <h4>ST1200 卧式离子风机</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ZhProductLayout>
