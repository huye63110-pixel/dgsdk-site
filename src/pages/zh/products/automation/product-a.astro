---
import ZhProductLayout from '../../../../layouts/ZhProductLayout.astro';
---

<ZhProductLayout title="扩散板清洗检验生产线 | DGSDK 史帝克"
  description="集清洗、检验和连续传送为一体的自动化生产线，工作流稳定高效，适用于扩散板加工。"
  image="/assets/img/automation/product-a.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/zh/">首页</a>
        <span>/</span>
        <a href="/zh/products">产品</a>
        <span>/</span>
        <a href="/zh/products/automation">自动化设备</a>
        <span>/</span>
        <span>扩散板清洗检验生产线</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/automation/product-a.jpg"
              alt="扩散板清洗检验生产线"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/automation/product-a.jpg"
              alt="扩散板生产线缩略图"
              data-full="/assets/img/automation/product-a.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>扩散板清洗检验生产线</h1>
          <p class="product-short-desc">
            集清洗、检验和连续传送为一体的自动化生产线，工作流稳定高效，适用于扩散板加工。
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">获取报价</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>工序集成</h4>
              <p>清洗、检验和传送集成为一条连续生产线。</p>
            </div>
            <div class="highlight-item">
              <h4>工作流稳定</h4>
              <p>提升工序协调性，保持生产节拍一致性。</p>
            </div>
            <div class="highlight-item">
              <h4>自动化支持</h4>
              <p>适用于需要高效处理和检验集成的工业产线。</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>产品描述</h2>
        <p>
          扩散板清洗检验生产线专为需要连续物料传送、表面清洗、检验协调和稳定生产节拍的工业应用而开发。
        </p>
        <p>
          适用于扩散板加工及其他对集成自动化、清洗质量和检验效率有较高要求的片材类产品工作流。
        </p>
      </section>

      <section class="detail-block">
        <h2>产品特点</h2>
        <ul class="feature-list">
          <li>集成清洗和检验的一体化生产线设计</li>
          <li>连续传送结构，工作流稳定</li>
          <li>适用于扩散板和片材类产品处理</li>
          <li>提升生产效率和检验协调性</li>
          <li>支持根据项目需求定制自动化配置</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>技术优势</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>线体集成</h3>
            <p>减少工序分离，提升整体生产效率。</p>
          </div>
          <div class="advantage-card yellow">
            <h3>检验支持</h3>
            <p>维持稳定的表面检验和工作流一致性。</p>
          </div>
          <div class="advantage-card green">
            <h3>灵活设计</h3>
            <p>可根据产品尺寸、产能和工艺需求定制。</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>应用行业</h2>
        <div class="application-tags">
          <span>扩散板加工</span>
          <span>清洁生产线</span>
          <span>检验系统</span>
          <span>自动化生产</span>
          <span>片材处理</span>
          <span>定制工业生产线</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="product-a">
          <div class="related-slider-header">
            <h2>相关产品</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/zh/products/automation/product-a" class="related-slide-card" data-key="product-a">
              <img src="/assets/img/automation/product-a.jpg" alt="扩散板清洗检验生产线" loading="lazy" />
              <h4>扩散板清洗检验生产线</h4>
            </a>
            <a href="/zh/products/automation/product-b" class="related-slide-card" data-key="product-b">
              <img src="/assets/img/automation/product-b.jpg" alt="机器人自动上下料清洗机" loading="lazy" />
              <h4>机器人自动上下料清洗机</h4>
            </a>
            <a href="/zh/products/automation/product-c" class="related-slide-card" data-key="product-c">
              <img src="/assets/img/automation/product-c.jpg" alt="偏光片吸收轴角度测量仪" loading="lazy" />
              <h4>偏光片吸收轴角度测量仪</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ZhProductLayout>
