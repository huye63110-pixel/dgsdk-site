---
import ZhProductLayout from '../../../../layouts/ZhProductLayout.astro';
---

<ZhProductLayout title="偏光片精密清洁机 | DGSDK 史帝克"
  description="高精度偏光片清洁设备，有效去除贴合、检验和包装前的灰尘、纤维、颗粒及静电污染。"
  image="/assets/img/cleaning-machine/polarizer-cleaner.webp">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/zh/">首页</a>
        <span>/</span>
        <a href="/zh/products">产品</a>
        <span>/</span>
        <a href="/zh/products/cleaning-machine">清洁机</a>
        <span>/</span>
        <span>偏光片精密清洁机</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/cleaning-machine/polarizer-cleaner.jpg"
              alt="偏光片精密清洁机"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/cleaning-machine/polarizer-cleaner.jpg"
              alt="偏光片清洁机缩略图"
              data-full="/assets/img/cleaning-machine/polarizer-cleaner.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>偏光片精密清洁机</h1>
          <p class="product-short-desc">
            高精度偏光片清洁设备，有效去除贴合、检验和包装前的灰尘、纤维、颗粒及静电污染。
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">获取报价</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>精密清洁</h4>
              <p>专为敏感偏光片表面设计，清洁效果稳定可靠。</p>
            </div>
            <div class="highlight-item">
              <h4>防静电处理</h4>
              <p>集成静电消除功能，减少清洁过程中的静电吸尘。</p>
            </div>
            <div class="highlight-item">
              <h4>定制化配置</h4>
              <p>可根据物料尺寸和产线布局进行定制配置。</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>产品描述</h2>
        <p>
          偏光片表面极为敏感，灰尘、纤维和颗粒污染物会直接导致贴合缺陷和良率损失。偏光片精密清洁机专为去除这些污染物而开发，有效降低生产不良率。
        </p>
        <p>
          设备采用滚筒清洁原理，配合静电消除功能，确保偏光片在贴合前保持洁净表面，提升产品良率和生产稳定性。
        </p>
      </section>

      <section class="detail-block">
        <h2>产品特点</h2>
        <ul class="feature-list">
          <li>专为偏光片精密清洁而设计</li>
          <li>集成静电消除，减少静电吸附</li>
          <li>滚筒清洁方式，清洁效果稳定</li>
          <li>支持根据物料尺寸定制</li>
          <li>适用于贴合、检验和包装前处理</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>技术优势</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>精密清洁</h3>
            <p>专业清洁方案，有效去除偏光片表面污染物，保障产品质量。</p>
          </div>
          <div class="advantage-card yellow">
            <h3>静电消除</h3>
            <p>集成防静电功能，减少静电吸尘对清洁效果的影响。</p>
          </div>
          <div class="advantage-card green">
            <h3>定制配置</h3>
            <p>根据产线物料尺寸和布局需求进行定制配置。</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>应用行业</h2>
        <div class="application-tags">
          <span>显示屏制造</span>
          <span>偏光片生产</span>
          <span>光学薄膜</span>
          <span>贴合工艺</span>
          <span>LCD制造</span>
          <span>精密装配</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="polarizer-cleaner">
          <div class="related-slider-header">
            <h2>相关产品</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/zh/products/cleaning-machine/polarizer-cleaner" class="related-slide-card" data-key="polarizer-cleaner">
              <img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="偏光片精密清洁机" loading="lazy" />
              <h4>偏光片精密清洁机</h4>
            </a>
            <a href="/zh/products/cleaning-machine/fpc-4-axis-cleaner" class="related-slide-card" data-key="fpc-4-axis-cleaner">
              <img src="/assets/img/cleaning-machine/fpc-4-axis-cleaner.jpg" alt="FPC四轴高精度清洁机" loading="lazy" />
              <h4>FPC四轴高精度清洁机</h4>
            </a>
            <a href="/zh/products/cleaning-machine/fpc-8-axis-cleaner" class="related-slide-card" data-key="fpc-8-axis-cleaner">
              <img src="/assets/img/cleaning-machine/fpc-8-axis-cleaner.jpg" alt="FPC八轴高端清洁机" loading="lazy" />
              <h4>FPC八轴高端清洁机</h4>
            </a>
            <a href="/zh/products/cleaning-machine/optical-film-cleaner" class="related-slide-card" data-key="optical-film-cleaner">
              <img src="/assets/img/cleaning-machine/optical.jpg" alt="大尺寸光学薄膜清洁机" loading="lazy" />
              <h4>大尺寸光学薄膜清洁机</h4>
            </a>
            <a href="/zh/products/cleaning-machine/lcm-cleaner" class="related-slide-card" data-key="lcm-cleaner">
              <img src="/assets/img/cleaning-machine/lcm-cleaner.jpg" alt="LCM模组工业清洁机" loading="lazy" />
              <h4>LCM模组工业清洁机</h4>
            </a>
            <a href="/zh/products/cleaning-machine/pcb-cleaner" class="related-slide-card" data-key="pcb-cleaner">
              <img src="/assets/img/cleaning-machine/pcb-cleaner.jpg" alt="PCB表面清洁机" loading="lazy" />
              <h4>PCB表面清洁机</h4>
            </a>
            <a href="/zh/products/cleaning-machine/pcb-vertical-cleaner" class="related-slide-card" data-key="pcb-vertical-cleaner">
              <img src="/assets/img/cleaning-machine/stick-pcb-vertical-cleaning-machine.jpg" alt="PCB垂直清洁系统" loading="lazy" />
              <h4>PCB垂直清洁系统</h4>
            </a>
            <a href="/zh/products/cleaning-machine/roll-chip-cleaner" class="related-slide-card" data-key="roll-chip-cleaner">
              <img src="/assets/img/cleaning-machine/roll-chip-cleaner.jpg" alt="滚轮通用清洁机" loading="lazy" />
              <h4>滚轮通用清洁机</h4>
            </a>
            <a href="/zh/products/cleaning-machine/smt-cleaner" class="related-slide-card" data-key="smt-cleaner">
              <img src="/assets/img/cleaning-machine/smt-cleaner.jpg" alt="SMT在线清洁机" loading="lazy" />
              <h4>SMT在线清洁机</h4>
            </a>
            <a href="/zh/products/cleaning-machine/backlight-cleaner" class="related-slide-card" data-key="backlight-cleaner">
              <img src="/assets/img/cleaning-machine/backlight-cleaner.jpg" alt="背光板清洁机" loading="lazy" />
              <h4>背光板清洁机</h4>
            </a>
            <a href="/zh/products/cleaning-machine/ccl-cleaner" class="related-slide-card" data-key="ccl-cleaner">
              <img src="/assets/img/cleaning-machine/ccl-cleaner.jpg" alt="史帝克CCL清洁机" loading="lazy" />
              <h4>史帝克CCL清洁机</h4>
            </a>
            <a href="/zh/products/cleaning-machine/inspection-cleaner" class="related-slide-card" data-key="inspection-cleaner">
              <img src="/assets/img/cleaning-machine/inspection-cleaner.jpg" alt="检验台清洁机" loading="lazy" />
              <h4>检验台清洁机</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ZhProductLayout>
