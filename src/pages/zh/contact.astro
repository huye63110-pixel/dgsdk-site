---
import ZhLayout from '../../layouts/ZhLayout.astro';
---

<ZhLayout
  title="联系我们 | DGSDK 史帝克"
  description="联系东莞史帝克自动化设备有限公司，获取工业自动化、静电消除器、清洁机和精密CNC零件的报价与技术支持。工作日24小时内回复。"
  canonical="https://www.dg-sdk.com/zh/contact"
>
  <section
    class="contact-hero"
    style="background: linear-gradient(rgba(113, 87, 87, 0.28), rgba(106, 56, 56, 0.18)), url('/assets/img/contact/contact.jpg') center/cover no-repeat;"
  >
    <div class="category-hero-overlay"></div>
    <div class="container category-hero-content">
      <h1>联系我们</h1>
      <p>
        联系史帝克，获取工业自动化设备、静电消除器、清洁机和精密CNC零件的报价与合作信息。
      </p>
    </div>
  </section>

  <section class="page-section contact-modern">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-left">
          <h2>联系我们</h2>

          <p class="company-name">东莞史帝克自动化设备有限公司</p>

          <p class="contact-desc">
            我们致力于为全球客户提供可靠的工业自动化解决方案、静电消除系统、清洁机和精密CNC零件。欢迎随时联系我们了解更多产品信息和合作机会。
          </p>

          <div class="response-guarantee">
            <i class="fas fa-clock"></i>
            <span>我们承诺在工作日 <strong>24小时内</strong> 回复所有询价。</span>
          </div>

          <h3>如有疑问，请联系我们</h3>

          <div class="contact-info-list">
            <div class="contact-info-item">
              <div class="contact-icon">
                <i class="fas fa-phone-alt"></i>
              </div>
              <div>
                <span class="contact-label">手机：</span>
                <p>+86 13602342003</p>
              </div>
            </div>

            <div class="contact-info-item">
              <div class="contact-icon">
                <i class="fab fa-whatsapp"></i>
              </div>
              <div>
                <span class="contact-label">WhatsApp：</span>
                <p>+61 436605126</p>
              </div>
            </div>

            <div class="contact-info-item">
              <div class="contact-icon">
                <i class="fas fa-envelope"></i>
              </div>
              <div>
                <span class="contact-label">邮箱：</span>
                <p>dgsdk2013@gmail.com</p>
              </div>
            </div>

            <div class="contact-info-item">
              <div class="contact-icon">
                <i class="fas fa-map-marker-alt"></i>
              </div>
              <div>
                <span class="contact-label">地址：</span>
                <p>广东省东莞市滨海路33号</p>
              </div>
            </div>
          </div>
        </div>

        <div class="contact-right">
          <div class="map-box">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3678.478825294075!2d113.76762507613407!3d22.784714925161143!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x34039625f048b6f7%3A0x20abebbe17b92cf2!2z5Lit5Zu95bm_5Lic55yB5Lic6I6e5biC5ruo5rKz6LevMzPlj7cg6YKu5pS_57yW56CBOiA1MjM4NTA!5e0!3m2!1szh-CN!2sus!4v1745226418103!5m2!1szh-CN!2sus"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section bg-light">
    <div class="container">
      <div class="text-center">
        <h2 class="section-heading text-uppercase">发送询价</h2>
        <h3 class="section-subheading text-muted">
          请留下您的信息，我们将在工作日24小时内回复您。
        </h3>
      </div>

      <div class="row justify-content-center">
        <div class="col-lg-8">
          <form action="https://formspree.io/f/mvzlpdwy" method="POST">
            <div class="form-group mb-3">
              <input class="form-control" type="text" name="name" placeholder="您的姓名 *" required />
            </div>

            <div class="form-group mb-3">
              <input class="form-control" type="email" name="email" placeholder="您的邮箱 *" required />
            </div>

            <div class="form-group mb-3">
              <input class="form-control" type="text" name="company" placeholder="公司名称" />
            </div>

            <div class="form-group mb-3">
              <textarea class="form-control" name="message" rows="6" placeholder="您的留言 *" required></textarea>
            </div>

            <div class="text-center">
              <button class="btn btn-primary btn-xl text-uppercase" type="submit">
                发送留言
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</ZhLayout>
