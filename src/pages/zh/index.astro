            const dots = document.querySelectorAll('#blogDotsZH span');
            function getCardWidth(){
              const card = track.querySelector('.blog-index-card');
              return card ? card.offsetWidth + 24 : 340;
            }
            document.getElementById('blogPrevZH').addEventListener('click',()=>track.scrollBy({left:-getCardWidth(),behavior:'smooth'}));
            document.getElementById('blogNextZH').addEventListener('click',()=>track.scrollBy({left:getCardWidth(),behavior:'smooth'}));
            track.addEventListener('scroll',()=>{
              const idx = Math.round(track.scrollLeft / getCardWidth());
              dots.forEach((d,i)=>d.classList.toggle('active',i===idx));
            },{passive:true});
            dots.forEach((d,i)=>d.addEventListener('click',()=>track.scrollTo({left:i*getCardWidth(),behavior:'smooth'})));
          })();
        </script>

