---
import ArLayout from '../../layouts/ArLayout.astro';

const faqItems = [
  {
    question: 'ما هو الحد الأدنى للطلب؟ هل يمكن تقديم طلبات تجريبية بكميات صغيرة؟',
    answer: 'الحد الأدنى للطلب القياسي عادةً 500 قطعة لكل منتج، وبعض الفئات يمكن البدء من 100 قطعة. كما نقبل الطلبات التجريبية بكميات صغيرة لبعض المنتجات، وقد تُحتسب رسوم على العينات يمكن خصمها من الطلبات الكبيرة لاحقاً. الطلبات المختلطة التي تبلغ كميات معينة قد لا تستلزم رسوم معالجة إضافية.'
  },
  {
    question: 'ما هي طرق الدفع المقبولة؟',
    answer: 'نقبل عادةً التحويل المصرفي (T/T) بدفعة أولى 30% والباقي قبل الشحن. للطلبات الكبيرة يمكن مناقشة خطاب الاعتماد (L/C). يُقبل PayPal للطلبات الصغيرة والعينات. لضمان سلامة المعاملات، يمكننا تقديم الفاتورة المبدئية ووثائق تسجيل الشركة والمستندات المتعلقة بالتصدير.'
  },
  {
    question: 'ما هي مهل التسليم المعتادة؟ هل تقبلون الطلبات العاجلة؟',
    answer: 'وقت الإنتاج القياسي عادةً 25 إلى 35 يوم عمل بعد تأكيد العينة، ويتفاوت حسب نوع المنتج والكمية. للمشاريع العاجلة يمكن التفاوض على الإنتاج المستعجل عند توافر الجدول الزمني وقد يستلزم رسوماً إضافية. يمكن أيضاً ترتيب الشحن على دفعات لبعض الطلبات.'
  },
  {
    question: 'كيف تضمنون جودة المنتجات؟',
    answer: 'نطبق عمليات رقابة جودة شاملة تشمل فحص المواد الخام، ومراقبة الإنتاج، والفحص النهائي قبل الشحن. تهدف إجراءات إدارة الجودة لدينا إلى ضمان ثبات أداء المنتج. في حالة وجود مشاكل جودة مؤكدة، نتعاون مع العميل لإيجاد الحل المناسب كالاستبدال أو التعويض.'
  },
  {
    question: 'هل تقدمون خدمات OEM أو ODM؟',
    answer: 'نعم، نقدم خدمات OEM وODM. في مشاريع OEM يمكن للعملاء تقديم رسوماتهم ومواصفاتهم أو متطلبات علامتهم التجارية. في مشاريع ODM يمكننا المساعدة في تطوير المنتج وتصميم الحلول بناءً على احتياجات التطبيق. كما نقبل توقيع اتفاقيات عدم الإفصاح (NDA) عند الحاجة.'
  },
  {
    question: 'هل تستوفي منتجاتكم الشهادات الدولية؟',
    answer: 'يمكن تقديم وثائق الامتثال للمعايير الدولية حسب فئة المنتج والسوق المستهدف. الشهادات الشائعة تشمل ISO وCE وFCC وRoHS وREACH. متطلبات الشهادات الخاصة يمكن مناقشة إجراءاتها بناءً على احتياجات مشروعك.'
  },
  {
    question: 'ما هي خيارات الشحن المتاحة؟',
    answer: 'ندعم طرق شحن متعددة تشمل الشحن البحري والجوي والبريد السريع والسكك الحديدية حسب وجهة الشحن ومتطلبات البضاعة. نقدم توصيات الشحن بناءً على التكلفة والجدول الزمني، ويمكننا التنسيق مع وكيل الشحن المحدد من قبل العميل.'
  },
  {
    question: 'هل يمكنكم المساعدة في تسوية الجمارك والرسوم الاستيرادية؟',
    answer: 'نوفر المستندات التصديرية اللازمة كالفاتورة التجارية وقائمة التعبئة وشهادة المنشأ (عند الاقتضاء). تعتمد رسوم الاستيراد والضريبة على القيمة المضافة ورسوم التخليص الجمركي على بلد الوجهة ورمز HS للمنتج. يمكن مناقشة شروط DDP أو DDU لبعض الأسواق عند الحاجة.'
  },
  {
    question: 'هل تتوفر عينات للتقييم؟',
    answer: 'نعم، يمكن توفير عينات المنتجات للتقييم. تكلفة العينة وترتيبات الشحن تختلف حسب نوع المنتج وما إذا كانت تخصيصاً. في معظم الحالات يمكن خصم رسوم العينة من الطلب الكبير التالي. يتفاوت وقت إنتاج العينات المخصصة حسب تعقيد المتطلبات.'
  },
  {
    question: 'كيف تتعاملون مع تقلبات أسعار العملات؟',
    answer: 'الأسعار عادةً صالحة لفترة محدودة وقد يعتمد التسعير النهائي على سعر الصرف عند تأكيد الطلب. للمشاريع الكبيرة يمكن مناقشة الدفع على مراحل أو حلول عملية أخرى للحد من مخاطر تقلبات العملة عند الاقتضاء.'
  }
];
---

<ArLayout
  title="الأسئلة الشائعة | DGSDK"
  description="أسئلة شائعة حول منتجات DGSDK تشمل معلومات عن أنظمة إزالة الكهرباء الساكنة وآلات التنظيف ومعدات الأتمتة وقطع CNC والطلبيات والجودة ومواعيد التسليم."
  canonical="https://www.dg-sdk.com/ar/faq"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  })} />

  <section
    class="faq-hero"
    style="background: linear-gradient(rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.18)), url('/assets/img/faq/faq-bg.jpg') center/cover no-repeat;"
  >
    <div class="faq-hero-overlay"></div>
    <div class="container faq-hero-content">
      <span class="faq-hero-kicker">الأسئلة الشائعة</span>
      <h1>إجابات على الأسئلة الشائعة حول منتجاتنا وتطبيقاتنا وخدماتنا.</h1>
      <p>
        استعرض الأسئلة الشائعة حول حلول DGSDK، تشمل التطبيقات الصناعية، فئات المنتجات، التصنيع المخصص، دعم الأتمتة وأساليب التعاون.
      </p>
    </div>
  </section>

  <section class="faq-intro-section">
    <div class="container">
      <div class="faq-intro-box">
        <span class="faq-section-label">الدعم والمعلومات</span>
        <h2>إجابات واضحة وعملية.</h2>
        <p>تساعد هذه الصفحة العملاء على فهم منتجاتنا وخدماتنا وقدراتنا الصناعية قبل بدء التعاون.</p>
      </div>
    </div>
  </section>

  <section class="faq-main-section">
    <div class="container">
      <div class="faq-layout">
        <aside class="faq-side-panel">
          <div class="faq-side-card">
            <span class="faq-side-label">دليل سريع</span>
            <h3>هل تحتاج مساعدة في إيجاد الحل المناسب؟</h3>
            <p>
              تصفح الأسئلة أدناه، أو تواصل مباشرة مع DGSDK للحصول على توصيات المنتجات والدعم الصناعي المخصص.
            </p>
            <div class="faq-side-actions">
              <a href="/ar/contact" class="faq-primary-btn">اتصل بنا</a>
              <a href="/ar/products" class="faq-text-link">تصفح المنتجات</a>
            </div>
          </div>
        </aside>

        <div class="faq-content">
          <div class="faq-heading-block">
            <span class="faq-section-label">الأسئلة الشائعة</span>
            <h2>أسئلة العملاء والشركاء الشائعة.</h2>
            <p>لتيسير اختيار المنتج وتسهيل التواصل التجاري.</p>
          </div>

          <div class="faq-list">
            {faqItems.map((item, index) => (
              <details class="faq-item" open={index === 0}>
                <summary class="faq-question">
                  <span>{item.question}</span>
                  <span class="faq-icon"></span>
                </summary>
                <div class="faq-answer">
                  <p>{item.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-bottom-section">
    <div class="container">
      <div class="faq-bottom-panel">
        <div class="faq-bottom-copy">
          <span class="faq-section-label dark">هل لديك المزيد من الأسئلة؟</span>
          <h2>يسعدنا مناقشة تطبيقاتك أو متطلبات منتجاتك.</h2>
          <p>
            إذا لم تجد إجابة لسؤالك هنا، يمكن لفريقنا مساعدتك في اختيار المنتج المناسب ومطابقة التطبيق والحلول الصناعية المخصصة.
          </p>
        </div>

        <div class="faq-bottom-actions">
          <a href="/ar/contact" class="faq-primary-btn">اتصل بنا</a>
          <a href="/ar/applications" class="faq-secondary-btn">تصفح التطبيقات</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .faq-hero {
      position: relative;
      min-height: 680px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 125px 0 60px;
      background:
        linear-gradient(rgba(15, 23, 42, 0.18), rgba(15, 23, 42, 0.10)),
        url('/assets/img/header-bg.jpg') center/cover no-repeat;
      overflow: hidden;
      text-align: center;
    }
    .faq-hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(rgba(255,255,255,0.06), rgba(255,255,255,0.03));
    }
    .faq-hero-content {
      position: relative;
      z-index: 2;
      max-width: 960px;
    }
    .faq-hero-kicker,
    .faq-section-label,
    .faq-side-label {
      display: inline-block;
      margin-bottom: 16px;
      padding: 6px 14px;
      border-radius: 999px;
      background: #fff4cc;
      color: #8a6a00;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .faq-section-label.dark {
      background: rgba(255,255,255,0.12);
      color: #fff4cc;
    }
    .faq-hero h1 {
      margin-bottom: 18px;
      font-size: clamp(2.4rem, 5vw, 4.6rem);
      line-height: 1.06;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #111;
    }
    .faq-hero p {
      max-width: 820px;
      margin: 0 auto;
      font-size: 1.04rem;
      line-height: 1.85;
      color: rgba(17,17,17,0.72);
    }
    .faq-intro-section { padding: 70px 0 32px; background: #fff; }
    .faq-intro-box, .faq-heading-block { max-width: 860px; margin: 0 auto; text-align: center; }
    .faq-intro-box h2, .faq-heading-block h2, .faq-bottom-copy h2 {
      margin-bottom: 16px;
      font-size: clamp(2rem, 3.4vw, 3rem);
      line-height: 1.1;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #111;
    }
    .faq-intro-box p, .faq-heading-block p, .faq-bottom-copy p, .faq-side-card p {
      margin: 0;
      font-size: 1rem;
      line-height: 1.85;
      color: #666;
    }
    .faq-main-section { padding: 40px 0 95px; background: #fff; }
    .faq-layout {
      display: grid;
      grid-template-columns: 300px minmax(0, 1fr);
      gap: 30px;
      align-items: start;
    }
    .faq-side-panel { position: sticky; top: 110px; margin-right: -16px; }
    .faq-side-card {
      padding: 28px;
      border-radius: 28px;
      background: linear-gradient(180deg, #ffffff 0%, #f8f9fb 100%);
      border: 1px solid #ececec;
      box-shadow: 0 18px 45px rgba(15,23,42,0.06);
    }
    .faq-side-card h3 { margin-bottom: 14px; font-size: 1.5rem; line-height: 1.25; font-weight: 800; color: #111; }
    .faq-side-actions { display: flex; flex-direction: column; gap: 12px; margin-top: 22px; }
    .faq-primary-btn, .faq-secondary-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 150px;
      padding: 14px 22px;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 700;
      transition: all 0.28s ease;
    }
    .faq-primary-btn { background: #ffcc00; color: #111; }
    .faq-primary-btn:hover { background: #ffd633; }
    .faq-secondary-btn { background: rgba(255,255,255,0.12); color: #fff; border: 1px solid rgba(255,255,255,0.18); }
    .faq-secondary-btn:hover { background: rgba(255,255,255,0.18); }
    .faq-text-link { display: inline-block; text-decoration: none; color: #0071e3; font-weight: 600; font-size: 0.96rem; }
    .faq-content { display: flex; flex-direction: column; gap: 26px; align-items: flex-start; width: 100%; max-width: 860px; }
    .faq-list { display: grid; gap: 18px; width: 100%; }
    .faq-item {
      background: #fff;
      border: 1px solid #ececec;
      border-radius: 26px;
      overflow: hidden;
      box-shadow: 0 16px 40px rgba(15,23,42,0.05);
      transition: box-shadow 0.28s ease, transform 0.28s ease;
    }
    .faq-item:hover { transform: translateY(-3px); box-shadow: 0 22px 50px rgba(15,23,42,0.10); }
    .faq-question {
      list-style: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 24px 26px;
      font-size: 1.14rem;
      line-height: 1.5;
      font-weight: 700;
      color: #111;
      user-select: none;
    }
    .faq-question::-webkit-details-marker { display: none; }
    .faq-icon { position: relative; width: 22px; height: 22px; flex-shrink: 0; }
    .faq-icon::before, .faq-icon::after {
      content: '';
      position: absolute;
      left: 50%;
      top: 50%;
      width: 16px;
      height: 2px;
      background: #111;
      border-radius: 999px;
      transform: translate(-50%, -50%);
      transition: transform 0.25s ease, opacity 0.25s ease;
    }
    .faq-icon::after { transform: translate(-50%, -50%) rotate(90deg); }
    .faq-item[open] .faq-icon::after { opacity: 0; transform: translate(-50%, -50%) rotate(90deg) scaleX(0.2); }
    .faq-answer { padding: 0 26px 24px; }
    .faq-answer p { margin: 0; font-size: 1rem; line-height: 1.85; color: #666; }
    .faq-bottom-section { padding: 0 0 95px; background: #fff; }
    .faq-bottom-panel {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 28px;
      padding: 40px 42px;
      border-radius: 32px;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      box-shadow: 0 28px 70px rgba(15,23,42,0.16);
    }
    .faq-bottom-copy { max-width: 720px; }
    .faq-bottom-copy h2 { color: #fff; }
    .faq-bottom-copy p { color: rgba(255,255,255,0.82); }
    .faq-bottom-actions { display: flex; gap: 14px; flex-wrap: wrap; }
    .faq-heading-block { width: 100%; max-width: 860px; margin: 0; text-align: right; }
    .faq-heading-block h2, .faq-heading-block p { width: 100%; max-width: 100%; margin-right: 0; }
    .faq-heading-block .faq-section-label { margin-right: 0; margin-left: auto; }
    @media (max-width: 991px) {
      .faq-layout { grid-template-columns: 1fr; }
      .faq-side-panel { position: sticky; top: 120px; margin-right: 0; }
      .faq-bottom-panel { flex-direction: column; align-items: flex-start; }
      .faq-heading-block { width: 100%; max-width: 860px; margin: 0 auto; text-align: center; }
      .faq-content { align-items: stretch; width: 100%; }
      .faq-heading-block .faq-section-label { margin-right: auto; margin-left: auto; }
    }
    @media (max-width: 768px) {
      .faq-hero { min-height: 260px; padding: 105px 0 45px; }
      .faq-hero h1 { font-size: clamp(2rem, 8vw, 2.9rem); }
      .faq-side-card, .faq-item, .faq-bottom-panel { border-radius: 24px; }
      .faq-question { padding: 20px; font-size: 1rem; }
      .faq-answer { padding: 0 20px 20px; }
      .faq-bottom-panel { padding: 28px 22px; }
    }
  </style>
</ArLayout>
