---
import ArProductLayout from '../../../../layouts/ArProductLayout.astro';
---

<ArProductLayout title="كتلة توصيل جناحية CNC | DGSDK"
  description="كتلة توصيل جناحية مطحونة بـ CNC بدقة عالية، تُستخدم للتوصيل الهيكلي للمعدات الصناعية وتكامل أنظمة التجميع الدقيق."
  image="/assets/img/precision-machined-parts/cnc-milled-wing-connection-block.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/ar/">الرئيسية</a>
        <span>/</span>
        <a href="/ar/products">المنتجات</a>
        <span>/</span>
        <a href="/ar/products/precision-machined-parts">قطع مشغولة بدقة</a>
        <span>/</span>
        <span>كتلة توصيل جناحية CNC</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/precision-machined-parts/cnc-milled-wing-connection-block.jpg"
              alt="كتلة توصيل جناحية CNC"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/precision-machined-parts/cnc-milled-wing-connection-block.jpg"
              alt="صورة مصغرة لكتلة التوصيل الجناحية CNC"
              data-full="/assets/img/precision-machined-parts/cnc-milled-wing-connection-block.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>كتلة توصيل جناحية CNC</h1>
          <p class="product-short-desc">
            كتلة توصيل جناحية مطحونة بـ CNC بدقة عالية، تُستخدم للتوصيل الهيكلي للمعدات الصناعية وتكامل أنظمة التجميع الدقيق.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">احصل على عرض سعر</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>توصيل دقيق</h4>
              <p>تشغيل عالي الدقة يضمن الدقة والموثوقية في التوصيل الهيكلي.</p>
            </div>
            <div class="highlight-item">
              <h4>طحن CNC</h4>
              <p>عملية طحن CNC الدقيقة مع تحكم صارم في تفاوتات الأبعاد.</p>
            </div>
            <div class="highlight-item">
              <h4>هيكل موثوق</h4>
              <p>مُصنَّع من مواد عالية الجودة، توصيل متين مناسب للاستخدام الصناعي الطويل الأمد.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>وصف المنتج</h2>
        <p>
          كتلة التوصيل الجناحية CNC هي قطعة هيكلية مهمة في معدات الأتمتة الصناعية وأنظمة التجميع الدقيق، تُستخدم لتوصيل وتثبيت وحدات الأجهزة الوظيفية المختلفة.
        </p>
        <p>
          تُصنَّع بعملية طحن CNC عالية الدقة مع تحكم صارم في دقة الأبعاد وجودة السطح، لضمان موثوقية التوصيل ودقة التجميع، وتلبية متطلبات القوة الهيكلية والدقة للمعدات الصناعية.
        </p>
      </section>

      <section class="detail-block">
        <h2>مميزات المنتج</h2>
        <ul class="feature-list">
          <li>طحن CNC عالي الدقة مع تحكم صارم في التفاوتات</li>
          <li>تصميم هيكلي جناحي، توصيل متين وموثوق</li>
          <li>مناسب لتوصيل وحدات المعدات الصناعية</li>
          <li>مواد عالية الجودة بمتانة عالية</li>
          <li>يدعم الأبعاد والمواصفات المخصصة</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>المزايا التقنية</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>تشغيل دقيق</h3>
            <p>طحن CNC عالي الدقة يضمن دقة أبعاد كتلة التوصيل وموثوقية تجميعها.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>هيكل متين</h3>
            <p>تصميم التوصيل الجناحي يوفر دعمًا هيكليًا موثوقًا وقوة توصيل عالية.</p>
          </div>
          <div class="advantage-card green">
            <h3>متانة وموثوقية</h3>
            <p>مواد وعمليات دقيقة عالية الجودة تلبي متطلبات الاستخدام الصناعي الطويل الأمد.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>قطاعات التطبيق</h2>
        <div class="application-tags">
          <span>تشغيل CNC</span>
          <span>التصنيع الدقيق</span>
          <span>المعدات الصناعية</span>
          <span>معدات الأتمتة</span>
          <span>القطع الميكانيكية</span>
          <span>إنتاج OEM</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="cnc-wing-connection-block">
          <div class="related-slider-header">
            <h2>منتجات ذات صلة</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/ar/products/precision-machined-parts/custom-precision-machined-parts" class="related-slide-card" data-key="custom-precision-machined-parts">
              <img src="/assets/img/precision-machined-parts/precision-machined-parts.jpg" alt="قطع مشغولة بدقة مخصصة" loading="lazy" />
              <h4>قطع مشغولة بدقة مخصصة</h4>
            </a>
            <a href="/ar/products/precision-machined-parts/cnc-milled-front-panel-rubber-roller-assembly" class="related-slide-card" data-key="cnc-milled-front-panel-rubber-roller-assembly">
              <img src="/assets/img/precision-machined-parts/cnc-milled-front-panel-rubber-roller-assembly.jpg" alt="لوحة أمامية مطحونة بـ CNC لتجميع أسطوانة مطاطية" loading="lazy" />
              <h4>لوحة أمامية مطحونة بـ CNC لتجميع أسطوانة مطاطية</h4>
            </a>
            <a href="/ar/products/precision-machined-parts/cnc-wing-connection-block" class="related-slide-card" data-key="cnc-wing-connection-block">
              <img src="/assets/img/precision-machined-parts/cnc-milled-wing-connection-block.jpg" alt="كتلة توصيل جناحية CNC" loading="lazy" />
              <h4>كتلة توصيل جناحية CNC</h4>
            </a>
            <a href="/ar/products/precision-machined-parts/lathe-machined-bearing-outer-retainer-plate" class="related-slide-card" data-key="lathe-machined-bearing-outer-retainer-plate">
              <img src="/assets/img/precision-machined-parts/lathe-machined-bearing-outer-retainer-plate.jpg" alt="لوحة تثبيت خارجية للمحمل مشغولة بالمخرطة" loading="lazy" />
              <h4>لوحة تثبيت خارجية للمحمل مشغولة بالمخرطة</h4>
            </a>
            <a href="/ar/products/precision-machined-parts/lathe-machined-shaft-end-fixing-component" class="related-slide-card" data-key="lathe-machined-shaft-end-fixing-component">
              <img src="/assets/img/precision-machined-parts/lathe-machined-shaft-end-fixing-component.jpg" alt="مكون تثبيت نهاية المحور مشغول بالمخرطة" loading="lazy" />
              <h4>مكون تثبيت نهاية المحور مشغول بالمخرطة</h4>
            </a>
            <a href="/ar/products/precision-machined-parts/milled-front-inner-fixing-plate-paper-roll-guide-rail" class="related-slide-card" data-key="milled-front-inner-fixing-plate-paper-roll-guide-rail">
              <img src="/assets/img/precision-machined-parts/milled-front-inner-fixing-plate-paper-roll-guide-rail.jpg" alt="لوحة تثبيت داخلية أمامية مطحونة لسكة توجيه لفة الورق" loading="lazy" />
              <h4>لوحة تثبيت داخلية أمامية مطحونة لسكة توجيه لفة الورق</h4>
            </a>
            <a href="/ar/products/precision-machined-parts/precision-bearing-bracket-cnc-milled" class="related-slide-card" data-key="precision-bearing-bracket-cnc-milled">
              <img src="/assets/img/precision-machined-parts/precision-bearing-bracket-cnc-milled.jpg" alt="حامل محمل دقيق (مطحون بـ CNC)" loading="lazy" />
              <h4>حامل محمل دقيق (مطحون بـ CNC)</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ArProductLayout>
