    <div class="container">
      <div class="breadcrumb">
        <a href="/ar/">الرئيسية</a>
        <span>/</span>
        <a href="/ar/products">المنتجات</a>
        <span>/</span>
        <a href="/ar/products/cleaning-machine">آلات التنظيف</a>
        <span>/</span>
        <span>آلة تنظيف أسطح PCB</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
