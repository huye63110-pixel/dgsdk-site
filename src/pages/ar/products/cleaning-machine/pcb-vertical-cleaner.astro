            <a href="/ar/products/cleaning-machine/optical-film-cleaner" class="related-slide-card" data-key="optical-film-cleaner">
              <img src="/assets/img/cleaning-machine/optical.jpg" alt="آلة تنظيف الأفلام البصرية الكبيرة" loading="lazy" />
              <h4>آلة تنظيف الأفلام البصرية الكبيرة</h4>
            </a>
            <a href="/ar/products/cleaning-machine/lcm-cleaner" class="related-slide-card" data-key="lcm-cleaner">
