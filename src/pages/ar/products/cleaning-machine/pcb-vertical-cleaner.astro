---
import ArProductLayout from '../../../../layouts/ArProductLayout.astro';
---

<ArProductLayout title="نظام تنظيف PCB الرأسي | DGSDK"
  description="معدات تنظيف PCB بتصميم رأسي مدمج، مناسبة لتطبيقات تصنيع PCB والمعالجة المسبقة للتفتيش في البيئات ذات المساحة المحدودة."
  image="/assets/img/cleaning-machine/stick-pcb-vertical-cleaning-machine.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/ar/">الرئيسية</a>
        <span>/</span>
        <a href="/ar/products">المنتجات</a>
        <span>/</span>
        <a href="/ar/products/cleaning-machine">آلات التنظيف</a>
        <span>/</span>
        <span>نظام تنظيف PCB الرأسي</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/cleaning-machine/stick-pcb-vertical-cleaning-machine.jpg"
              alt="نظام تنظيف PCB الرأسي"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/cleaning-machine/stick-pcb-vertical-cleaning-machine.jpg"
              alt="صورة مصغرة لنظام تنظيف PCB الرأسي"
              data-full="/assets/img/cleaning-machine/stick-pcb-vertical-cleaning-machine.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>نظام تنظيف PCB الرأسي</h1>
          <p class="product-short-desc">
            معدات تنظيف PCB بتصميم رأسي مدمج، مناسبة لتطبيقات تصنيع PCB والمعالجة المسبقة للتفتيش في البيئات ذات المساحة المحدودة.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">طلب عرض سعر</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>تصميم رأسي مدمج</h4>
              <p>التخطيط الرأسي يوفر مساحة أرضية في المصنع، وهو مثالي لبيئات الإنتاج ذات المساحة المحدودة.</p>
            </div>
            <div class="highlight-item">
              <h4>تنظيف PCB فعّال</h4>
              <p>إزالة فعّالة للملوثات من سطح PCB لضمان جودة العملية.</p>
            </div>
            <div class="highlight-item">
              <h4>توافق مع مراحل الإنتاج</h4>
              <p>مناسبة لتنظيف السطح قبل المراحل الرئيسية في تصنيع PCB.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>وصف المنتج</h2>
        <p>
          بالنسبة لمصانع PCB ذات المساحة الأرضية المحدودة، تشغل آلات التنظيف الأفقية التقليدية مساحة كبيرة. يعتمد نظام تنظيف PCB الرأسي تصميماً رأسياً يوفر مساحة المصنع بشكل فعّال.
        </p>
        <p>
          يضمن الحل الرأسي فعالية التنظيف مع تقليل مساحة المعدات المشغولة، وهو مناسب لتطبيقات تصنيع PCB المدمجة والمعالجة المسبقة للتفتيش.
        </p>
      </section>

      <section class="detail-block">
        <h2>مميزات المنتج</h2>
        <ul class="feature-list">
          <li>تخطيط رأسي يوفر المساحة الأرضية بشكل فعّال</li>
          <li>إزالة فعّالة للغبار والجسيمات من سطح PCB</li>
          <li>مناسبة للمراحل الرئيسية قبل التصنيع والتفتيش</li>
          <li>نقل مستقر وسلس لألواح PCB</li>
          <li>دعم التهيئة المخصصة للأحجام المختلفة</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>المزايا التقنية</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>توفير المساحة بالتصميم الرأسي</h3>
            <p>التصميم الرأسي يُقلل بشكل كبير من المساحة الأرضية المشغولة.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>تنظيف فعّال</h3>
            <p>أداء تنظيف فعّال لأسطح PCB يضمن متطلبات جودة العملية.</p>
          </div>
          <div class="advantage-card green">
            <h3>تهيئة مرنة</h3>
            <p>دعم التهيئة المخصصة وفقاً لأحجام PCB ومتطلبات العملية.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>قطاعات التطبيق</h2>
        <div class="application-tags">
          <span>تصنيع PCB</span>
          <span>التصنيع الإلكتروني</span>
          <span>إنتاج SMT</span>
          <span>خطوط التفتيش</span>
          <span>عمليات الطباعة</span>
          <span>الإنتاج الصناعي</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="pcb-vertical-cleaner">
          <div class="related-slider-header">
            <h2>منتجات ذات صلة</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/ar/products/cleaning-machine/polarizer-cleaner" class="related-slide-card" data-key="polarizer-cleaner">
