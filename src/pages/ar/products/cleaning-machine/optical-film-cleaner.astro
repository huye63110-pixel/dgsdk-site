---
import ArProductLayout from '../../../../layouts/ArProductLayout.astro';
---

<ArProductLayout title="آلة تنظيف الأفلام البصرية الكبيرة | DGSDK"
  description="معدات تنظيف صناعية للأفلام البصرية ذات المساحة الكبيرة، تُزيل الغبار والألياف والجسيمات الملوثة بفعالية قبل عمليتي اللصق والتفتيش."
  image="/assets/img/cleaning-machine/optical.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/ar/">الرئيسية</a>
        <span>/</span>
        <a href="/ar/products">المنتجات</a>
        <span>/</span>
        <a href="/ar/products/cleaning-machine">آلات التنظيف</a>
        <span>/</span>
        <span>آلة تنظيف الأفلام البصرية الكبيرة</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/cleaning-machine/optical.jpg"
              alt="آلة تنظيف الأفلام البصرية الكبيرة"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/cleaning-machine/optical.jpg"
              alt="صورة مصغرة لآلة تنظيف الأفلام البصرية"
              data-full="/assets/img/cleaning-machine/optical.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>آلة تنظيف الأفلام البصرية الكبيرة</h1>
          <p class="product-short-desc">
            معدات تنظيف صناعية للأفلام البصرية ذات المساحة الكبيرة، تُزيل الغبار والألياف والجسيمات الملوثة بفعالية قبل عمليتي اللصق والتفتيش.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">طلب عرض سعر</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>تنظيف المساحات الكبيرة</h4>
              <p>تنظيف سطحي فعّال وعالي الكفاءة للأفلام البصرية ذات الأبعاد الكبيرة.</p>
            </div>
            <div class="highlight-item">
              <h4>تنظيف عالي الدقة</h4>
              <p>حل تنظيف محسّن خصيصاً للأسطح الحساسة للأفلام البصرية.</p>
            </div>
            <div class="highlight-item">
              <h4>نقل مستقر</h4>
              <p>نظام نقل مواد مستقر يمنع تلف سطح الفيلم.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>وصف المنتج</h2>
        <p>
          تتطلب الأفلام البصرية الكبيرة الحجم درجة عالية من نظافة السطح قبل عملية اللصق، إذ يمكن لأي جسيمات أو ألياف ملوثة أن تُسبب عيوباً بصرية. تم تطوير آلة تنظيف الأفلام البصرية الكبيرة خصيصاً لمعالجة هذه المشكلة.
        </p>
        <p>
          تدعم المعدات عملية التنظيف الدقيقة للأفلام البصرية ذات المساحة الكبيرة، وتُزيل الغبار والألياف والجسيمات والشحنات الكهروستاتيكية بفعالية، مما يضمن جودة المنتج خلال مرحلة اللصق.
        </p>
      </section>

      <section class="detail-block">
        <h2>مميزات المنتج</h2>
        <ul class="feature-list">
          <li>دعم تنظيف الأفلام البصرية الكبيرة الحجم</li>
          <li>تنظيف عالي الدقة يُزيل الملوثات الدقيقة بفعالية</li>
          <li>نقل مستقر يمنع تلف المواد</li>
          <li>وظيفة إزالة الكهرباء الساكنة المدمجة</li>
          <li>مناسب للمعالجة المسبقة قبل اللصق والتفتيش والتعبئة</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>المزايا التقنية</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>دعم المساحات الكبيرة</h3>
            <p>مصمم للأفلام البصرية الكبيرة الحجم، يدعم التنظيف الواسع عالي الكفاءة.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>تنظيف بجودة بصرية</h3>
            <p>محسّن للأسطح الحساسة للأفلام البصرية، بدقة تنظيف تلبي متطلبات التطبيقات البصرية.</p>
          </div>
          <div class="advantage-card green">
            <h3>نقل مستقر</h3>
            <p>نظام نقل مواد موثوق يضمن إتمام عملية التنظيف دون إلحاق ضرر بالفيلم.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>قطاعات التطبيق</h2>
        <div class="application-tags">
          <span>الأفلام البصرية</span>
          <span>تصنيع الشاشات</span>
          <span>إنتاج الشرائح المستقطبة</span>
          <span>تصنيع LCD</span>
          <span>عمليات اللصق</span>
          <span>التنظيف الدقيق</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="optical-film-cleaner">
          <div class="related-slider-header">
            <h2>منتجات ذات صلة</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/ar/products/cleaning-machine/polarizer-cleaner" class="related-slide-card" data-key="polarizer-cleaner">
              <img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="آلة تنظيف الشرائح المستقطبة الدقيقة" loading="lazy" />
              <h4>آلة تنظيف الشرائح المستقطبة الدقيقة</h4>
            </a>
            <a href="/ar/products/cleaning-machine/fpc-4-axis-cleaner" class="related-slide-card" data-key="fpc-4-axis-cleaner">
              <img src="/assets/img/cleaning-machine/fpc-4-axis-cleaner.jpg" alt="آلة تنظيف FPC رباعية المحاور" loading="lazy" />
              <h4>آلة تنظيف FPC رباعية المحاور</h4>
            </a>
            <a href="/ar/products/cleaning-machine/fpc-8-axis-cleaner" class="related-slide-card" data-key="fpc-8-axis-cleaner">
              <img src="/assets/img/cleaning-machine/fpc-8-axis-cleaner.jpg" alt="آلة تنظيف FPC ثمانية المحاور" loading="lazy" />
              <h4>آلة تنظيف FPC ثمانية المحاور</h4>
            </a>
            <a href="/ar/products/cleaning-machine/optical-film-cleaner" class="related-slide-card" data-key="optical-film-cleaner">
              <img src="/assets/img/cleaning-machine/optical.jpg" alt="آلة تنظيف الأفلام البصرية الكبيرة" loading="lazy" />
              <h4>آلة تنظيف الأفلام البصرية الكبيرة</h4>
            </a>
            <a href="/ar/products/cleaning-machine/lcm-cleaner" class="related-slide-card" data-key="lcm-cleaner">
              <img src="/assets/img/cleaning-machine/lcm-cleaner.jpg" alt="آلة تنظيف وحدات LCM الصناعية" loading="lazy" />
              <h4>آلة تنظيف وحدات LCM الصناعية</h4>
            </a>
            <a href="/ar/products/cleaning-machine/pcb-cleaner" class="related-slide-card" data-key="pcb-cleaner">
