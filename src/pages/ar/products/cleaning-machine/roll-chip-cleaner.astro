---
import ArProductLayout from '../../../../layouts/ArProductLayout.astro';
---

<ArProductLayout title="آلة التنظيف العامة بالأسطوانات | DGSDK"
  description="نظام تنظيف عام بالأسطوانات، مناسب لإزالة الجسيمات والألياف والملوثات السطحية من المواد اللفافية والمواد الورقية."
  image="/assets/img/cleaning-machine/roll-chip-cleaner.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/ar/">الرئيسية</a>
        <span>/</span>
        <a href="/ar/products">المنتجات</a>
        <span>/</span>
        <a href="/ar/products/cleaning-machine">آلات التنظيف</a>
        <span>/</span>
        <span>آلة التنظيف العامة بالأسطوانات</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/cleaning-machine/roll-chip-cleaner.jpg"
              alt="آلة التنظيف العامة بالأسطوانات"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/cleaning-machine/roll-chip-cleaner.jpg"
              alt="صورة مصغرة لآلة التنظيف بالأسطوانات"
              data-full="/assets/img/cleaning-machine/roll-chip-cleaner.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>آلة التنظيف العامة بالأسطوانات</h1>
          <p class="product-short-desc">
            نظام تنظيف عام بالأسطوانات، مناسب لإزالة الجسيمات والألياف والملوثات السطحية من المواد اللفافية والمواد الورقية.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">طلب عرض سعر</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>تنظيف متعدد الأغراض</h4>
              <p>مناسبة لتنظيف أسطح أنواع متعددة من المواد اللفافية والورقية.</p>
            </div>
            <div class="highlight-item">
              <h4>تنظيف بأسطوانتين</h4>
              <p>هيكل الأسطوانتين يضمن تنظيفاً متزامناً وفعّالاً للوجهين.</p>
            </div>
            <div class="highlight-item">
              <h4>نقل مستقر</h4>
              <p>نقل سلس للمواد يمنع تلف المواد اللفافية والورقية.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>وصف المنتج</h2>
        <p>
          تعتمد آلة التنظيف العامة بالأسطوانات مبدأ التنظيف بالأسطوانتين، وهي مصممة خصيصاً لتنظيف أسطح المواد اللفافية والورقية، وتُستخدم على نطاق واسع في معالجة الأفلام والملصقات وألواح PCB وغيرها من المواد الورقية والمشابهة.
        </p>
        <p>
          يجعلها التصميم العام قادرةً على التكيف مع أنواع متعددة من المواد، وتُزيل الجسيمات والألياف والملوثات السطحية بفعالية، مما يدعم متطلبات المعالجة المسبقة في مختلف عمليات الإنتاج الصناعي.
        </p>
      </section>

      <section class="detail-block">
        <h2>مميزات المنتج</h2>
        <ul class="feature-list">
          <li>هيكل الأسطوانتين للتنظيف المتزامن للوجهين</li>
          <li>مناسبة للمواد اللفافية وأنواع متعددة من المواد الورقية</li>
          <li>إزالة فعّالة للجسيمات والألياف والملوثات السطحية</li>
          <li>نقل مستقر يمنع تلف المواد</li>
          <li>دعم أنواع وأحجام مختلفة من المواد</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>المزايا التقنية</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>تنظيف بأسطوانتين</h3>
            <p>هيكل الأسطوانتين يُتيح تنظيفاً متزامناً وفعّالاً لوجهي المادة.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>تكيف شامل</h3>
            <p>تناسب على نطاق واسع المواد اللفافية والورقية وغيرها من أنواع المواد المتنوعة.</p>
          </div>
          <div class="advantage-card green">
            <h3>نقل مستقر</h3>
            <p>نظام نقل موثوق يضمن اجتياز جميع أنواع المواد لعملية التنظيف بسلاسة.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>قطاعات التطبيق</h2>
        <div class="application-tags">
          <span>التصنيع الإلكتروني</span>
          <span>إنتاج الأفلام</span>
          <span>تصنيع PCB</span>
          <span>التعبئة الصناعية</span>
          <span>معالجة المواد اللفافية</span>
          <span>التنظيف الدقيق</span>
        </div>
      </section>

