---
import ArProductLayout from '../../../../layouts/ArProductLayout.astro';
---

<ArProductLayout title="آلة تنظيف وحدات LCM الصناعية | DGSDK"
  description="معدات تنظيف صناعية مخصصة لإنتاج وحدات LCM، تُزيل الغبار والجسيمات والشحنات الكهروستاتيكية بفعالية قبل التجميع والتفتيش والتعبئة."
  image="/assets/img/cleaning-machine/lcm-cleaner.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/ar/">الرئيسية</a>
        <span>/</span>
        <a href="/ar/products">المنتجات</a>
        <span>/</span>
        <a href="/ar/products/cleaning-machine">آلات التنظيف</a>
        <span>/</span>
        <span>آلة تنظيف وحدات LCM الصناعية</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/cleaning-machine/lcm-cleaner.jpg"
              alt="آلة تنظيف وحدات LCM الصناعية"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/cleaning-machine/lcm-cleaner.jpg"
              alt="صورة مصغرة لآلة تنظيف LCM"
              data-full="/assets/img/cleaning-machine/lcm-cleaner.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>آلة تنظيف وحدات LCM الصناعية</h1>
          <p class="product-short-desc">
            معدات تنظيف صناعية مخصصة لإنتاج وحدات LCM، تُزيل الغبار والجسيمات والشحنات الكهروستاتيكية بفعالية قبل التجميع والتفتيش والتعبئة.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">طلب عرض سعر</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>مخصصة لـ LCM</h4>
              <p>مصممة ومحسّنة خصيصاً للمعالجة المسبقة في مراحل إنتاج وحدات LCM.</p>
            </div>
            <div class="highlight-item">
              <h4>تنظيف شامل</h4>
              <p>إزالة فعّالة للغبار والجسيمات والألياف والشحنات الكهروستاتيكية.</p>
            </div>
            <div class="highlight-item">
              <h4>توافق مع الإنتاج</h4>
              <p>مناسبة لمراحل متعددة بما فيها تجميع وحدات LCM والتفتيش والتعبئة.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>وصف المنتج</h2>
        <p>
          تحتاج وحدات LCM إلى الحفاظ على نظافة سطحية صارمة قبل مراحل التجميع والتفتيش والتعبئة، تجنباً لعيوب المنتج الناتجة عن الغبار وتلوث الجسيمات. صُممت آلة تنظيف وحدات LCM الصناعية خصيصاً لتحقيق هذا الغرض.
        </p>
        <p>
          المعدات محسّنة لمعالجة وحدات LCM وتُزيل مختلف أنواع الملوثات السطحية بفعالية، مما يدعم التشغيل المستقر والكفؤ لخطوط تجميع الشاشات.
        </p>
      </section>

      <section class="detail-block">
        <h2>مميزات المنتج</h2>
        <ul class="feature-list">
          <li>مصممة خصيصاً لتنظيف وحدات LCM</li>
          <li>إزالة فعّالة للجسيمات والألياف والغبار والكهرباء الساكنة</li>
          <li>مناسبة للمعالجة المسبقة قبل التجميع والتفتيش والتعبئة</li>
          <li>نقل مستقر يمنع تلف الوحدات</li>
          <li>دعم التهيئة المخصصة للأحجام المختلفة</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>المزايا التقنية</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>مخصصة لـ LCM</h3>
            <p>مصممة لبيئة إنتاج وحدات LCM، وتلبي متطلبات التنظيف الخاصة بمعالجة الوحدات.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>تنظيف شامل</h3>
            <p>إزالة فعّالة لجميع أنواع الملوثات السطحية، مع ضمان جودة تنظيف مستقرة ومتسقة للوحدات.</p>
          </div>
          <div class="advantage-card green">
            <h3>تهيئة مرنة</h3>
            <p>يمكن تخصيص التهيئة وفقاً لأحجام الوحدات وتخطيط خط الإنتاج.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>قطاعات التطبيق</h2>
        <div class="application-tags">
          <span>تجميع LCM</span>
          <span>تصنيع الشاشات</span>
          <span>إنتاج الوحدات</span>
          <span>التنظيف الدقيق</span>
          <span>التصنيع الإلكتروني</span>
          <span>تصنيع LCD</span>
        </div>
      </section>

