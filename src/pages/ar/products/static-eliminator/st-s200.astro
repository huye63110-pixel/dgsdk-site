---
import ArProductLayout from '../../../../layouts/ArProductLayout.astro';
---

<ArProductLayout title="ST-S200 مروحة أيونية مصغرة | DGSDK"
  description="مروحة أيونية مدمجة لإزالة الكهرباء الساكنة محليًا في أماكن العمل وذراع الروبوت ومحطات التجميع الدقيقة."
  image="/assets/img/static-eliminator/st-s200.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/ar/">الرئيسية</a>
        <span>/</span>
        <a href="/ar/products">المنتجات</a>
        <span>/</span>
        <a href="/ar/products/static-eliminator">إزالة الكهرباء الساكنة</a>
        <span>/</span>
        <span>ST-S200 مروحة أيونية مصغرة</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/static-eliminator/st-s200.jpg"
              alt="ST-S200 مروحة أيونية مصغرة"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/static-eliminator/st-s200.jpg"
              alt="ST-S200 Thumbnail 1"
              data-full="/assets/img/static-eliminator/st-s200.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>ST-S200 مروحة أيونية مصغرة</h1>
          <p class="product-short-desc">
            مروحة أيونية مدمجة لإزالة الكهرباء الساكنة محليًا في أماكن العمل وذراع الروبوت ومحطات التجميع الدقيقة.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">طلب عرض سعر</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>صغير وخفيف</h4>
              <p>شكل مدمج مناسب للاستخدام على سطح المكتب وفي الأماكن الضيقة.</p>
            </div>
            <div class="highlight-item">
              <h4>إزالة محلية للكهرباء الساكنة</h4>
              <p>إخراج هواء أيوني دقيق يزيل الكهرباء الساكنة المحلية في محطة العمل بفاعلية.</p>
            </div>
            <div class="highlight-item">
              <h4>تركيب مرن</h4>
              <p>طرق تركيب متعددة تسهل التكامل مع أنواع مختلفة من المعدات والتجهيزات.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>وصف المنتج</h2>
        <p>
          صُممت المروحة الأيونية المصغرة ST-S200 لإزالة الكهرباء الساكنة محليًا، وهي مناسبة لأماكن العمل ونهاية ذراع الروبوت ومحطات التجميع الدقيقة.
        </p>
        <p>
          يتيح شكلها الصغير تركيبها بسهولة في الأماكن الضيقة، وهي مناسبة لتجميع الإلكترونيات وSMT والتطبيقات الصناعية الدقيقة.
        </p>
      </section>

      <section class="detail-block">
        <h2>مميزات المنتج</h2>
        <ul class="feature-list">
          <li>تصميم مصغر مناسب لإزالة الكهرباء الساكنة المحلية في الأماكن الضيقة</li>
          <li>طرق تركيب مرنة تتناسب مع أنواع مختلفة من المعدات</li>
          <li>إخراج أيوني مستقر لنتائج إزالة موثوقة</li>
          <li>مناسب لتجميع الإلكترونيات والصناعة الدقيقة</li>
          <li>خفيف وسهل النقل للاستخدام المرن</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>المزايا التقنية</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>صغير ومدمج</h3>
            <p>شكل مصغر يتيح الاستخدام المرن على أماكن العمل وفي الأماكن الضيقة.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>تركيب مرن</h3>
            <p>طرق تركيب متعددة تتناسب مع أنواع مختلفة من المعدات ونهايات ذراع الروبوت.</p>
          </div>
          <div class="advantage-card green">
            <h3>إزالة مستقرة</h3>
            <p>إخراج أيوني موثوق يلبي متطلبات التحكم الدقيق في الكهرباء الساكنة محليًا.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>قطاعات التطبيق</h2>
        <div class="application-tags">
          <span>تجميع الإلكترونيات</span>
          <span>التجميع الدقيق</span>
          <span>إنتاج SMT</span>
          <span>مكان العمل</span>
          <span>ذراع الروبوت</span>
          <span>الغرف النظيفة</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="st-s200">
          <div class="related-slider-header">
            <h2>منتجات ذات صلة</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/ar/products/static-eliminator/st-g-series" class="related-slide-card" data-key="st-g-series">
              <img src="/assets/img/static-eliminator/st-g.jpg" alt="سلسلة ST-G من الأعواد الأيونية الذكية" loading="lazy" />
              <h4>سلسلة ST-G من الأعواد الأيونية الذكية</h4>
            </a>
            <a href="/ar/products/static-eliminator/st-e-series" class="related-slide-card" data-key="st-e-series">
              <img src="/assets/img/static-eliminator/st-e.jpg" alt="سلسلة ST-E من الأعواد الأيونية الذكية" loading="lazy" />
              <h4>سلسلة ST-E من الأعواد الأيونية الذكية</h4>
            </a>
            <a href="/ar/products/static-eliminator/st-f-series" class="related-slide-card" data-key="st-f-series">
              <img src="/assets/img/static-eliminator/st-f.jpg" alt="سلسلة ST-F من الأعواد الأيونية الذكية" loading="lazy" />
              <h4>سلسلة ST-F من الأعواد الأيونية الذكية</h4>
            </a>
            <a href="/ar/products/static-eliminator/st-s200" class="related-slide-card" data-key="st-s200">
              <img src="/assets/img/static-eliminator/st-s200.jpg" alt="ST-S200 مروحة أيونية مصغرة" loading="lazy" />
              <h4>ST-S200 مروحة أيونية مصغرة</h4>
            </a>
            <a href="/ar/products/static-eliminator/st-101a" class="related-slide-card" data-key="st-101a">
              <img src="/assets/img/static-eliminator/st-101a.webp" alt="ST101A مروحة أيونية مكتبية" loading="lazy" />
              <h4>ST101A مروحة أيونية مكتبية</h4>
            </a>
            <a href="/ar/products/static-eliminator/st-104a" class="related-slide-card" data-key="st-104a">
              <img src="/assets/img/static-eliminator/st-104a.jpg" alt="ST104A مروحة أيونية أفقية" loading="lazy" />
              <h4>ST104A مروحة أيونية أفقية</h4>
            </a>
            <a href="/ar/products/static-eliminator/st-1200" class="related-slide-card" data-key="st-1200">
              <img src="/assets/img/static-eliminator/st-1200.jpg" alt="ST1200 مروحة أيونية أفقية" loading="lazy" />
              <h4>ST1200 مروحة أيونية أفقية</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ArProductLayout>
