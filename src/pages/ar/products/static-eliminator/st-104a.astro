---
import ArProductLayout from '../../../../layouts/ArProductLayout.astro';
---

<ArProductLayout title="ST104A مروحة أيونية أفقية | DGSDK ستيك"
  description="مروحة أيونية أفقية مكتبية بإخراج أيوني محسّن، مناسبة لغرف الأبحاث والتصنيع الإلكتروني وخطوط إنتاج SMT."
  image="/assets/img/static-eliminator/st-104a.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/ar/">الرئيسية</a>
        <span>/</span>
        <a href="/ar/products">المنتجات</a>
        <span>/</span>
        <a href="/ar/products/static-eliminator">إزالة الكهرباء الساكنة</a>
        <span>/</span>
        <span>ST104A مروحة أيونية أفقية</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/static-eliminator/st-104a.jpg"
              alt="ST104A مروحة أيونية أفقية"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/static-eliminator/st-104a.jpg"
              alt="ST104A Thumbnail 1"
              data-full="/assets/img/static-eliminator/st-104a.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>ST104A مروحة أيونية أفقية</h1>
          <p class="product-short-desc">
            مروحة أيونية أفقية مكتبية بإخراج أيوني محسّن، مناسبة لغرف الأبحاث والتصنيع الإلكتروني وخطوط إنتاج SMT.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">طلب عرض سعر</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>تصميم أفقي</h4>
              <p>نفخ هواء عرضي واسع يغطي مساحة عمل أكبر.</p>
            </div>
            <div class="highlight-item">
              <h4>إخراج أيوني محسّن</h4>
              <p>قدرة توليد أيوني قوية لإزالة الكهرباء الساكنة بفعالية في نطاق أوسع.</p>
            </div>
            <div class="highlight-item">
              <h4>تشغيل مستقر</h4>
              <p>تصميم صناعي موثوق، مناسب للبيئات الإنتاجية المستمرة.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>وصف المنتج</h2>
        <p>
          تم تصميم مروحة ST104A الأيونية الأفقية لتطبيقات إزالة الكهرباء الساكنة على المكتب التي تتطلب تغطية أوسع، حيث تجعلها قدرة الإخراج الأيوني المحسّنة مناسبة لبيئات التصنيع الإلكتروني وإنتاج SMT وغرف الأبحاث.
        </p>
        <p>
          يوفر الهيكل الأفقي تغطية أوسع لتدفق الهواء الأيوني، مما يجعله مناسباً للتحكم في الكهرباء الساكنة على أسطح العمل الكبيرة ومحطات التجميع الدقيق.
        </p>
      </section>

      <section class="detail-block">
        <h2>مميزات المنتج</h2>
        <ul class="feature-list">
          <li>طراز أفقي بتغطية أوسع</li>
          <li>إخراج أيوني محسّن بقدرة أعلى على إزالة الشحنات</li>
          <li>مناسب لغرف الأبحاث وبيئات التصنيع الدقيق</li>
          <li>مستقر وموثوق للإنتاج الصناعي المستمر</li>
          <li>سهل التركيب والصيانة</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>المزايا التقنية</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>تغطية واسعة</h3>
            <p>تصميم نفخ أفقي يوفر مساحة تغطية فعالة أكبر مقارنة بالطراز المكتبي.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>إزالة شحنات محسّنة</h3>
            <p>قدرة إخراج أيوني معززة لتلبية متطلبات إزالة الكهرباء الساكنة في مناطق العمل الأكبر.</p>
          </div>
          <div class="advantage-card green">
            <h3>موثوق ومستقر</h3>
            <p>تصميم صناعي يدعم التشغيل المستقر طويل الأمد في بيئات التصنيع الإلكتروني وSMT.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>قطاعات التطبيق</h2>
        <div class="application-tags">
          <span>التصنيع الإلكتروني</span>
          <span>إنتاج SMT</span>
          <span>غرف الأبحاث</span>
          <span>التجميع الدقيق</span>
          <span>منضدة العمل</span>
          <span>التغليف</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="st-104a">
          <div class="related-slider-header">
            <h2>منتجات ذات صلة</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/ar/products/static-eliminator/st-g-series" class="related-slide-card" data-key="st-g-series">
              <img src="/assets/img/static-eliminator/st-g.jpg" alt="سلسلة ST-G للقضيب الأيوني الذكي" loading="lazy" />
              <h4>سلسلة ST-G للقضيب الأيوني الذكي</h4>
            </a>
            <a href="/ar/products/static-eliminator/st-e-series" class="related-slide-card" data-key="st-e-series">
              <img src="/assets/img/static-eliminator/st-e.jpg" alt="سلسلة ST-E للقضيب الأيوني الذكي" loading="lazy" />
              <h4>سلسلة ST-E للقضيب الأيوني الذكي</h4>
            </a>
            <a href="/ar/products/static-eliminator/st-f-series" class="related-slide-card" data-key="st-f-series">
              <img src="/assets/img/static-eliminator/st-f.jpg" alt="سلسلة ST-F للقضيب الأيوني الذكي" loading="lazy" />
              <h4>سلسلة ST-F للقضيب الأيوني الذكي</h4>
            </a>
            <a href="/ar/products/static-eliminator/st-s200" class="related-slide-card" data-key="st-s200">
              <img src="/assets/img/static-eliminator/st-s200.jpg" alt="ST-S200 مروحة أيونية مصغرة" loading="lazy" />
              <h4>ST-S200 مروحة أيونية مصغرة</h4>
            </a>
            <a href="/ar/products/static-eliminator/st-101a" class="related-slide-card" data-key="st-101a">
              <img src="/assets/img/static-eliminator/st-101a.webp" alt="ST101A مروحة أيونية مكتبية" loading="lazy" />
              <h4>ST101A مروحة أيونية مكتبية</h4>
            </a>
            <a href="/ar/products/static-eliminator/st-104a" class="related-slide-card" data-key="st-104a">
              <img src="/assets/img/static-eliminator/st-104a.jpg" alt="ST104A مروحة أيونية أفقية" loading="lazy" />
              <h4>ST104A مروحة أيونية أفقية</h4>
            </a>
            <a href="/ar/products/static-eliminator/st-1200" class="related-slide-card" data-key="st-1200">
              <img src="/assets/img/static-eliminator/st-1200.jpg" alt="ST1200 مروحة أيونية أفقية" loading="lazy" />
              <h4>ST1200 مروحة أيونية أفقية</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ArProductLayout>
