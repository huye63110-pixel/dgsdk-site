---
import ArProductLayout from '../../../../layouts/ArProductLayout.astro';
---

<ArProductLayout title="خط إنتاج تنظيف وفحص ألواح الانتشار | DGSDK"
  description="خط إنتاج آلي متكامل يجمع التنظيف والفحص والنقل المستمر في منظومة واحدة، سير عمل مستقر وعالي الكفاءة لمعالجة ألواح الانتشار."
  image="/assets/img/automation/product-a.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/ar/">الرئيسية</a>
        <span>/</span>
        <a href="/ar/products">المنتجات</a>
        <span>/</span>
        <a href="/ar/products/automation">معدات الأتمتة</a>
        <span>/</span>
        <span>خط إنتاج تنظيف وفحص ألواح الانتشار</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/automation/product-a.jpg"
              alt="خط إنتاج تنظيف وفحص ألواح الانتشار"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/automation/product-a.jpg"
              alt="صورة مصغرة لخط إنتاج ألواح الانتشار"
              data-full="/assets/img/automation/product-a.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>خط إنتاج تنظيف وفحص ألواح الانتشار</h1>
          <p class="product-short-desc">
            خط إنتاج آلي متكامل يجمع التنظيف والفحص والنقل المستمر في منظومة واحدة، سير عمل مستقر وعالي الكفاءة لمعالجة ألواح الانتشار.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">احصل على عرض سعر</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>تكامل العمليات</h4>
              <p>التنظيف والفحص والنقل مدمجة في خط إنتاج متواصل واحد.</p>
            </div>
            <div class="highlight-item">
              <h4>سير عمل مستقر</h4>
              <p>تحسين تنسيق العمليات والحفاظ على ثبات إيقاع الإنتاج.</p>
            </div>
            <div class="highlight-item">
              <h4>دعم الأتمتة</h4>
              <p>مناسب للخطوط الصناعية التي تتطلب معالجة فعّالة وتكامل الفحص.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>وصف المنتج</h2>
        <p>
          تم تطوير خط إنتاج تنظيف وفحص ألواح الانتشار خصيصًا للتطبيقات الصناعية التي تتطلب نقلًا مستمرًا للمواد وتنظيف الأسطح وتنسيق الفحص وإيقاع إنتاج ثابت.
        </p>
        <p>
          مناسب لمعالجة ألواح الانتشار وغيرها من منتجات الألواح التي تتطلب أتمتة متكاملة وجودة تنظيف عالية وكفاءة فحص محسّنة.
        </p>
      </section>

      <section class="detail-block">
        <h2>مميزات المنتج</h2>
        <ul class="feature-list">
          <li>تصميم خط إنتاج متكامل يجمع التنظيف والفحص</li>
          <li>هيكل نقل متواصل بسير عمل مستقر</li>
          <li>مناسب لمعالجة ألواح الانتشار ومنتجات الألواح</li>
          <li>تحسين كفاءة الإنتاج وتنسيق الفحص</li>
          <li>يدعم تخصيص إعداد الأتمتة وفق متطلبات المشروع</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>المزايا التقنية</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>تكامل الخط</h3>
            <p>تقليل انفصال العمليات وتحسين الكفاءة الإنتاجية الإجمالية.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>دعم الفحص</h3>
            <p>الحفاظ على ثبات فحص الأسطح واتساق سير العمل.</p>
          </div>
          <div class="advantage-card green">
            <h3>تصميم مرن</h3>
            <p>قابل للتخصيص وفق أبعاد المنتج والطاقة الإنتاجية ومتطلبات العملية.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>قطاعات التطبيق</h2>
        <div class="application-tags">
          <span>معالجة ألواح الانتشار</span>
          <span>خطوط التنظيف</span>
          <span>أنظمة الفحص</span>
          <span>الإنتاج الآلي</span>
          <span>معالجة الألواح</span>
          <span>خطوط إنتاج صناعية مخصصة</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="product-a">
          <div class="related-slider-header">
            <h2>منتجات ذات صلة</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/ar/products/automation/product-a" class="related-slide-card" data-key="product-a">
              <img src="/assets/img/automation/product-a.jpg" alt="خط إنتاج تنظيف وفحص ألواح الانتشار" loading="lazy" />
              <h4>خط إنتاج تنظيف وفحص ألواح الانتشار</h4>
            </a>
            <a href="/ar/products/automation/product-b" class="related-slide-card" data-key="product-b">
              <img src="/assets/img/automation/product-b.jpg" alt="آلة تنظيف بتغذية وإخراج روبوتية تلقائية" loading="lazy" />
              <h4>آلة تنظيف بتغذية وإخراج روبوتية تلقائية</h4>
            </a>
            <a href="/ar/products/automation/product-c" class="related-slide-card" data-key="product-c">
              <img src="/assets/img/automation/product-c.jpg" alt="جهاز قياس زاوية محور امتصاص الفيلم الاستقطابي" loading="lazy" />
              <h4>جهاز قياس زاوية محور امتصاص الفيلم الاستقطابي</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ArProductLayout>
