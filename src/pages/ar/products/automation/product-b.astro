---
import ArProductLayout from '../../../../layouts/ArProductLayout.astro';
---

<ArProductLayout title="آلة تنظيف بتغذية وإخراج روبوتية تلقائية | DGSDK"
  description="معدات تنظيف بتغذية وإخراج تلقائيين بالذراع الروبوتية، ترفع كفاءة الإنتاج وتقلل التناول اليدوي مع الحفاظ على جودة تنظيف ثابتة."
  image="/assets/img/automation/product-b.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/ar/">الرئيسية</a>
        <span>/</span>
        <a href="/ar/products">المنتجات</a>
        <span>/</span>
        <a href="/ar/products/automation">معدات الأتمتة</a>
        <span>/</span>
        <span>آلة تنظيف بتغذية وإخراج روبوتية تلقائية</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/automation/product-b.jpg"
              alt="آلة تنظيف بتغذية وإخراج روبوتية تلقائية"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/automation/product-b.jpg"
              alt="صورة مصغرة لآلة التنظيف الروبوتية"
              data-full="/assets/img/automation/product-b.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>آلة تنظيف بتغذية وإخراج روبوتية تلقائية</h1>
          <p class="product-short-desc">
            معدات تنظيف بتغذية وإخراج تلقائيين بالذراع الروبوتية، ترفع كفاءة الإنتاج وتقلل التناول اليدوي مع الحفاظ على جودة تنظيف ثابتة.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">احصل على عرض سعر</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>تكامل روبوتي</h4>
              <p>تغذية وإخراج تلقائيان بالذراع الروبوتية لتقليل التدخل اليدوي.</p>
            </div>
            <div class="highlight-item">
              <h4>كفاءة إنتاجية عالية</h4>
              <p>التغذية والإخراج الآليان يرفعان إيقاع الإنتاج والكفاءة الإجمالية.</p>
            </div>
            <div class="highlight-item">
              <h4>جودة تنظيف ثابتة</h4>
              <p>العملية الآلية تضمن نتائج تنظيف ثابتة ومتسقة في كل دفعة.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>وصف المنتج</h2>
        <p>
          تدمج آلة التنظيف بالتغذية والإخراج الروبوتيين التلقائيين بين التغذية والإخراج التلقاويين بالذراع الروبوتية ووظيفة التنظيف الصناعي في منظومة واحدة، مما يقلل فعليًا من التناول اليدوي ويرفع كفاءة الإنتاج واتساق جودة التنظيف.
        </p>
        <p>
          مناسبة لتطبيقات التنظيف الصناعي التي تستلزم تغذية وإخراجًا آليين فعّالين، إذ يسهم التكامل الروبوتي في خفض تكاليف العمالة وتحسين إيقاع الإنتاج وثبات نظافة المنتج.
        </p>
      </section>

      <section class="detail-block">
        <h2>مميزات المنتج</h2>
        <ul class="feature-list">
          <li>تغذية وإخراج تلقائيان بالذراع الروبوتية لتقليل التشغيل اليدوي</li>
          <li>عملية آلية لرفع كفاءة الإنتاج</li>
          <li>جودة تنظيف ثابتة مع اتساق دفعي ممتاز</li>
          <li>مناسبة لتطبيقات التنظيف الصناعي الآلي</li>
          <li>تدعم التهيئة الآلية المخصصة</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>المزايا التقنية</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>تكامل روبوتي</h3>
            <p>التغذية والإخراج الآليان بالذراع الروبوتية يقللان الحاجة إلى التدخل اليدوي بشكل ملحوظ.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>تحسين الكفاءة</h3>
            <p>التغذية والإخراج الآليان يرفعان إيقاع الإنتاج ويخفضان تكاليف العمالة.</p>
          </div>
          <div class="advantage-card green">
            <h3>جودة ثابتة</h3>
            <p>العملية الآلية تضمن جودة تنظيف متسقة وموثوقة في كل دفعة.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>قطاعات التطبيق</h2>
        <div class="application-tags">
          <span>الأنظمة الروبوتية</span>
          <span>الإنتاج الآلي</span>
          <span>التنظيف الصناعي</span>
          <span>الأتمتة الدقيقة</span>
          <span>تصنيع الإلكترونيات</span>
          <span>خطوط إنتاج صناعية مخصصة</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="product-b">
          <div class="related-slider-header">
            <h2>منتجات ذات صلة</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/ar/products/automation/product-a" class="related-slide-card" data-key="product-a">
              <img src="/assets/img/automation/product-a.jpg" alt="خط إنتاج تنظيف وفحص ألواح الانتشار" loading="lazy" />
              <h4>خط إنتاج تنظيف وفحص ألواح الانتشار</h4>
            </a>
            <a href="/ar/products/automation/product-b" class="related-slide-card" data-key="product-b">
              <img src="/assets/img/automation/product-b.jpg" alt="آلة تنظيف بتغذية وإخراج روبوتية تلقائية" loading="lazy" />
              <h4>آلة تنظيف بتغذية وإخراج روبوتية تلقائية</h4>
            </a>
            <a href="/ar/products/automation/product-c" class="related-slide-card" data-key="product-c">
              <img src="/assets/img/automation/product-c.jpg" alt="جهاز قياس زاوية محور امتصاص الفيلم الاستقطابي" loading="lazy" />
              <h4>جهاز قياس زاوية محور امتصاص الفيلم الاستقطابي</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ArProductLayout>
