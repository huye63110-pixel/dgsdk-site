---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us | DGSDK">
  <section
    class="about-hero"
    style="background: linear-gradient(rgba(2, 1, 1, 0.28), rgba(36, 31, 31, 0.18)), url('/assets/img/about/about us.jpg') center/cover no-repeat;"
    <div class="about-hero-overlay"></div>
    <div class="container about-hero-content">
      <span class="about-hero-kicker">About DGSDK</span>
      <h1>Industrial automation and precision manufacturing solutions built for long-term reliability.</h1>
      <p>
        Dongguan Shidike Automation Equipment Co., Ltd. specializes in static elimination systems,
        cleaning machines, automation equipment, and precision machined parts for industrial customers worldwide.
      </p>
    </div>
  </section>

  <section class="about-intro-section">
    <div class="container">
      <div class="about-intro-grid">
        <div class="about-intro-copy">
          <span class="about-section-label">Who We Are</span>
          <h2>A professional manufacturer focused on quality, engineering, and practical industrial solutions.</h2>
          <p>
            DGSDK is based in Dongguan, China, and is committed to providing reliable products and customized
            solutions for customers in electronics, SMT, display manufacturing, packaging, and precision production.
          </p>
          <p>
            Our main business covers static elimination systems, industrial cleaning equipment, automation systems,
            and precision CNC machined parts. We focus on stable performance, production efficiency, and long-term
            cooperation with global customers.
          </p>

          <div class="about-intro-points">
            <div class="about-point">
              <strong>Core Products</strong>
              <span>Static eliminators, cleaning machines, automation equipment, CNC parts</span>
            </div>
            <div class="about-point">
              <strong>Manufacturing Focus</strong>
              <span>Quality control, practical engineering, stable industrial performance</span>
            </div>
            <div class="about-point">
              <strong>Service Goal</strong>
              <span>Reliable support for long-term industrial cooperation</span>
            </div>
          </div>
        </div>

       <div class="about-image-stack">
  <img src="/assets/img/about/about-lobby.jpg" alt="DGSDK company lobby" class="about-main-image" />
  <img src="/assets/img/about/about-lathe.jpg" alt="DGSDK CNC lathe equipment" class="about-float-image" />
</div>
        </div>
      </div>
    </div>
  </section>

  <section class="about-values-section">
    <div class="container">
      <div class="about-section-heading text-center">
        <span class="about-section-label">Why Choose Us</span>
        <h2>Built around industrial reliability.</h2>
        <p>
          We focus on what matters most in manufacturing environments: consistency, efficiency,
          quality control, responsive support, and practical cooperation.
        </p>
      </div>

      <div class="about-values-grid">
        <div class="about-value-card">
          <img src="/assets/img/about/about-support.png" alt="Technical support" class="about-value-icon" />
          <h3>Professional Support</h3>
          <p>
            We provide responsive communication and practical technical support for product selection and project discussion.
          </p>
        </div>

        <div class="about-value-card">
          <img src="/assets/img/about/icon-delivery.png" alt="Delivery support" class="about-value-icon" />
          <h3>Reliable Delivery</h3>
          <p>
            Stable production management helps us support on-time delivery and efficient manufacturing coordination.
          </p>
        </div>

        <div class="about-value-card">
          <img src="/assets/img/about/icon-guarantee.png" alt="Quality assurance" class="about-value-icon" />
          <h3>Quality Assurance</h3>
          <p>
            We focus on product consistency, inspection standards, and dependable industrial performance.
          </p>
        </div>

        <div class="about-value-card">
          <img src="/assets/img/about/icon-support.png" alt="Cooperation service" class="about-value-icon" />
          <h3>Long-Term Cooperation</h3>
          <p>
            Our goal is to build stable and lasting partnerships with global industrial customers.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="about-products-section">
    <div class="container">
      <div class="about-section-heading text-center">
        <span class="about-section-label">Our Business</span>
        <h2>Four core product directions.</h2>
        <p>
          A complete industrial product structure covering static control, cleaning, automation, and precision machining.
        </p>
      </div>

      <div class="about-business-grid">
        <a href="/products/static-eliminator" class="about-business-card">
          <img src="/assets/img/static-white-bg.png" alt="Static Elimination Systems" />
          <h3>Static Elimination Systems</h3>
          <p>Ion bars, ion fans, and electrostatic control solutions for sensitive industrial environments.</p>
        </a>

        <a href="/products/cleaning-machine" class="about-business-card">
          <img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="Cleaning Machine" />
          <h3>Cleaning Machine</h3>
          <p>Precision cleaning equipment for PCB, FPC, SMT, polarizer, LCM, backlight, and optical film applications.</p>
        </a>

        <a href="/products/automation" class="about-business-card">
          <img src="/assets/img/automation/product-c.jpg" alt="Automation Equipment" />
          <h3>Automation Equipment</h3>
          <p>Custom industrial automation systems designed to improve workflow and production efficiency.</p>
        </a>

        <a href="/products/precision-machined parts" class="about-business-card">
          <img src="/assets/img/precision-machined-parts/Precision-Bearing-Bracket-CNC-Milled.jpg" alt="Precision Machined Parts" />
          <h3>Precision Machined Parts</h3>
          <p>High-precision CNC parts built with stable tolerance control and reliable manufacturing quality.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="about-gallery-section">
    <div class="container">
      <div class="about-section-heading text-center">
        <span class="about-section-label">Factory Gallery</span>
        <h2>Inside our production environment.</h2>
        <p>
          Real equipment, real manufacturing, and real industrial working conditions.
        </p>
      </div>

      <div class="about-gallery-grid">
        <div class="about-gallery-item item">
          <img src="/assets/img/about/about-machining-center.jpg" alt="Machining center equipment" />
        </div>
        <div class="about-gallery-item item">
          <img src="/assets/img/about/about-lobby.jpg" alt="DGSDK company lobby" />
        </div>
        <div class="about-gallery-item">
          <img src="/assets/img/about/about-lathe.jpg" alt="CNC lathe equipment" />
        </div>
        <div class="about-gallery-item">
          <img src="/assets/img/about/about-cnc-process.jpg" alt="CNC machining process" />
        </div>
        
      </div>
    </div>
  </section>
  <style>
    .about-values-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 22px;
    }

    .about-value-card {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
    }

    .about-value-icon {
      width: 84px;
      height: 84px;
      object-fit: contain;
      display: block;
      margin: 0 0 18px;
      opacity: 0.92;
    }

    .about-gallery-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 22px;
    }

    .about-gallery-item {
      overflow: hidden;
      border-radius: 18px;
      background: #f7f8fa;
      box-shadow: 0 14px 36px rgba(15, 23, 42, 0.08);
    }

    .about-gallery-item img {
      width: 100%;
      height: 320px;
      object-fit: cover;
      display: block;
      border-radius: 18px;
    }

    @media (max-width: 991px) {
      .about-values-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 768px) {
      .about-values-grid,
      .about-gallery-grid {
        grid-template-columns: 1fr;
      }

      .about-value-icon {
        width: 72px;
        height: 72px;
      }

      .about-gallery-item img {
        height: 240px;
      }
    }
  </style>

  <section class="about-timeline-section">
    <div class="container">
      <div class="about-section-heading text-center">
        <span class="about-section-label">Our Development</span>
        <h2>Growing with industrial customers.</h2>
        <p>
          A development path focused on engineering capability, manufacturing reliability, and long-term service value.
        </p>
      </div>

      <div class="about-timeline">
        <div class="about-timeline-line"></div>

        <div class="about-timeline-item left">
          <div class="about-timeline-dot">01</div>
          <div class="about-timeline-card">
            <h3>Company Foundation</h3>
            <p>
              Established in Dongguan with a focus on industrial equipment, automation, and practical manufacturing solutions.
            </p>
          </div>
        </div>

        <div class="about-timeline-item right">
          <div class="about-timeline-dot">02</div>
          <div class="about-timeline-card">
            <h3>Product Expansion</h3>
            <p>
              Expanded into static elimination systems and precision cleaning equipment for electronics and display industries.
            </p>
          </div>
        </div>

        <div class="about-timeline-item left">
          <div class="about-timeline-dot">03</div>
          <div class="about-timeline-card">
            <h3>Manufacturing Capability</h3>
            <p>
              Improved CNC machining and automation integration capability to support more customized industrial needs.
            </p>
          </div>
        </div>

        <div class="about-timeline-item right">
          <div class="about-timeline-dot">04</div>
          <div class="about-timeline-card">
            <h3>Global Cooperation</h3>
            <p>
              Serving customers with stable quality, engineering support, and long-term cooperation for overseas markets.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="about-cta-section">
    <div class="container">
      <div class="about-cta-box">
        <div class="about-cta-copy">
          <span class="about-section-label">Work With Us</span>
          <h2>Looking for a reliable industrial manufacturing partner?</h2>
          <p>
            Contact DGSDK to discuss your project, product requirements, or customized industrial solution.
          </p>
        </div>

        <div class="about-cta-actions">
          <a href="/contact" class="about-cta-btn primary">Contact Us</a>
          <a href="/products" class="about-cta-btn secondary">View Products</a>
        </div>
      </div>
    </div>
  </section>
</Layout>