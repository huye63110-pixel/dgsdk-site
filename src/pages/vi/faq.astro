---
import ViLayout from '../../layouts/ViLayout.astro';

const faqItems = [
  {
    question: 'Số lượng đặt hàng tối thiểu là bao nhiêu? Có chấp nhận đơn hàng thử số lượng nhỏ không?',
    answer: 'Số lượng đặt hàng tối thiểu tiêu chuẩn của chúng tôi thường là 500 chiếc mỗi sản phẩm, một số danh mục sản phẩm có thể bắt đầu từ 100 chiếc. Chúng tôi cũng hỗ trợ đơn hàng thử số lượng nhỏ cho một số sản phẩm, mẫu thử có thể phát sinh phí, thường được khấu trừ vào đơn hàng số lượng lớn tiếp theo. Đối với đơn hàng kết hợp đủ số lượng, có thể được miễn phí xử lý bổ sung.'
  },
  {
    question: 'Những phương thức thanh toán nào được chấp nhận?',
    answer: 'Chúng tôi thường chấp nhận thanh toán bằng chuyển khoản ngân hàng (T/T), thông thường là đặt cọc 30%, số còn lại thanh toán trước khi giao hàng. Đối với các đơn hàng lớn hơn, có thể thỏa thuận thanh toán bằng thư tín dụng (L/C). PayPal có thể được sử dụng cho các đơn hàng mẫu nhỏ. Để đảm bảo an toàn giao dịch, chúng tôi có thể cung cấp hóa đơn chiếu lệ, tài liệu đăng ký công ty và các chứng từ liên quan đến xuất khẩu.'
  },
  {
    question: 'Thời gian giao hàng thường là bao lâu? Có hỗ trợ đơn hàng gấp không?',
    answer: 'Thời gian sản xuất tiêu chuẩn thường là 25 đến 35 ngày làm việc sau khi xác nhận mẫu, tùy thuộc vào loại sản phẩm và số lượng đơn hàng. Đối với các dự án khẩn cấp, có thể thỏa thuận sản xuất gấp tùy theo lịch sắp xếp, có thể phát sinh thêm chi phí. Một số đơn hàng cũng có thể sắp xếp giao hàng nhiều đợt.'
  },
  {
    question: 'Chất lượng sản phẩm được đảm bảo như thế nào?',
    answer: 'Chúng tôi áp dụng quy trình kiểm soát chất lượng toàn diện, bao gồm kiểm tra nguyên liệu đầu vào, kiểm tra trong quá trình sản xuất và kiểm tra cuối cùng trước khi xuất hàng. Quy trình quản lý chất lượng của chúng tôi nhằm đảm bảo hiệu suất sản phẩm ổn định và nhất quán. Trong trường hợp có vấn đề chất lượng được xác nhận, chúng tôi sẽ thảo luận với khách hàng để tìm giải pháp phù hợp như bổ sung hàng, thay thế hoặc bồi thường.'
  },
  {
    question: 'Có cung cấp dịch vụ OEM/ODM không?',
    answer: 'Có, chúng tôi cung cấp dịch vụ OEM và ODM. Trong các dự án OEM, khách hàng có thể cung cấp bản vẽ, thông số kỹ thuật hoặc yêu cầu thương hiệu riêng; trong các dự án ODM, chúng tôi có thể hỗ trợ phát triển sản phẩm và thiết kế giải pháp dựa trên yêu cầu ứng dụng. Nếu cần, chúng tôi cũng hỗ trợ ký kết thỏa thuận bảo mật (NDA).'
  },
  {
    question: 'Sản phẩm có đáp ứng tiêu chuẩn quốc tế không?',
    answer: 'Sản phẩm của chúng tôi có thể cung cấp bằng chứng tuân thủ các tiêu chuẩn quốc tế tùy theo loại sản phẩm và thị trường mục tiêu. Các chứng nhận phổ biến bao gồm ISO, CE, FCC, RoHS, REACH và nhiều loại khác. Nếu có yêu cầu chứng nhận đặc biệt, có thể thỏa thuận quy trình xử lý theo nhu cầu dự án của bạn.'
  },
  {
    question: 'Có những phương thức vận chuyển nào?',
    answer: 'Chúng tôi hỗ trợ nhiều phương thức vận chuyển, bao gồm đường biển, đường hàng không, chuyển phát nhanh và vận tải đường sắt (tùy thuộc vào điểm đến và yêu cầu hàng hóa). Chúng tôi có thể đề xuất phương thức vận chuyển dựa trên chi phí và thời gian giao hàng, và cũng có thể phối hợp với đơn vị vận chuyển do khách hàng chỉ định.'
  },
  {
    question: 'Hỗ trợ xử lý thuế hải quan và thuế nhập khẩu như thế nào?',
    answer: 'Chúng tôi có thể cung cấp các chứng từ xuất khẩu cần thiết như hóa đơn thương mại, phiếu đóng gói và giấy chứng nhận xuất xứ (nếu có). Thuế nhập khẩu, VAT và phí thông quan phụ thuộc vào quốc gia đến và mã HS của sản phẩm. Nếu cần, chúng tôi cũng có thể thỏa thuận giao hàng theo điều kiện DDP hoặc DDU cho một số thị trường.'
  },
  {
    question: 'Có cung cấp mẫu sản phẩm không?',
    answer: 'Có, có thể cung cấp mẫu sản phẩm để đánh giá. Phí mẫu và sắp xếp chi phí vận chuyển tùy thuộc vào loại sản phẩm và có cần tùy chỉnh hay không. Trong hầu hết các trường hợp, phí mẫu có thể được khấu trừ vào đơn hàng số lượng lớn tiếp theo. Thời gian sản xuất mẫu tùy chỉnh phụ thuộc vào mức độ phức tạp của yêu cầu.'
  },
  {
    question: 'Biến động tỷ giá hối đoái được xử lý như thế nào?',
    answer: 'Báo giá thường có thời hạn hiệu lực giới hạn, và giá cuối cùng có thể phụ thuộc vào tỷ giá hối đoái tại thời điểm xác nhận đơn hàng. Đối với các dự án lớn, chúng tôi có thể thỏa thuận thanh toán theo từng giai đoạn hoặc các giải pháp thực tế khác để giảm thiểu rủi ro tỷ giá trong các trường hợp phù hợp.'
  }
];
---

<ViLayout
  title="FAQ | DGSDK"
  description="Câu hỏi thường gặp về sản phẩm DGSDK, bao gồm máy khử tĩnh điện, máy làm sạch, thiết bị tự động hóa và linh kiện CNC chính xác về đặt hàng, chất lượng và thời gian giao hàng."
  canonical="https://www.dg-sdk.com/vi/faq"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  })} />

  <section
    class="faq-hero"
    style="background: linear-gradient(rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.18)), url('/assets/img/faq/faq-bg.jpg') center/cover no-repeat;"
  >
    <div class="faq-hero-overlay"></div>
    <div class="container faq-hero-content">
      <span class="faq-hero-kicker">Câu hỏi thường gặp</span>
      <h1>Giải đáp các câu hỏi thường gặp về sản phẩm, ứng dụng và dịch vụ của chúng tôi.</h1>
      <p>
        Khám phá các câu hỏi thường gặp về giải pháp DGSDK, bao gồm ứng dụng công nghiệp, danh mục sản phẩm, sản xuất tùy chỉnh, hỗ trợ tự động hóa và phương thức hợp tác.
      </p>
    </div>
  </section>

  <section class="faq-intro-section">
    <div class="container">
      <div class="faq-intro-box">
        <span class="faq-section-label">Hỗ trợ & Thông tin</span>
        <h2>Giải đáp rõ ràng và thiết thực.</h2>
        <p>Trang này giúp khách hàng hiểu đầy đủ về sản phẩm, dịch vụ và năng lực ứng dụng công nghiệp của chúng tôi trước khi bắt đầu hợp tác.</p>
      </div>
    </div>
  </section>

  <section class="faq-main-section">
    <div class="container">
      <div class="faq-layout">
        <aside class="faq-side-panel">
          <div class="faq-side-card">
            <span class="faq-side-label">Hướng dẫn nhanh</span>
            <h3>Cần giúp đỡ tìm giải pháp phù hợp?</h3>
            <p>
              Xem các câu hỏi trên trang này, hoặc liên hệ trực tiếp với DGSDK để nhận tư vấn sản phẩm và hỗ trợ công nghiệp tùy chỉnh.
            </p>
            <div class="faq-side-actions">
              <a href="/vi/contact" class="faq-primary-btn">Liên hệ chúng tôi</a>
              <a href="/vi/products" class="faq-text-link">Xem sản phẩm</a>
            </div>
          </div>
        </aside>

        <div class="faq-content">
          <div class="faq-heading-block">
            <span class="faq-section-label">Câu hỏi thường gặp</span>
            <h2>Câu hỏi từ khách hàng và đối tác.</h2>
            <p>Giúp việc lựa chọn sản phẩm và trao đổi kinh doanh diễn ra thuận lợi hơn.</p>
          </div>

          <div class="faq-list">
            {faqItems.map((item, index) => (
              <details class="faq-item" open={index === 0}>
                <summary class="faq-question">
                  <span>{item.question}</span>
                  <span class="faq-icon"></span>
                </summary>
                <div class="faq-answer">
                  <p>{item.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-bottom-section">
    <div class="container">
      <div class="faq-bottom-panel">
        <div class="faq-bottom-copy">
          <span class="faq-section-label dark">Vẫn còn câu hỏi?</span>
          <h2>Hãy thảo luận về ứng dụng hoặc nhu cầu sản phẩm của bạn.</h2>
          <p>
            Nếu câu hỏi của bạn chưa được liệt kê tại đây, đội ngũ của chúng tôi có thể giúp bạn lựa chọn sản phẩm, phân tích ứng dụng và đề xuất giải pháp công nghiệp tùy chỉnh.
          </p>
        </div>

        <div class="faq-bottom-actions">
          <a href="/vi/contact" class="faq-primary-btn">Liên hệ chúng tôi</a>
          <a href="/vi/applications" class="faq-secondary-btn">Xem lĩnh vực ứng dụng</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .faq-hero {
      position: relative;
      min-height: 680px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 125px 0 60px;
      background:
        linear-gradient(rgba(15, 23, 42, 0.18), rgba(15, 23, 42, 0.10)),
        url('/assets/img/header-bg.jpg') center/cover no-repeat;
      overflow: hidden;
      text-align: center;
    }
    .faq-hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(rgba(255,255,255,0.06), rgba(255,255,255,0.03));
    }
    .faq-hero-content {
      position: relative;
      z-index: 2;
      max-width: 960px;
    }
    .faq-hero-kicker,
    .faq-section-label,
    .faq-side-label {
      display: inline-block;
      margin-bottom: 16px;
      padding: 6px 14px;
      border-radius: 999px;
      background: #fff4cc;
      color: #8a6a00;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .faq-section-label.dark {
      background: rgba(255,255,255,0.12);
      color: #fff4cc;
    }
    .faq-hero h1 {
      margin-bottom: 18px;
      font-size: clamp(2.4rem, 5vw, 4.6rem);
      line-height: 1.06;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #111;
    }
    .faq-hero p {
      max-width: 820px;
      margin: 0 auto;
      font-size: 1.04rem;
      line-height: 1.85;
      color: rgba(17,17,17,0.72);
    }
    .faq-intro-section { padding: 70px 0 32px; background: #fff; }
    .faq-intro-box, .faq-heading-block { max-width: 860px; margin: 0 auto; text-align: center; }
    .faq-intro-box h2, .faq-heading-block h2, .faq-bottom-copy h2 {
      margin-bottom: 16px;
      font-size: clamp(2rem, 3.4vw, 3rem);
      line-height: 1.1;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #111;
    }
    .faq-intro-box p, .faq-heading-block p, .faq-bottom-copy p, .faq-side-card p {
      margin: 0;
      font-size: 1rem;
      line-height: 1.85;
      color: #666;
    }
    .faq-main-section { padding: 40px 0 95px; background: #fff; }
    .faq-layout {
      display: grid;
      grid-template-columns: 300px minmax(0, 1fr);
      gap: 30px;
      align-items: start;
    }
    .faq-side-panel { position: sticky; top: 110px; margin-left: -16px; }
    .faq-side-card {
      padding: 28px;
      border-radius: 28px;
      background: linear-gradient(180deg, #ffffff 0%, #f8f9fb 100%);
      border: 1px solid #ececec;
      box-shadow: 0 18px 45px rgba(15,23,42,0.06);
    }
    .faq-side-card h3 { margin-bottom: 14px; font-size: 1.5rem; line-height: 1.25; font-weight: 800; color: #111; }
    .faq-side-actions { display: flex; flex-direction: column; gap: 12px; margin-top: 22px; }
    .faq-primary-btn, .faq-secondary-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 150px;
      padding: 14px 22px;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 700;
      transition: all 0.28s ease;
    }
    .faq-primary-btn { background: #ffcc00; color: #111; }
    .faq-primary-btn:hover { background: #ffd633; }
    .faq-secondary-btn { background: rgba(255,255,255,0.12); color: #fff; border: 1px solid rgba(255,255,255,0.18); }
    .faq-secondary-btn:hover { background: rgba(255,255,255,0.18); }
    .faq-text-link { display: inline-block; text-decoration: none; color: #0071e3; font-weight: 600; font-size: 0.96rem; }
    .faq-content { display: flex; flex-direction: column; gap: 26px; align-items: flex-start; width: 100%; max-width: 860px; }
    .faq-list { display: grid; gap: 18px; width: 100%; }
    .faq-item {
      background: #fff;
      border: 1px solid #ececec;
      border-radius: 26px;
      overflow: hidden;
      box-shadow: 0 16px 40px rgba(15,23,42,0.05);
      transition: box-shadow 0.28s ease, transform 0.28s ease;
    }
    .faq-item:hover { transform: translateY(-3px); box-shadow: 0 22px 50px rgba(15,23,42,0.10); }
    .faq-question {
      list-style: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 24px 26px;
      font-size: 1.14rem;
      line-height: 1.5;
      font-weight: 700;
      color: #111;
      user-select: none;
    }
    .faq-question::-webkit-details-marker { display: none; }
    .faq-icon { position: relative; width: 22px; height: 22px; flex-shrink: 0; }
    .faq-icon::before, .faq-icon::after {
      content: '';
      position: absolute;
      left: 50%;
      top: 50%;
      width: 16px;
      height: 2px;
      background: #111;
      border-radius: 999px;
      transform: translate(-50%, -50%);
      transition: transform 0.25s ease, opacity 0.25s ease;
    }
    .faq-icon::after { transform: translate(-50%, -50%) rotate(90deg); }
    .faq-item[open] .faq-icon::after { opacity: 0; transform: translate(-50%, -50%) rotate(90deg) scaleX(0.2); }
    .faq-answer { padding: 0 26px 24px; }
    .faq-answer p { margin: 0; font-size: 1rem; line-height: 1.85; color: #666; }
    .faq-bottom-section { padding: 0 0 95px; background: #fff; }
    .faq-bottom-panel {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 28px;
      padding: 40px 42px;
      border-radius: 32px;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      box-shadow: 0 28px 70px rgba(15,23,42,0.16);
    }
    .faq-bottom-copy { max-width: 720px; }
    .faq-bottom-copy h2 { color: #fff; }
    .faq-bottom-copy p { color: rgba(255,255,255,0.82); }
    .faq-bottom-actions { display: flex; gap: 14px; flex-wrap: wrap; }
    .faq-heading-block { width: 100%; max-width: 860px; margin: 0; text-align: left; }
    .faq-heading-block h2, .faq-heading-block p { width: 100%; max-width: 100%; margin-left: 0; margin-right: 0; }
    .faq-heading-block .faq-section-label { margin-left: 0; margin-right: auto; }
    @media (max-width: 991px) {
      .faq-layout { grid-template-columns: 1fr; }
      .faq-side-panel { position: sticky; top: 120px; margin-left: 0; }
      .faq-bottom-panel { flex-direction: column; align-items: flex-start; }
      .faq-heading-block { width: 100%; max-width: 860px; margin: 0 auto; text-align: center; }
      .faq-content { align-items: stretch; width: 100%; }
      .faq-heading-block .faq-section-label { margin-left: auto; margin-right: auto; }
    }
    @media (max-width: 768px) {
      .faq-hero { min-height: 260px; padding: 105px 0 45px; }
      .faq-hero h1 { font-size: clamp(2rem, 8vw, 2.9rem); }
      .faq-side-card, .faq-item, .faq-bottom-panel { border-radius: 24px; }
      .faq-question { padding: 20px; font-size: 1rem; }
      .faq-answer { padding: 0 20px 20px; }
      .faq-bottom-panel { padding: 28px 22px; }
    }
  </style>
</ViLayout>
