---
import ViProductLayout from '../../../../layouts/ViProductLayout.astro';
---

<ViProductLayout title="Máy Làm Sạch Màng Quang Học Khổ Lớn | DGSDK STICK"
  description="Thiết bị làm sạch công nghiệp màng quang học khổ lớn, loại bỏ hiệu quả bụi, sợi và hạt bẩn trước khi dán và kiểm tra."
  image="/assets/img/cleaning-machine/optical.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/vi/">Trang chủ</a>
        <span>/</span>
        <a href="/vi/products">Sản phẩm</a>
        <span>/</span>
        <a href="/vi/products/cleaning-machine">Máy làm sạch</a>
        <span>/</span>
        <span>Máy Làm Sạch Màng Quang Học Khổ Lớn</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/cleaning-machine/optical.jpg"
              alt="Máy Làm Sạch Màng Quang Học Khổ Lớn"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/cleaning-machine/optical.jpg"
              alt="Ảnh thu nhỏ máy làm sạch màng quang học"
              data-full="/assets/img/cleaning-machine/optical.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>Máy Làm Sạch Màng Quang Học Khổ Lớn</h1>
          <p class="product-short-desc">
            Thiết bị làm sạch công nghiệp màng quang học khổ lớn, loại bỏ hiệu quả bụi, sợi và hạt bẩn trước khi dán và kiểm tra.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Yêu cầu báo giá</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Làm sạch khổ lớn</h4>
              <p>Xử lý làm sạch bề mặt hiệu quả cho màng quang học kích thước lớn.</p>
            </div>
            <div class="highlight-item">
              <h4>Làm sạch độ chính xác cao</h4>
              <p>Giải pháp làm sạch được tối ưu hóa riêng cho bề mặt nhạy cảm của màng quang học.</p>
            </div>
            <div class="highlight-item">
              <h4>Truyền tải ổn định</h4>
              <p>Hệ thống truyền tải vật liệu ổn định, tránh làm hỏng bề mặt màng.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Mô tả sản phẩm</h2>
        <p>
          Màng quang học khổ lớn yêu cầu độ sạch bề mặt rất cao trước khi dán, bất kỳ hạt bẩn hoặc sợi nào cũng có thể gây ra lỗi quang học. Máy làm sạch màng quang học khổ lớn được phát triển để giải quyết vấn đề này.
        </p>
        <p>
          Thiết bị hỗ trợ xử lý làm sạch chính xác cho màng quang học khổ lớn, loại bỏ hiệu quả bụi, sợi, hạt bẩn và ô nhiễm tĩnh điện, đảm bảo chất lượng sản phẩm trong quy trình dán.
        </p>
      </section>

      <section class="detail-block">
        <h2>Tính năng sản phẩm</h2>
        <ul class="feature-list">
          <li>Hỗ trợ làm sạch màng quang học khổ lớn</li>
          <li>Làm sạch độ chính xác cao, loại bỏ hiệu quả các chất ô nhiễm nhỏ</li>
          <li>Truyền tải ổn định, tránh hỏng hóc vật liệu</li>
          <li>Tích hợp chức năng khử tĩnh điện</li>
          <li>Phù hợp cho tiền xử lý trước khi dán, kiểm tra và đóng gói</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Ưu điểm kỹ thuật</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Hỗ trợ khổ lớn</h3>
            <p>Được thiết kế riêng cho màng quang học khổ lớn, hỗ trợ làm sạch rộng hiệu quả.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>Làm sạch cấp quang học</h3>
            <p>Tối ưu hóa cho bề mặt nhạy cảm của màng quang học, độ chính xác làm sạch đáp ứng yêu cầu ứng dụng quang học.</p>
          </div>
          <div class="advantage-card green">
            <h3>Truyền tải ổn định</h3>
            <p>Hệ thống truyền tải vật liệu đáng tin cậy, đảm bảo màng hoàn thành làm sạch mà không bị hỏng.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Ngành ứng dụng</h2>
        <div class="application-tags">
          <span>Màng quang học</span>
          <span>Sản xuất màn hình</span>
          <span>Sản xuất kính phân cực</span>
          <span>Sản xuất LCD</span>
          <span>Quy trình dán</span>
          <span>Làm sạch chính xác</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="optical-film-cleaner">
          <div class="related-slider-header">
            <h2>Sản phẩm liên quan</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/vi/products/cleaning-machine/polarizer-cleaner" class="related-slide-card" data-key="polarizer-cleaner">
              <img src="/assets/img/cleaning-machine/polarizer-cleaner.jpg" alt="Máy Làm Sạch Kính Phân Cực Chính Xác" loading="lazy" />
              <h4>Máy Làm Sạch Kính Phân Cực Chính Xác</h4>
            </a>
            <a href="/vi/products/cleaning-machine/fpc-4-axis-cleaner" class="related-slide-card" data-key="fpc-4-axis-cleaner">
              <img src="/assets/img/cleaning-machine/fpc-4-axis-cleaner.jpg" alt="Máy Làm Sạch FPC 4 Trục Độ Chính Xác Cao" loading="lazy" />
              <h4>Máy Làm Sạch FPC 4 Trục Độ Chính Xác Cao</h4>
            </a>
            <a href="/vi/products/cleaning-machine/fpc-8-axis-cleaner" class="related-slide-card" data-key="fpc-8-axis-cleaner">
              <img src="/assets/img/cleaning-machine/fpc-8-axis-cleaner.jpg" alt="Máy Làm Sạch FPC 8 Trục Cao Cấp" loading="lazy" />
              <h4>Máy Làm Sạch FPC 8 Trục Cao Cấp</h4>
            </a>
            <a href="/vi/products/cleaning-machine/optical-film-cleaner" class="related-slide-card" data-key="optical-film-cleaner">
              <img src="/assets/img/cleaning-machine/optical.jpg" alt="Máy Làm Sạch Màng Quang Học Khổ Lớn" loading="lazy" />
              <h4>Máy Làm Sạch Màng Quang Học Khổ Lớn</h4>
            </a>
            <a href="/vi/products/cleaning-machine/lcm-cleaner" class="related-slide-card" data-key="lcm-cleaner">
              <img src="/assets/img/cleaning-machine/lcm-cleaner.jpg" alt="Máy Làm Sạch Công Nghiệp Module LCM" loading="lazy" />
              <h4>Máy Làm Sạch Công Nghiệp Module LCM</h4>
            </a>
            <a href="/vi/products/cleaning-machine/pcb-cleaner" class="related-slide-card" data-key="pcb-cleaner">
              <img src="/assets/img/cleaning-machine/pcb-cleaner.jpg" alt="Máy Làm Sạch Bề Mặt PCB" loading="lazy" />
              <h4>Máy Làm Sạch Bề Mặt PCB</h4>
            </a>
            <a href="/vi/products/cleaning-machine/pcb-vertical-cleaner" class="related-slide-card" data-key="pcb-vertical-cleaner">
              <img src="/assets/img/cleaning-machine/stick-pcb-vertical-cleaning-machine.jpg" alt="Hệ Thống Làm Sạch PCB Dọc" loading="lazy" />
              <h4>Hệ Thống Làm Sạch PCB Dọc</h4>
            </a>
            <a href="/vi/products/cleaning-machine/roll-chip-cleaner" class="related-slide-card" data-key="roll-chip-cleaner">
              <img src="/assets/img/cleaning-machine/roll-chip-cleaner.jpg" alt="Máy Làm Sạch Con Lăn Đa Năng" loading="lazy" />
              <h4>Máy Làm Sạch Con Lăn Đa Năng</h4>
            </a>
            <a href="/vi/products/cleaning-machine/smt-cleaner" class="related-slide-card" data-key="smt-cleaner">
              <img src="/assets/img/cleaning-machine/smt-cleaner.jpg" alt="Máy Làm Sạch Trực Tuyến SMT" loading="lazy" />
              <h4>Máy Làm Sạch Trực Tuyến SMT</h4>
            </a>
            <a href="/vi/products/cleaning-machine/backlight-cleaner" class="related-slide-card" data-key="backlight-cleaner">
              <img src="/assets/img/cleaning-machine/backlight-cleaner.jpg" alt="Máy Làm Sạch Tấm Đèn Nền" loading="lazy" />
              <h4>Máy Làm Sạch Tấm Đèn Nền</h4>
            </a>
            <a href="/vi/products/cleaning-machine/ccl-cleaner" class="related-slide-card" data-key="ccl-cleaner">
              <img src="/assets/img/cleaning-machine/ccl-cleaner.jpg" alt="Máy Làm Sạch CCL STICK" loading="lazy" />
              <h4>Máy Làm Sạch CCL STICK</h4>
            </a>
            <a href="/vi/products/cleaning-machine/inspection-cleaner" class="related-slide-card" data-key="inspection-cleaner">
              <img src="/assets/img/cleaning-machine/inspection-cleaner.jpg" alt="Máy Làm Sạch Bàn Kiểm Tra" loading="lazy" />
              <h4>Máy Làm Sạch Bàn Kiểm Tra</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ViProductLayout>
