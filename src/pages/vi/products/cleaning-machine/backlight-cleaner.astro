            </a>
            <a href="/vi/products/cleaning-machine/backlight-cleaner" class="related-slide-card" data-key="backlight-cleaner">
              <img src="/assets/img/cleaning-machine/backlight-cleaner.jpg" alt="Máy Làm Sạch Tấm Đèn Nền" loading="lazy" />
              <h4>Máy Làm Sạch Tấm Đèn Nền</h4>
            </a>
            <a href="/vi/products/cleaning-machine/ccl-cleaner" class="related-slide-card" data-key="ccl-cleaner">
              <img src="/assets/img/cleaning-machine/ccl-cleaner.jpg" alt="Máy Làm Sạch CCL STICK" loading="lazy" />
              <h4>Máy Làm Sạch CCL STICK</h4>
            </a>
            <a href="/vi/products/cleaning-machine/inspection-cleaner" class="related-slide-card" data-key="inspection-cleaner">
              <img src="/assets/img/cleaning-machine/inspection-cleaner.jpg" alt="Máy Làm Sạch Bàn Kiểm Tra" loading="lazy" />
