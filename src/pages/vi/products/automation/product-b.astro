---
import ViProductLayout from '../../../../layouts/ViProductLayout.astro';
---

<ViProductLayout title="Máy Làm Sạch Nạp/Dỡ Tự Động Bằng Robot | DGSDK"
  description="Thiết bị làm sạch nạp/dỡ tự động bằng cánh tay robot, nâng cao hiệu quả sản xuất, giảm vận chuyển thủ công, duy trì chất lượng làm sạch ổn định."
  image="/assets/img/automation/product-b.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/vi/">Trang chủ</a>
        <span>/</span>
        <a href="/vi/products">Sản phẩm</a>
        <span>/</span>
        <a href="/vi/products/automation">Thiết Bị Tự Động Hóa</a>
        <span>/</span>
        <span>Máy Làm Sạch Nạp/Dỡ Tự Động Bằng Robot</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/automation/product-b.jpg"
              alt="Máy Làm Sạch Nạp/Dỡ Tự Động Bằng Robot"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/automation/product-b.jpg"
              alt="Ảnh thu nhỏ máy làm sạch robot"
              data-full="/assets/img/automation/product-b.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>Máy Làm Sạch Nạp/Dỡ Tự Động Bằng Robot</h1>
          <p class="product-short-desc">
            Thiết bị làm sạch nạp/dỡ tự động bằng cánh tay robot, nâng cao hiệu quả sản xuất, giảm vận chuyển thủ công, duy trì chất lượng làm sạch ổn định.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Yêu Cầu Báo Giá</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Tích Hợp Robot</h4>
              <p>Cánh tay robot tự động nạp/dỡ, giảm can thiệp thủ công.</p>
            </div>
            <div class="highlight-item">
              <h4>Hiệu Suất Sản Xuất Cao</h4>
              <p>Nạp/dỡ tự động nâng cao nhịp sản xuất và hiệu quả tổng thể.</p>
            </div>
            <div class="highlight-item">
              <h4>Chất Lượng Làm Sạch Ổn Định</h4>
              <p>Quy trình tự động đảm bảo hiệu quả làm sạch nhất quán và ổn định cho mỗi lô hàng.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Mô Tả Sản Phẩm</h2>
        <p>
          Máy làm sạch nạp/dỡ tự động bằng robot tích hợp nạp/dỡ tự động bằng cánh tay robot với chức năng làm sạch công nghiệp thành một hệ thống, giảm hiệu quả vận chuyển thủ công, nâng cao hiệu quả sản xuất và tính nhất quán chất lượng làm sạch.
        </p>
        <p>
          Phù hợp cho các ứng dụng làm sạch công nghiệp yêu cầu nạp/dỡ tự động hiệu quả, giảm chi phí nhân công thông qua tích hợp robot, nâng cao nhịp sản xuất và sự ổn định độ sạch của sản phẩm.
        </p>
      </section>

      <section class="detail-block">
        <h2>Đặc Điểm Sản Phẩm</h2>
        <ul class="feature-list">
          <li>Cánh tay robot tự động nạp/dỡ, giảm thao tác thủ công</li>
          <li>Quy trình tự động hóa, nâng cao hiệu quả sản xuất</li>
          <li>Chất lượng làm sạch ổn định, tính nhất quán giữa các lô tốt</li>
          <li>Phù hợp cho ứng dụng tự động hóa làm sạch công nghiệp</li>
          <li>Hỗ trợ tùy chỉnh cấu hình tự động hóa</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Ưu Điểm Kỹ Thuật</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Tích Hợp Robot</h3>
            <p>Cánh tay robot tự động nạp/dỡ, giảm đáng kể nhu cầu thao tác thủ công.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>Nâng Cao Hiệu Suất</h3>
            <p>Nạp/dỡ tự động nâng cao nhịp sản xuất, giảm chi phí nhân công.</p>
          </div>
          <div class="advantage-card green">
            <h3>Chất Lượng Ổn Định</h3>
            <p>Quy trình tự động đảm bảo chất lượng làm sạch nhất quán và đáng tin cậy cho mỗi lô hàng.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Ngành Ứng Dụng</h2>
        <div class="application-tags">
          <span>Hệ Thống Robot</span>
          <span>Sản Xuất Tự Động</span>
          <span>Làm Sạch Công Nghiệp</span>
          <span>Tự Động Hóa Chính Xác</span>
          <span>Sản Xuất Điện Tử</span>
          <span>Dây Chuyền Công Nghiệp Tùy Chỉnh</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="product-b">
          <div class="related-slider-header">
            <h2>Sản Phẩm Liên Quan</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/vi/products/automation/product-a" class="related-slide-card" data-key="product-a">
              <img src="/assets/img/automation/product-a.jpg" alt="Dây Chuyền Làm Sạch và Kiểm Tra Tấm Khuếch Tán" loading="lazy" />
              <h4>Dây Chuyền Làm Sạch và Kiểm Tra Tấm Khuếch Tán</h4>
            </a>
            <a href="/vi/products/automation/product-b" class="related-slide-card" data-key="product-b">
              <img src="/assets/img/automation/product-b.jpg" alt="Máy Làm Sạch Nạp/Dỡ Tự Động Bằng Robot" loading="lazy" />
              <h4>Máy Làm Sạch Nạp/Dỡ Tự Động Bằng Robot</h4>
            </a>
            <a href="/vi/products/automation/product-c" class="related-slide-card" data-key="product-c">
              <img src="/assets/img/automation/product-c.jpg" alt="Thiết Bị Đo Góc Trục Hấp Thụ Phim Phân Cực" loading="lazy" />
              <h4>Thiết Bị Đo Góc Trục Hấp Thụ Phim Phân Cực</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ViProductLayout>
