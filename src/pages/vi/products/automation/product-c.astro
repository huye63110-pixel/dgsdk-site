---
import ViProductLayout from '../../../../layouts/ViProductLayout.astro';
---

<ViProductLayout title="Máy Đo Góc Trục Hấp Thụ Kính Phân Cực | DGSDK STICK"
  description="Thiết bị tự động hóa tùy chỉnh, nâng cao hiệu quả đo góc trục hấp thụ kính phân cực, ổn định quy trình và tính nhất quán sản xuất."
  image="/assets/img/automation/product-c.jpg">
  <section class="product-detail-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/vi/">Trang chủ</a>
        <span>/</span>
        <a href="/vi/products">Sản phẩm</a>
        <span>/</span>
        <a href="/vi/products/automation">Thiết Bị Tự Động Hóa</a>
        <span>/</span>
        <span>Máy Đo Góc Trục Hấp Thụ Kính Phân Cực</span>
      </div>

      <div class="product-top">
        <div class="product-gallery">
          <div class="product-main-image slider-wrapper">
            <button class="slider-arrow left" id="prevImage">‹</button>
            <img
              id="mainProductImage"
              src="/assets/img/automation/product-c.jpg"
              alt="Máy Đo Góc Trục Hấp Thụ Kính Phân Cực"
            />
            <button class="slider-arrow right" id="nextImage">›</button>
          </div>

          <div class="product-thumbs">
            <img
              class="thumb-image active-thumb"
              src="/assets/img/automation/product-c.jpg"
              alt="Ảnh thu nhỏ máy đo kính phân cực"
              data-full="/assets/img/automation/product-c.jpg"
            />
          </div>
        </div>

        <div class="product-summary">
          <h1>Máy Đo Góc Trục Hấp Thụ Kính Phân Cực</h1>
          <p class="product-short-desc">
            Thiết bị tự động hóa tùy chỉnh, nâng cao hiệu quả đo góc trục hấp thụ kính phân cực, ổn định quy trình và tính nhất quán sản xuất.
          </p>

          <div class="product-actions">
            <button class="quote-btn" type="button">Yêu cầu báo giá</button>
            <a href="https://wa.me/61436605126" target="_blank" class="whatsapp-btn">WhatsApp</a>
          </div>

          <div class="product-highlights">
            <div class="highlight-item">
              <h4>Đo lường chính xác</h4>
              <p>Phát hiện tự động góc trục hấp thụ kính phân cực với độ chính xác cao.</p>
            </div>
            <div class="highlight-item">
              <h4>Tích hợp tự động hóa</h4>
              <p>Quy trình đo lường tự động, nâng cao hiệu quả kiểm tra và tính nhất quán.</p>
            </div>
            <div class="highlight-item">
              <h4>Đảm bảo chất lượng</h4>
              <p>Đo góc chính xác, đảm bảo chất lượng kính phân cực đáp ứng yêu cầu.</p>
            </div>
          </div>
        </div>
      </div>

      <section class="detail-block">
        <h2>Mô tả sản phẩm</h2>
        <p>
          Góc trục hấp thụ kính phân cực là thông số quan trọng ảnh hưởng đến hiệu suất quang học sản phẩm trong sản xuất LCD và màn hình, đo lường chính xác là khâu quan trọng của kiểm soát chất lượng. Máy đo góc trục hấp thụ kính phân cực được thiết kế chuyên biệt để tự động phát hiện thông số quan trọng này.
        </p>
        <p>
          Thiết bị đo lường tự động hóa tùy chỉnh, cung cấp phát hiện góc trục hấp thụ kính phân cực ổn định và hiệu quả cao, nâng cao ổn định quy trình và tính nhất quán sản xuất, đáp ứng yêu cầu kiểm soát chất lượng nghiêm ngặt của sản xuất màn hình.
        </p>
      </section>

      <section class="detail-block">
        <h2>Tính năng sản phẩm</h2>
        <ul class="feature-list">
          <li>Đo tự động góc trục hấp thụ kính phân cực với độ chính xác cao</li>
          <li>Quy trình phát hiện tự động hóa, hiệu quả đo lường cao</li>
          <li>Kết quả đo lường ổn định và nhất quán, chất lượng đáng tin cậy</li>
          <li>Phù hợp với kiểm soát chất lượng sản xuất LCD và màn hình</li>
          <li>Hỗ trợ cấu hình tự động hóa tùy chỉnh</li>
        </ul>
      </section>

      <section class="detail-block">
        <h2>Ưu điểm kỹ thuật</h2>
        <div class="advantage-grid">
          <div class="advantage-card blue">
            <h3>Đo lường chính xác</h3>
            <p>Hệ thống đo lường tự động độ chính xác cao, đảm bảo dữ liệu góc kính phân cực chính xác và đáng tin cậy.</p>
          </div>
          <div class="advantage-card yellow">
            <h3>Phát hiện tự động</h3>
            <p>Quy trình đo lường tự động hóa, nâng cao đáng kể hiệu quả kiểm tra và năng lực sản xuất.</p>
          </div>
          <div class="advantage-card green">
            <h3>Đảm bảo chất lượng</h3>
            <p>Kết quả đo lường ổn định và nhất quán, cung cấp hỗ trợ chất lượng đáng tin cậy cho sản xuất màn hình.</p>
          </div>
        </div>
      </section>

      <section class="detail-block">
        <h2>Ngành ứng dụng</h2>
        <div class="application-tags">
          <span>Sản xuất kính phân cực</span>
          <span>Sản xuất màn hình</span>
          <span>Hệ thống đo lường</span>
          <span>Kiểm soát chất lượng</span>
          <span>Sản xuất LCD</span>
          <span>Tự động hóa chính xác</span>
        </div>
      </section>

      <section class="detail-block">
        <div class="related-slider-wrap" data-current="product-c">
          <div class="related-slider-header">
            <h2>Sản phẩm liên quan</h2>
            <div class="related-slider-nav">
              <button class="related-slider-btn related-slider-prev" type="button">‹</button>
              <button class="related-slider-btn related-slider-next" type="button">›</button>
            </div>
          </div>
          <div class="related-slider-track">
            <a href="/vi/products/automation/product-a" class="related-slide-card" data-key="product-a">
              <img src="/assets/img/automation/product-a.jpg" alt="Dây Chuyền Làm Sạch và Kiểm Tra Tấm Khuếch Tán" loading="lazy" />
              <h4>Dây Chuyền Làm Sạch và Kiểm Tra Tấm Khuếch Tán</h4>
            </a>
            <a href="/vi/products/automation/product-b" class="related-slide-card" data-key="product-b">
              <img src="/assets/img/automation/product-b.jpg" alt="Máy Làm Sạch Nạp/Dỡ Tự Động Robot" loading="lazy" />
              <h4>Máy Làm Sạch Nạp/Dỡ Tự Động Robot</h4>
            </a>
            <a href="/vi/products/automation/product-c" class="related-slide-card" data-key="product-c">
              <img src="/assets/img/automation/product-c.jpg" alt="Máy Đo Góc Trục Hấp Thụ Kính Phân Cực" loading="lazy" />
              <h4>Máy Đo Góc Trục Hấp Thụ Kính Phân Cực</h4>
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</ViProductLayout>
