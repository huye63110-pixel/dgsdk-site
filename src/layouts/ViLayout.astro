---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
const {
  title = "DGSDK | Giải Pháp Tự Động Hóa Công Nghiệp & Khử Tĩnh Điện",
  description = "DGSDK là nhà sản xuất chuyên nghiệp tại Đông Quan, Trung Quốc, chuyên sản xuất hệ thống khử tĩnh điện, máy làm sạch công nghiệp, thiết bị tự động hóa và linh kiện CNC chính xác.",
  image = "/assets/img/header-bg.webp",
  canonical: _rawCanonical = Astro.url.href
} = Astro.props;
const _segments = new URL(_rawCanonical).pathname.split('/').filter(Boolean);
const canonical = _segments.length > 1 ? _rawCanonical.replace(/\/$/, '') : _rawCanonical;
---

<!DOCTYPE html>
<html lang="vi" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="vi" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical.replace('/vi', '')} />
    <link rel="alternate" hreflang="zh" href={canonical.replace('/vi', '/zh')} />
    <link rel="alternate" hreflang="ar" href={canonical.replace('/vi', '/ar')} />
    <link rel="alternate" hreflang="ja" href={canonical.replace('/vi', '/ja')} />
    <link rel="alternate" hreflang="ko" href={canonical.replace('/vi', '/ko')} />
    <link rel="alternate" hreflang="es" href={canonical.replace('/vi', '/es')} />
    <link rel="alternate" hreflang="x-default" href={canonical.replace('/vi', '')} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://www.dg-sdk.com${image}`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="DGSDK" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://www.dg-sdk.com${image}`} />

    <!-- SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="DGSDK - Dongguan Shidike Automation Equipment Co., Ltd." />
    <meta name="keywords" content="khử tĩnh điện, máy làm sạch công nghiệp, linh kiện CNC chính xác, thiết bị tự động hóa, nhà sản xuất Đông Quan" />
    <meta name="geo.region" content="CN-GD" />
    <meta name="geo.placename" content="Dongguan, Guangdong, China" />

    <link rel="stylesheet" href="/css/styles.css" />
    <!-- Performance hints -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <!-- Font Awesome: deferred (non-render-blocking) -->
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" /></noscript>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": ["Organization", "LocalBusiness"],
      "name": "DGSDK",
      "alternateName": "Dongguan Shidike Automation Equipment Co., Ltd.",
      "url": "https://www.dg-sdk.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.dg-sdk.com/logo.png",
        "width": 600,
        "height": 169
      },
      "description": "Nhà sản xuất chuyên nghiệp hệ thống khử tĩnh điện, máy làm sạch công nghiệp, thiết bị tự động hóa và linh kiện CNC chính xác.",
      "foundingDate": "2013",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "33 Đường Binhai",
        "addressLocality": "Đông Quan",
        "addressRegion": "Quảng Đông",
        "postalCode": "523000",
        "addressCountry": "CN"
      },
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "telephone": "+86-13602342003",
          "contactType": "sales",
          "availableLanguage": ["English", "Chinese", "Vietnamese"],
          "areaServed": "Worldwide"
        }
      ],
      "email": "huye63110@gmail.com"
    }
    </script>
  </head>

  <body id="page-top">
    <!-- Thanh điều hướng -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
      <div class="container">
        <a class="navbar-brand" href="/vi/">
          <img src="/logo.png" alt="DGSDK Logo" width="200" height="56" loading="eager" />
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarResponsive"
          aria-controls="navbarResponsive"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          Menu <i class="fas fa-bars ms-1"></i>
        </button>
        <div class="collapse navbar-collapse" id="navbarResponsive">
          <ul class="navbar-nav text-uppercase ms-auto py-4 py-lg-0">
            <li class="nav-item"><a class="nav-link" href="/vi/">Trang chủ</a></li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="/vi/products" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Sản phẩm</a>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/vi/products">Tất cả sản phẩm</a></li>
                <li><a class="dropdown-item" href="/vi/products/static-eliminator">Hệ thống khử tĩnh điện</a></li>
                <li><a class="dropdown-item" href="/vi/products/cleaning-machine">Máy làm sạch</a></li>
                <li><a class="dropdown-item" href="/vi/products/precision-machined-parts">Linh kiện gia công chính xác</a></li>
                <li><a class="dropdown-item" href="/vi/products/automation">Thiết bị tự động hóa</a></li>
              </ul>
            </li>
            <li class="nav-item"><a class="nav-link" href="/vi/applications">Ứng dụng</a></li>
            <li class="nav-item"><a class="nav-link" href="/vi/about">Về chúng tôi</a></li>
            <li class="nav-item"><a class="nav-link" href="/vi/contact">Liên hệ</a></li>
            <li class="nav-item"><a class="nav-link" href="/vi/faq">FAQ</a></li>

            <li class="nav-item lang-dropdown" id="langDropdown">
              <button class="nav-link lang-btn" type="button" id="langToggle" aria-label="Chọn ngôn ngữ" aria-expanded="false">
                VI <i class="fas fa-chevron-down"></i>
              </button>
              <ul class="lang-menu" id="langMenu">
                <li><a href="/">English</a></li>
                <li><a href="/zh/">中文</a></li>
                <li><a href="/vi/">Tiếng Việt</a></li>
                <li><a href="/ar/">العربية</a></li>
                <li><a href="/ja/">日本語</a></li>
                <li><a href="/ko/">한국어</a></li>
                <li><a href="/es/">Español</a></li>
              </ul>
            </li>

            <li class="nav-item nav-icon-item search-dropdown" id="searchDropdown">
              <button class="nav-link nav-icon-btn" type="button" id="searchToggle" aria-label="Tìm kiếm sản phẩm" aria-expanded="false">
                <i class="fas fa-search"></i>
              </button>
              <div class="search-box" id="searchBox">
                <input type="text" placeholder="Tìm kiếm sản phẩm..." autocomplete="off" />
              </div>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main style="padding-top: 110px;">
      <slot />
    </main>

    <!-- Nút mạng xã hội nổi -->
    <div class="floating-social">
      <a href="mailto:huye63110@gmail.com" target="_blank" rel="noopener noreferrer" aria-label="Email" class="float-btn email">
        <i class="fas fa-envelope"></i>
      </a>
      <a href="https://wa.me/61436605126?text=Xin ch%C3%A0o%2C t%C3%B4i quan t%C3%A2m %C4%91%E1%BA%BFn s%E1%BA%A3n ph%E1%BA%A9m c%E1%BB%A7a b%E1%BA%A1n" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="float-btn whatsapp">
        <i class="fab fa-whatsapp"></i>
      </a>
      <a href="https://www.linkedin.com/in/henry-hu-0ba80737a" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="float-btn linkedin">
        <i class="fab fa-linkedin-in"></i>
      </a>
      <a href="https://www.tiktok.com/@machingmasters" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="float-btn tiktok">
        <i class="fab fa-tiktok"></i>
      </a>
      <a href="https://www.instagram.com/ls_machiningmasters" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="float-btn instagram">
        <i class="fab fa-instagram"></i>
      </a>
      <a href="https://youtube.com/@machiningmasters01" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="float-btn youtube">
        <i class="fab fa-youtube"></i>
      </a>
      <a href="https://www.facebook.com/yourcompany" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="float-btn facebook">
        <i class="fab fa-facebook-f"></i>
      </a>
      <a href="#page-top" aria-label="Về đầu trang" class="float-btn top">
        <i class="fas fa-arrow-up"></i>
      </a>
    </div>

    <!-- Chân trang -->
    <footer class="site-footer">
      <div class="footer-container">
        <div class="footer-col footer-brand">
          <img src="/logo.png" alt="DGSDK Logo" width="180" height="50" class="footer-logo" loading="lazy" />
          <p>DGSDK là nhà sản xuất chuyên nghiệp tại Đông Quan, Trung Quốc, chuyên sản xuất hệ thống khử tĩnh điện, máy làm sạch công nghiệp, thiết bị tự động hóa và linh kiện CNC chính xác.</p>
        </div>
        <div class="footer-col">
          <h4>Liên kết nhanh</h4>
          <a href="/vi/">Trang chủ</a>
          <a href="/vi/applications">Ứng dụng</a>
          <a href="/vi/about">Về chúng tôi</a>
          <a href="/vi/contact">Liên hệ</a>
          <a href="/vi/faq">FAQ</a>
        </div>
        <div class="footer-col">
          <h4>Sản phẩm</h4>
          <a href="/vi/products/static-eliminator">Hệ thống khử tĩnh điện</a>
          <a href="/vi/products/cleaning-machine">Máy làm sạch</a>
          <a href="/vi/products/precision-machined-parts">Linh kiện gia công chính xác</a>
          <a href="/vi/products/automation">Thiết bị tự động hóa</a>
        </div>
        <div class="footer-col">
          <h4>Liên hệ</h4>
          <p>Điện thoại: +86 13602342003</p>
          <p>WhatsApp: +61 436605126</p>
          <p>Email: huye63110@gmail.com</p>
          <p>Địa chỉ: 33 Đường Binhai, Đông Quan, Quảng Đông, Trung Quốc</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 DGSDK. Bảo lưu mọi quyền. <a href="/privacy" style="color:rgba(255,255,255,0.5);text-decoration:none;margin-left:12px;">Chính sách bảo mật</a></p>
      </div>
    </footer>

    <!-- Modal báo giá toàn cục -->
    <div class="quote-modal" id="quoteModal">
      <div class="quote-modal-overlay" id="closeQuoteModal"></div>
      <div class="quote-modal-content">
        <button class="quote-modal-close" id="closeQuoteModalBtn" type="button" aria-label="Đóng biểu mẫu báo giá">×</button>
        <h2>Nhận báo giá</h2>
        <p>Vui lòng để lại thông tin liên hệ và chúng tôi sẽ phản hồi sớm.</p>
        <form class="quote-form" id="quoteFormMain">
          <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />
          <input type="text" placeholder="Họ và tên" required />
          <input type="email" placeholder="Email" required />
          <textarea placeholder="Tin nhắn"></textarea>
          <button type="submit">Gửi tin nhắn</button>
        </form>
      </div>
    </div>

    <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script is:inline src="/js/scripts.js"></script>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('quoteModal');
        const closeOverlay = document.getElementById('closeQuoteModal');
        const closeBtn = document.getElementById('closeQuoteModalBtn');
        const form = document.getElementById('quoteFormMain');

        document.querySelectorAll('.quote-btn').forEach(btn => {
          btn.addEventListener('click', () => modal.classList.add('active'));
        });
        if (closeOverlay) closeOverlay.addEventListener('click', () => modal.classList.remove('active'));
        if (closeBtn) closeBtn.addEventListener('click', () => modal.classList.remove('active'));

        if (form) {
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            const honeypot = form.querySelector('input[name="website"]');
            if (honeypot && honeypot.value !== '') return;
            alert('Tin nhắn đã được gửi! Chúng tôi sẽ phản hồi sớm nhất có thể.');
            modal.classList.remove('active');
            form.reset();
          });
        }
      });
    </script>

    <Analytics />
    <SpeedInsights />
  </body>
</html>
