---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
const {
  title = "DGSDK | Industrial Automation & Static Control Solutions",
  description = "DGSDK is a professional manufacturer in Dongguan, China, specializing in static elimination systems, industrial cleaning machines, automation equipment, and precision CNC parts.",
  image = "/assets/img/header-bg.webp",
  canonical: _rawCanonical = Astro.url.href
} = Astro.props;

const base = "https://www.dg-sdk.com";
// Normalize canonical: strip trailing slash for deep paths (keep / and /lang/)
const _segments = new URL(_rawCanonical).pathname.split('/').filter(Boolean);
const canonical = _segments.length > 1 ? _rawCanonical.replace(/\/$/, '') : _rawCanonical;
const path = new URL(canonical).pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang for multilingual versions -->
    <link rel="alternate" hreflang="en" href={`${base}${path}`} />
    <link rel="alternate" hreflang="zh" href={`${base}/zh${path === '/' ? '/' : path}`} />
    <link rel="alternate" hreflang="vi" href={`${base}/vi${path === '/' ? '/' : path}`} />
    <link rel="alternate" hreflang="ar" href={`${base}/ar${path === '/' ? '/' : path}`} />
    <link rel="alternate" hreflang="ja" href={`${base}/ja${path === '/' ? '/' : path}`} />
    <link rel="alternate" hreflang="ko" href={`${base}/ko${path === '/' ? '/' : path}`} />
    <link rel="alternate" hreflang="es" href={`${base}/es${path === '/' ? '/' : path}`} />
    <link rel="alternate" hreflang="x-default" href={`${base}${path}`} />

    <!-- Open Graph (Facebook, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://www.dg-sdk.com${image}`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="DGSDK" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://www.dg-sdk.com${image}`} />

    <!-- Extra SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="DGSDK - Dongguan Shidike Automation Equipment Co., Ltd." />
    <meta name="keywords" content="static eliminator, static elimination system, cleaning machine, CNC parts, precision machined parts, automation equipment, industrial automation, Dongguan, China manufacturer" />

    <!-- Geo targeting -->
    <meta name="geo.region" content="CN-GD" />
    <meta name="geo.placename" content="Dongguan, Guangdong, China" />

    <!-- Performance hints -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />

    <!-- Critical CSS -->
    <link rel="stylesheet" href="/css/styles.css" />

    <!-- Font Awesome: deferred (non-render-blocking) -->
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" /></noscript>

    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Structured Data: Organization + LocalBusiness -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": ["Organization", "LocalBusiness"],
      "name": "DGSDK",
      "alternateName": "Dongguan Shidike Automation Equipment Co., Ltd.",
      "url": "https://www.dg-sdk.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.dg-sdk.com/logo.png",
        "width": 600,
        "height": 169
      },
      "image": "https://www.dg-sdk.com/assets/img/header-bg.webp",
      "description": "Professional manufacturer specializing in static elimination systems, industrial cleaning machines, automation equipment, and precision CNC parts.",
      "foundingDate": "2013",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Binhai Road 33",
        "addressLocality": "Dongguan",
        "addressRegion": "Guangdong",
        "postalCode": "523000",
        "addressCountry": "CN"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 22.7847,
        "longitude": 113.7676
      },
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "telephone": "+86-13602342003",
          "contactType": "sales",
          "availableLanguage": ["English", "Chinese"],
          "areaServed": "Worldwide"
        },
        {
          "@type": "ContactPoint",
          "telephone": "+61-436605126",
          "contactType": "customer support",
          "contactOption": "WhatsApp",
          "availableLanguage": ["English", "Chinese"]
        }
      ],
      "email": "dgsdk2013@gmail.com",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Industrial Products",
        "itemListElement": [
          {"@type": "OfferCatalog", "name": "Static Elimination Systems"},
          {"@type": "OfferCatalog", "name": "Industrial Cleaning Machines"},
          {"@type": "OfferCatalog", "name": "Precision Machined Parts"},
          {"@type": "OfferCatalog", "name": "Automation Equipment"}
        ]
      },
      "sameAs": [
        "https://www.facebook.com/yourcompany",
        "https://www.tiktok.com/@machineforge?_r=1&_t=ZS-95scfOHz6Ea"
      ]
    }
    </script>
  </head>

  <body id="page-top">
    <!-- NAV -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
      <div class="container">
        <a class="navbar-brand" href="/" aria-label="DGSDK homepage">
          <picture>
            <source srcset="/logo-300.webp 300w, /logo.webp 600w" sizes="(max-width: 768px) 160px, 200px" type="image/webp" />
            <img src="/logo.png" alt="DGSDK Logo" width="200" height="56" loading="eager" fetchpriority="high" />
          </picture>
        </a>

        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarResponsive"
          aria-controls="navbarResponsive"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          Menu
          <i class="fas fa-bars ms-1"></i>
        </button>

        <div class="collapse navbar-collapse" id="navbarResponsive">
          <ul class="navbar-nav text-uppercase ms-auto py-4 py-lg-0">
            <li class="nav-item">
              <a class="nav-link" href="/">Home</a>
            </li>

            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="/products" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Products
              </a>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/products">All Products</a></li>
                <li><a class="dropdown-item" href="/products/static-eliminator">Static Elimination System</a></li>
                <li><a class="dropdown-item" href="/products/cleaning-machine">Cleaning Machine</a></li>
                <li><a class="dropdown-item" href="/products/precision-machined-parts">Precision Machined Parts</a></li>
                <li><a class="dropdown-item" href="/products/automation">Automation Equipment</a></li>
              </ul>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/applications">Applications</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/about">About Us</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/contact">Contact Us</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/faq">FAQ</a>
            </li>

            <li class="nav-item lang-dropdown" id="langDropdown">
              <button class="nav-link lang-btn" type="button" id="langToggle" aria-label="Select language" aria-expanded="false">
                EN <i class="fas fa-chevron-down" aria-hidden="true"></i>
              </button>
              <ul class="lang-menu" id="langMenu">
                <li><a href="/">English</a></li>
                <li><a href="/zh/">中文</a></li>
                <li><a href="/vi/">Tiếng Việt</a></li>
                <li><a href="/ar/">العربية</a></li>
                <li><a href="/ja/">日本語</a></li>
                <li><a href="/ko/">한국어</a></li>
                <li><a href="/es/">Español</a></li>
              </ul>
            </li>

            <li class="nav-item nav-icon-item search-dropdown" id="searchDropdown">
              <button class="nav-link nav-icon-btn" type="button" id="searchToggle" aria-label="Search products" aria-expanded="false">
                <i class="fas fa-search" aria-hidden="true"></i>
              </button>
              <div class="search-box" id="searchBox" role="search">
                <input type="text" placeholder="Search products..." aria-label="Search products" />
              </div>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main style="padding-top: 110px;">
      <slot />
    </main>

    <!-- FLOATING SOCIAL -->
    <div class="floating-social">
      <a href="mailto:dgsdk2013@gmail.com" target="_blank" rel="noopener noreferrer" aria-label="Email" class="float-btn email">
        <i class="fas fa-envelope"></i>
      </a>
      <a href="https://wa.me/61436605126?text=Hello%20I%20am%20interested%20in%20your%20products" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="float-btn whatsapp">
        <i class="fab fa-whatsapp"></i>
      </a>
      <a href="https://www.tiktok.com/@machineforge?_r=1&_t=ZS-95scfOHz6Ea" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="float-btn tiktok">
        <i class="fab fa-tiktok"></i>
      </a>
      <a href="https://www.facebook.com/yourcompany" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="float-btn facebook">
        <i class="fab fa-facebook-f"></i>
      </a>
      <a href="#page-top" aria-label="Back to Top" class="float-btn top">
        <i class="fas fa-arrow-up"></i>
      </a>
    </div>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="footer-container">
        <div class="footer-col footer-brand">
          <img src="/logo.png" alt="DGSDK Logo" width="180" height="50" class="footer-logo" loading="lazy" />
          <p>DGSDK is a professional manufacturer in Dongguan, China, specializing in static elimination systems, industrial cleaning machines, automation equipment, and precision CNC parts.</p>
        </div>
        <div class="footer-col">
          <p class="footer-col-title">Quick Links</p>
          <a href="/">Home</a>
          <a href="/applications">Applications</a>
          <a href="/about">About Us</a>
          <a href="/contact">Contact Us</a>
          <a href="/faq">FAQ</a>
        </div>
        <div class="footer-col">
          <p class="footer-col-title">Products</p>
          <a href="/products/static-eliminator">Static Eliminator</a>
          <a href="/products/cleaning-machine">Cleaning Machine</a>
          <a href="/products/precision-machined-parts">Precision Machined Parts</a>
          <a href="/products/automation">Automation Equipment</a>
        </div>
        <div class="footer-col">
          <p class="footer-col-title">Contact</p>
          <p>Phone: +86 13602342003</p>
          <p>WhatsApp: +61 436605126</p>
          <p>Email: dgsdk2013@gmail.com</p>
          <p>Address: Binhai Road 33, Dongguan, Guangdong, China</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 DGSDK. All rights reserved. <a href="/privacy" style="color:rgba(255,255,255,0.5);text-decoration:none;margin-left:12px;">Privacy Policy</a></p>
      </div>
    </footer>

    <script defer src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script defer src="/js/scripts.js"></script>

    <script is:inline>
      const langToggle = document.getElementById('langToggle');
      const langMenu = document.getElementById('langMenu');
      const searchToggle = document.getElementById('searchToggle');
      const searchBox = document.getElementById('searchBox');

      if (langToggle && langMenu) {
        langToggle.addEventListener('click', function(e) {
          e.stopPropagation();
          langMenu.classList.toggle('show');
          if (searchBox) searchBox.classList.remove('show');
        });
      }
      if (searchToggle && searchBox) {
        searchToggle.addEventListener('click', function(e) {
          e.stopPropagation();
          searchBox.classList.toggle('show');
          if (langMenu) langMenu.classList.remove('show');
        });
      }
      document.addEventListener('click', function() {
        if (langMenu) langMenu.classList.remove('show');
        if (searchBox) searchBox.classList.remove('show');
      });
    </script>

    <!-- GLOBAL QUOTE MODAL -->
    <div class="quote-modal" id="quoteModal">
      <div class="quote-modal-overlay" id="closeQuoteModal"></div>
      <div class="quote-modal-content">
        <button class="quote-modal-close" id="closeQuoteModalBtn" type="button" aria-label="Close quote form">×</button>
        <h2>Get a Quote</h2>
        <p>Please leave your contact details and we will get back to you shortly.</p>
        <form class="quote-form" id="quoteFormMain" action="https://formspree.io/f/mvzlpdwy" method="POST">
          <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />
          <input type="text" name="name" placeholder="Your Name" required />
          <input type="email" name="email" placeholder="Your Email" required />
          <textarea name="message" placeholder="Your Message"></textarea>
          <button type="submit">Send Message</button>
        </form>
      </div>
    </div>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('quoteModal');
        const closeOverlay = document.getElementById('closeQuoteModal');
        const closeBtn = document.getElementById('closeQuoteModalBtn');
        const form = document.getElementById('quoteFormMain');

        document.querySelectorAll('.quote-btn').forEach(btn => {
          btn.addEventListener('click', () => modal.classList.add('active'));
        });
        if (closeOverlay) closeOverlay.addEventListener('click', () => modal.classList.remove('active'));
        if (closeBtn) closeBtn.addEventListener('click', () => modal.classList.remove('active'));

        if (form) {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const honeypot = form.querySelector('input[name="website"]');
            if (honeypot && honeypot.value !== '') return;
            const btn = form.querySelector('button[type="submit"]');
            if (btn) btn.disabled = true;
            try {
              const res = await fetch('https://formspree.io/f/mvzlpdwy', {
                method: 'POST',
                body: new FormData(form),
                headers: { 'Accept': 'application/json' }
              });
              if (res.ok) {
                alert('Message sent! We will contact you shortly.');
                modal.classList.remove('active');
                form.reset();
              } else {
                alert('Error sending message. Please try again.');
              }
            } catch(err) {
              alert('Error sending message. Please try again.');
            } finally {
              if (btn) btn.disabled = false;
            }
          });
        }
      });
    </script>
    <Analytics />
    <SpeedInsights />
  </body>
</html>
