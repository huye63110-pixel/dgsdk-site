    <!-- Theme JS -->
    <script is:inline src="/js/scripts.js"></script>

    <!-- Inline toggle script -->
    <script is:inline>
      const langToggle = document.getElementById('langToggle');
      const langMenu = document.getElementById('langMenu');

      const searchToggle = document.getElementById('searchToggle');
      const searchBox = document.getElementById('searchBox');

      if (langToggle && langMenu) {
        langToggle.addEventListener('click', function (e) {
          e.stopPropagation();
          langMenu.classList.toggle('show');
          if (searchBox) searchBox.classList.remove('show');
        });
      }

      if (searchToggle && searchBox) {
        searchToggle.addEventListener('click', function (e) {
          e.stopPropagation();
          searchBox.classList.toggle('show');
          if (langMenu) langMenu.classList.remove('show');
        });
      }

      document.addEventListener('click', function () {
        if (langMenu) langMenu.classList.remove('show');
        if (searchBox) searchBox.classList.remove('show');
      });
    </script>

    <!-- GLOBAL QUOTE MODAL -->
<div class="quote-modal" id="quoteModal">
  <div class="quote-modal-overlay" id="closeQuoteModal"></div>

  <div class="quote-modal-content">
    <button class="quote-modal-close" id="closeQuoteModalBtn">×</button>

    <h2>Get a Quote</h2>
    <p>
      Please leave your contact details and we will get back to you shortly.
    </p>

    <form class="quote-form">
      <input type="text" placeholder="Your Name" required />
      <input type="email" placeholder="Your Email" required />
      <textarea placeholder="Your Message"></textarea>
      <button type="submit">Send Message</button>
    </form>
  </div>
</div>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {

    const modal = document.getElementById('quoteModal');
    const closeOverlay = document.getElementById('closeQuoteModal');
    const closeBtn = document.getElementById('closeQuoteModalBtn');

    // 👉 所有按钮统一控制
    document.querySelectorAll('.quote-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        modal.classList.add('active');
      });
    });

    if (closeOverlay) {
      closeOverlay.addEventListener('click', () => {
        modal.classList.remove('active');
      });
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', () => {
        modal.classList.remove('active');
      });
    }

  });
</script>
