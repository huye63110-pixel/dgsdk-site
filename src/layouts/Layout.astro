        html,
        body {
          max-width: 100%;
          overflow-x: clip;
        }

        .products-overview-section,
        .category-info-block {
          background: #f5f6f8;
          overflow-x: clip;
        }

        .products-overview-section {
          padding-top: 28px !important;
          padding-bottom: 56px !important;
        }

        .products-overview-section .container,
        .category-info-block .container {
          width: 100%;
          max-width: 100%;
          padding-left: 12px !important;
          padding-right: 12px !important;
        }

        .products-overview-layout,
        .products-sidebar,
        .products-sidebar-box,
        .products-main,
        .apple-product-section,
        .apple-product-showcase,
        .apple-card-grid,
        .apple-product-card {
          width: 100% !important;
          min-width: 0;
          max-width: 100%;
        }

        .products-overview-layout {
          display: block !important;
        }

        .products-sidebar {
          margin-bottom: 20px;
        }

        .products-sidebar-box {
          display: flex !important;
          gap: 8px;
          overflow-x: auto;
          padding: 10px !important;
          border-radius: 18px !important;
          background: rgba(255, 255, 255, 0.92);
          box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
        }

        .products-sidebar-box::-webkit-scrollbar {
          display: none;
        }

        .products-sidebar-box h3 {
          display: none !important;
        }

        .products-sidebar-box a {
          flex: 0 0 auto;
          margin: 0 !important;
          padding: 9px 14px !important;
          border-radius: 999px !important;
          font-size: 13px !important;
          line-height: 1.2;
          white-space: nowrap;
        }

        .products-sidebar-box .active-category {
          background: #111827 !important;
          color: #fff !important;
        }

        body:has(.products-overview-section) #mainNav {
          border-bottom: 0 !important;
          box-shadow: none !important;
        }

        body:has(.products-overview-section) main {
          padding-top: 80px !important;
        }

        .products-hero {
          height: auto !important;
          min-height: 320px !important;
