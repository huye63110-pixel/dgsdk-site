            rgba(0, 0, 0, 0.12) 100%
          ) !important;
        }

        .products-hero-inner {
          padding-left: 18px !important;
          padding-right: 18px !important;
          text-align: left !important;
        }

        .products-hero h1 {
          max-width: 11em;
          font-size: clamp(2rem, 8vw, 2.45rem) !important;
          line-height: 1.08 !important;
          margin-bottom: 12px !important;
