---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
const {
  title = "DGSDK | Industrial Automation & Static Control Solutions",
  description = "DGSDK is a professional manufacturer in Dongguan, China, specializing in static elimination systems, industrial cleaning machines, automation equipment, and precision CNC parts.",
  image = "/assets/img/header-bg.webp",
  canonical: _rawCanonical = Astro.url.href,
  noLangAlternates = false,
} = Astro.props;

const base = "https://www.dg-sdk.com";
// Normalize canonical: strip trailing slash for all non-root paths
const _rawPath = new URL(_rawCanonical).pathname;
const canonical = _rawPath === '/' ? _rawCanonical : _rawCanonical.replace(/\/$/, '');
const path = new URL(canonical).pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang for multilingual versions -->
    <link rel="alternate" hreflang="en" href={`${base}${path}`} />
    {!noLangAlternates && <link rel="alternate" hreflang="zh" href={`${base}/zh${path === '/' ? '/' : path}`} />}
    <link rel="alternate" hreflang="x-default" href={`${base}${path}`} />

    <!-- Open Graph (Facebook, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://www.dg-sdk.com${image}`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="DGSDK" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://www.dg-sdk.com${image}`} />

    <!-- Extra SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="DGSDK - Dongguan Shidike Automation Equipment Co., Ltd." />
    <meta name="keywords" content="static eliminator, static elimination system, cleaning machine, CNC parts, precision machined parts, automation equipment, industrial automation, Dongguan, China manufacturer" />

    <!-- Geo targeting -->
    <meta name="geo.region" content="CN-GD" />
    <meta name="geo.placename" content="Dongguan, Guangdong, China" />

    <!-- Performance hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />

    <!-- Inter font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Critical CSS -->
    <link rel="stylesheet" href="/css/styles.css" />
    <style is:global>
