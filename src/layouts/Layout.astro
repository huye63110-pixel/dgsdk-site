          line-height: 1.65 !important;
          margin-left: 0 !important;
          margin-right: 0 !important;
        }

        .apple-product-section {
          margin-bottom: 32px !important;
        }

        .apple-card-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
          gap: 12px !important;
        }

        .apple-product-showcase {
          grid-template-columns: minmax(0, 1fr) !important;
          gap: 18px !important;
          min-height: 0 !important;
          margin-bottom: 18px !important;
          padding: 28px 20px 24px !important;
          border-radius: 24px !important;
          background: #fff !important;
          box-shadow: 0 16px 38px rgba(15, 23, 42, 0.08) !important;
          text-align: left !important;
        }

        .apple-product-copy {
          text-align: left !important;
        }

        .apple-product-copy h2 {
          font-size: 1.55rem !important;
          line-height: 1.12 !important;
          margin-bottom: 12px !important;
        }

        .apple-product-copy p {
          font-size: 0.94rem !important;
          line-height: 1.7 !important;
          margin-bottom: 16px !important;
        }

        .apple-product-actions {
          justify-content: flex-start !important;
        }

        .apple-product-visual {
          max-width: 100% !important;
          min-height: 170px;
        }

        .apple-product-visual img {
          width: 100% !important;
          height: 190px !important;
          object-fit: contain !important;
        }

        .apple-product-card h3,
        .apple-product-card p,
        .apple-card-tag,
        .products-hero h1,
        .products-hero p {
          overflow-wrap: anywhere;
        }

        .apple-product-card {
          min-height: 226px;
          padding: 12px !important;
          border-radius: 18px !important;
          background: #fff !important;
          box-shadow: 0 10px 26px rgba(15, 23, 42, 0.08) !important;
        }

        .apple-product-card img {
          height: 112px !important;
          margin-bottom: 12px !important;
          object-fit: contain !important;
        }

        .apple-card-tag {
          margin-bottom: 8px !important;
        }

        .apple-product-card h3 {
          font-size: 14px !important;
          line-height: 1.25 !important;
        }

        .floating-social {
          right: 8px !important;
          bottom: 18px !important;
          gap: 7px !important;
        }

        .floating-social .float-btn {
          width: 38px !important;
          height: 38px !important;
          font-size: 15px !important;
        }

        body:has(.products-overview-section) .floating-social {
          left: 50% !important;
          right: auto !important;
          bottom: 10px !important;
          flex-direction: row !important;
          gap: 6px !important;
          padding: 6px !important;
          border-radius: 999px;
          background: rgba(17, 24, 39, 0.72);
          box-shadow: 0 14px 34px rgba(15, 23, 42, 0.24);
          backdrop-filter: blur(12px);
          transform: translateX(-50%) !important;
        }

        body:has(.products-overview-section) .float-social-group {
          flex-direction: row !important;
          gap: 6px !important;
        }

        body:has(.products-overview-section) .floating-social .float-btn {
          width: 34px !important;
          height: 34px !important;
          font-size: 14px !important;
          box-shadow: none !important;
        }

        .products-overview-section [data-aos="fade-left"],
        .products-overview-section [data-aos="fade-right"] {
          transform: none !important;
        }
      }
    </style>

