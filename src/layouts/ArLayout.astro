---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
const {
  title = "DGSDK | حلول الأتمتة الصناعية وإزالة الكهرباء الساكنة",
  description = "DGSDK شركة مصنعة متخصصة في دونغقوان، الصين، تتخصص في أنظمة إزالة الكهرباء الساكنة، آلات التنظيف الصناعية، معدات الأتمتة وقطع CNC الدقيقة.",
  image = "/assets/img/header-bg.webp",
  canonical: _rawCanonical = Astro.url.href
} = Astro.props;
const _segments = new URL(_rawCanonical).pathname.split('/').filter(Boolean);
const canonical = _segments.length > 1 ? _rawCanonical.replace(/\/$/, '') : _rawCanonical;
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="ar" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical.replace('/ar', '')} />
    <link rel="alternate" hreflang="zh" href={canonical.replace('/ar', '/zh')} />
    <link rel="alternate" hreflang="vi" href={canonical.replace('/ar', '/vi')} />
    <link rel="alternate" hreflang="ja" href={canonical.replace('/ar', '/ja')} />
    <link rel="alternate" hreflang="ko" href={canonical.replace('/ar', '/ko')} />
    <link rel="alternate" hreflang="es" href={canonical.replace('/ar', '/es')} />
    <link rel="alternate" hreflang="x-default" href={canonical.replace('/ar', '')} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://www.dg-sdk.com${image}`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="DGSDK" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://www.dg-sdk.com${image}`} />

    <!-- SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="DGSDK - 东莞史帝克自动化设备有限公司" />
    <meta name="keywords" content="إزالة الكهرباء الساكنة, آلات التنظيف الصناعية, قطع CNC دقيقة, معدات الأتمتة, مصنع دونغقوان" />
    <meta name="geo.region" content="CN-GD" />
    <meta name="geo.placename" content="Dongguan, Guangdong, China" />

    <!-- Bootstrap RTL -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="/css/styles.css" />
    <!-- Performance hints -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <!-- Font Awesome: deferred (non-render-blocking) -->
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" /></noscript>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": ["Organization", "LocalBusiness"],
      "name": "DGSDK",
      "alternateName": "东莞史帝克自动化设备有限公司",
      "url": "https://www.dg-sdk.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.dg-sdk.com/logo.png",
        "width": 600,
        "height": 169
      },
      "description": "شركة مصنعة متخصصة في أنظمة إزالة الكهرباء الساكنة، آلات التنظيف الصناعية، معدات الأتمتة وقطع CNC الدقيقة.",
      "foundingDate": "2013",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "33 Binhai Road",
        "addressLocality": "Dongguan",
        "addressRegion": "Guangdong",
        "postalCode": "523000",
        "addressCountry": "CN"
      },
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "telephone": "+86-13602342003",
          "contactType": "sales",
          "availableLanguage": ["English", "Chinese", "Arabic"],
          "areaServed": "Worldwide"
        }
      ],
      "email": "huye63110@gmail.com"
    }
    </script>
  </head>

  <body id="page-top">
    <!-- شريط التنقل -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
      <div class="container">
