---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
const {
  title = "DGSDK | 産業用自動化・静電気除去ソリューション",
  description = "DGSDKは中国東莞を拠点とする専門メーカーで、静電気除去システム、産業用洗浄機、自動化設備、精密CNC部品を専門としています。",
  image = "/assets/img/header-bg.webp",
  canonical: _rawCanonical = Astro.url.href
} = Astro.props;
const _segments = new URL(_rawCanonical).pathname.split('/').filter(Boolean);
const canonical = _segments.length > 1 ? _rawCanonical.replace(/\/$/, '') : _rawCanonical;
---

<!DOCTYPE html>
<html lang="ja" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="ja" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical.replace('/ja', '')} />
    <link rel="alternate" hreflang="zh" href={canonical.replace('/ja', '/zh')} />
    <link rel="alternate" hreflang="vi" href={canonical.replace('/ja', '/vi')} />
    <link rel="alternate" hreflang="ar" href={canonical.replace('/ja', '/ar')} />
    <link rel="alternate" hreflang="ko" href={canonical.replace('/ja', '/ko')} />
    <link rel="alternate" hreflang="es" href={canonical.replace('/ja', '/es')} />
    <link rel="alternate" hreflang="x-default" href={canonical.replace('/ja', '')} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://www.dg-sdk.com${image}`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="DGSDK" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://www.dg-sdk.com${image}`} />

    <!-- SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="DGSDK - 东莞史帝克自动化设备有限公司" />
    <meta name="keywords" content="静電気除去, 産業用洗浄機, 精密CNC部品, 自動化設備, 東莞メーカー" />
    <meta name="geo.region" content="CN-GD" />
    <meta name="geo.placename" content="Dongguan, Guangdong, China" />

    <link rel="stylesheet" href="/css/styles.css" />
    <!-- Performance hints -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <!-- Font Awesome: deferred (non-render-blocking) -->
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" /></noscript>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": ["Organization", "LocalBusiness"],
      "name": "DGSDK",
      "alternateName": "东莞史帝克自动化设备有限公司",
      "url": "https://www.dg-sdk.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.dg-sdk.com/logo.png",
        "width": 600,
        "height": 169
      },
      "description": "静電気除去システム、産業用洗浄機、自動化設備、精密CNC部品の専門メーカー。",
      "foundingDate": "2013",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "滨海路33号",
        "addressLocality": "东莞",
        "addressRegion": "广东",
        "postalCode": "523000",
        "addressCountry": "CN"
      },
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "telephone": "+86-13602342003",
          "contactType": "sales",
          "availableLanguage": ["English", "Chinese", "Japanese"],
          "areaServed": "Worldwide"
        }
      ],
      "email": "dgsdk2013@gmail.com"
    }
    </script>
  </head>

  <body id="page-top">
    <!-- ナビゲーション -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
      <div class="container">
        <a class="navbar-brand" href="/ja/">
          <img src="/logo.png" alt="DGSDK Logo" width="200" height="56" loading="eager" />
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarResponsive"
          aria-controls="navbarResponsive"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          メニュー <i class="fas fa-bars ms-1"></i>
        </button>
        <div class="collapse navbar-collapse" id="navbarResponsive">
          <ul class="navbar-nav text-uppercase ms-auto py-4 py-lg-0">
            <li class="nav-item"><a class="nav-link" href="/ja/">ホーム</a></li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="/ja/products" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">製品</a>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/ja/products">すべての製品</a></li>
                <li><a class="dropdown-item" href="/ja/products/static-eliminator">静電気除去システム</a></li>
                <li><a class="dropdown-item" href="/ja/products/cleaning-machine">産業用洗浄機</a></li>
                <li><a class="dropdown-item" href="/ja/products/precision-machined-parts">精密加工部品</a></li>
                <li><a class="dropdown-item" href="/ja/products/automation">自動化設備</a></li>
              </ul>
            </li>
            <li class="nav-item"><a class="nav-link" href="/ja/applications">応用分野</a></li>
            <li class="nav-item"><a class="nav-link" href="/ja/about">会社概要</a></li>
            <li class="nav-item"><a class="nav-link" href="/ja/contact">お問い合わせ</a></li>
            <li class="nav-item"><a class="nav-link" href="/ja/faq">よくある質問</a></li>

            <li class="nav-item lang-dropdown" id="langDropdown">
              <button class="nav-link lang-btn" type="button" id="langToggle" aria-label="言語を選択" aria-expanded="false">
                JP <i class="fas fa-chevron-down"></i>
              </button>
              <ul class="lang-menu" id="langMenu">
                <li><a href="/">English</a></li>
                <li><a href="/zh/">中文</a></li>
                <li><a href="/vi/">Tiếng Việt</a></li>
                <li><a href="/ar/">العربية</a></li>
                <li><a href="/ja/">日本語</a></li>
                <li><a href="/ko/">한국어</a></li>
                <li><a href="/es/">Español</a></li>
              </ul>
            </li>

            <li class="nav-item nav-icon-item search-dropdown" id="searchDropdown">
              <button class="nav-link nav-icon-btn" type="button" id="searchToggle" aria-label="製品を検索" aria-expanded="false">
                <i class="fas fa-search"></i>
              </button>
              <div class="search-box" id="searchBox">
                <input type="text" placeholder="製品を検索..." autocomplete="off" />
              </div>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main style="padding-top: 110px;">
      <slot />
    </main>

    <!-- フローティングソーシャルボタン -->
    <div class="floating-social">
      <a href="mailto:dgsdk2013@gmail.com" target="_blank" rel="noopener noreferrer" aria-label="Email" class="float-btn email">
        <i class="fas fa-envelope"></i>
      </a>
      <a href="https://wa.me/61436605126?text=こんにちは、製品に興味があります" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="float-btn whatsapp">
        <i class="fab fa-whatsapp"></i>
      </a>
      <a href="https://www.tiktok.com/@machineforge?_r=1&_t=ZS-95scfOHz6Ea" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="float-btn tiktok">
        <i class="fab fa-tiktok"></i>
      </a>
      <a href="https://www.facebook.com/yourcompany" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="float-btn facebook">
        <i class="fab fa-facebook-f"></i>
      </a>
      <a href="#page-top" aria-label="トップへ戻る" class="float-btn top">
        <i class="fas fa-arrow-up"></i>
      </a>
    </div>

    <!-- フッター -->
    <footer class="site-footer">
      <div class="footer-container">
        <div class="footer-col footer-brand">
          <img src="/logo.png" alt="DGSDK Logo" width="180" height="50" class="footer-logo" loading="lazy" />
          <p>DGSDKは中国広東省東莞市を拠点とする専門メーカーで、静電気除去システム、産業用洗浄機、自動化設備、精密CNC部品を専門に製造しています。</p>
        </div>
        <div class="footer-col">
          <h4>クイックリンク</h4>
          <a href="/ja/">ホーム</a>
          <a href="/ja/applications">応用分野</a>
          <a href="/ja/about">会社概要</a>
          <a href="/ja/contact">お問い合わせ</a>
          <a href="/ja/faq">よくある質問</a>
        </div>
        <div class="footer-col">
          <h4>製品</h4>
          <a href="/ja/products/static-eliminator">静電気除去システム</a>
          <a href="/ja/products/cleaning-machine">産業用洗浄機</a>
          <a href="/ja/products/precision-machined-parts">精密加工部品</a>
          <a href="/ja/products/automation">自動化設備</a>
        </div>
        <div class="footer-col">
          <h4>連絡先</h4>
          <p>電話：+86 13602342003</p>
          <p>WhatsApp：+61 436605126</p>
          <p>メール：dgsdk2013@gmail.com</p>
          <p>住所：中国広東省東莞市濱海路33号</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 DGSDK. All rights reserved. <a href="/privacy" style="color:rgba(255,255,255,0.5);text-decoration:none;margin-left:12px;">Privacy Policy</a></p>
      </div>
    </footer>

    <!-- お見積もりモーダル -->
    <div class="quote-modal" id="quoteModal">
      <div class="quote-modal-overlay" id="closeQuoteModal"></div>
      <div class="quote-modal-content">
        <button class="quote-modal-close" id="closeQuoteModalBtn" type="button" aria-label="見積フォームを閉じる">×</button>
        <h2>お見積もり</h2>
        <p>お問い合わせ内容をご記入ください。営業時間内に折り返しご連絡いたします。</p>
        <form class="quote-form" id="quoteFormMain">
          <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />
          <input type="text" placeholder="お名前" required />
          <input type="email" placeholder="メールアドレス" required />
          <textarea placeholder="メッセージ"></textarea>
          <button type="submit">送信する</button>
        </form>
      </div>
    </div>

    <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script is:inline src="/js/scripts.js"></script>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('quoteModal');
        const closeOverlay = document.getElementById('closeQuoteModal');
        const closeBtn = document.getElementById('closeQuoteModalBtn');
        const form = document.getElementById('quoteFormMain');

        document.querySelectorAll('.quote-btn').forEach(btn => {
          btn.addEventListener('click', () => modal.classList.add('active'));
        });
        if (closeOverlay) closeOverlay.addEventListener('click', () => modal.classList.remove('active'));
        if (closeBtn) closeBtn.addEventListener('click', () => modal.classList.remove('active'));

        if (form) {
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            const honeypot = form.querySelector('input[name="website"]');
            if (honeypot && honeypot.value !== '') return;
            alert('メッセージを送信しました。折り返しご連絡いたします。');
            modal.classList.remove('active');
            form.reset();
          });
        }
      });
    </script>

    <Analytics />
    <SpeedInsights />
  </body>
</html>
