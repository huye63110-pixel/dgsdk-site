---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
const {
  title = "DGSDK | 工业自动化与静电消除解决方案",
  description = "东莞史帝克自动化设备有限公司，专业生产静电消除器、工业清洁机、自动化设备和精密CNC零件。",
  image = "/assets/img/header-bg.webp",
  canonical = Astro.url.href
} = Astro.props;
---

<!DOCTYPE html>
<html lang="zh" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="zh" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical.replace('/zh', '')} />
    <link rel="alternate" hreflang="x-default" href={canonical.replace('/zh', '')} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://www.dg-sdk.com${image}`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="DGSDK 史帝克" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://www.dg-sdk.com${image}`} />

    <!-- SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="DGSDK - 东莞史帝克自动化设备有限公司" />
    <meta name="keywords" content="静电消除器, 静电消除系统, 工业清洁机, 精密CNC零件, 自动化设备, 工业自动化, 东莞制造商, 史帝克" />
    <meta name="geo.region" content="CN-GD" />
    <meta name="geo.placename" content="Dongguan, Guangdong, China" />

    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": ["Organization", "LocalBusiness"],
      "name": "DGSDK",
      "alternateName": "东莞史帝克自动化设备有限公司",
      "url": "https://www.dg-sdk.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.dg-sdk.com/logo.png",
        "width": 600,
        "height": 169
      },
      "description": "专业生产静电消除系统、工业清洁机、自动化设备和精密CNC零件。",
      "foundingDate": "2013",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "滨海路33号",
        "addressLocality": "东莞",
        "addressRegion": "广东",
        "postalCode": "523000",
        "addressCountry": "CN"
      },
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "telephone": "+86-13602342003",
          "contactType": "sales",
          "availableLanguage": ["English", "Chinese"],
          "areaServed": "Worldwide"
        }
      ],
      "email": "huye63110@gmail.com"
    }
    </script>
  </head>

  <body id="page-top">
    <!-- 导航栏 -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
      <div class="container">
        <a class="navbar-brand" href="/zh/">
          <img src="/logo.png" alt="DGSDK Logo" loading="lazy" />
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarResponsive"
          aria-controls="navbarResponsive"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          菜单 <i class="fas fa-bars ms-1"></i>
        </button>
        <div class="collapse navbar-collapse" id="navbarResponsive">
          <ul class="navbar-nav text-uppercase ms-auto py-4 py-lg-0">
            <li class="nav-item"><a class="nav-link" href="/zh/">首页</a></li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="/zh/products" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">产品</a>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/zh/products">所有产品</a></li>
                <li><a class="dropdown-item" href="/zh/products/static-eliminator">静电消除系统</a></li>
                <li><a class="dropdown-item" href="/zh/products/cleaning-machine">清洁机</a></li>
                <li><a class="dropdown-item" href="/zh/products/precision-machined-parts">精密加工零件</a></li>
                <li><a class="dropdown-item" href="/zh/products/automation">自动化设备</a></li>
              </ul>
            </li>
            <li class="nav-item"><a class="nav-link" href="/zh/applications">应用领域</a></li>
            <li class="nav-item"><a class="nav-link" href="/zh/about">关于我们</a></li>
            <li class="nav-item"><a class="nav-link" href="/zh/contact">联系我们</a></li>
            <li class="nav-item"><a class="nav-link" href="/zh/faq">常见问题</a></li>

            <li class="nav-item lang-dropdown" id="langDropdown">
              <button class="nav-link lang-btn" type="button" id="langToggle">
                中文 <i class="fas fa-chevron-down"></i>
              </button>
              <ul class="lang-menu" id="langMenu">
                <li><a href="/">English</a></li>
                <li><a href="/zh/">中文</a></li>
                <li><a href="/vi/">Tiếng Việt</a></li>
                <li><a href="/ar/">العربية</a></li>
                <li><a href="/ja/">日本語</a></li>
                <li><a href="/ko/">한국어</a></li>
                <li><a href="/es/">Español</a></li>
              </ul>
            </li>

            <li class="nav-item nav-icon-item search-dropdown" id="searchDropdown">
              <button class="nav-link nav-icon-btn" type="button" id="searchToggle">
                <i class="fas fa-search"></i>
              </button>
              <div class="search-box" id="searchBox">
                <input type="text" placeholder="搜索产品..." autocomplete="off" />
              </div>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main style="padding-top: 110px;">
      <slot />
    </main>

    <!-- 悬浮社交按钮 -->
    <div class="floating-social">
      <a href="mailto:huye63110@gmail.com" target="_blank" rel="noopener noreferrer" aria-label="Email" class="float-btn email">
        <i class="fas fa-envelope"></i>
      </a>
      <a href="https://wa.me/61436605126?text=您好，我对您的产品感兴趣" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="float-btn whatsapp">
        <i class="fab fa-whatsapp"></i>
      </a>
      <a href="https://www.linkedin.com/in/henry-hu-0ba80737a" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="float-btn linkedin">
        <i class="fab fa-linkedin-in"></i>
      </a>
      <a href="https://www.tiktok.com/@machingmasters" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="float-btn tiktok">
        <i class="fab fa-tiktok"></i>
      </a>
      <a href="https://www.instagram.com/ls_machiningmasters" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="float-btn instagram">
        <i class="fab fa-instagram"></i>
      </a>
      <a href="https://youtube.com/@machiningmasters01" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="float-btn youtube">
        <i class="fab fa-youtube"></i>
      </a>
      <a href="https://www.facebook.com/yourcompany" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="float-btn facebook">
        <i class="fab fa-facebook-f"></i>
      </a>
      <a href="#page-top" aria-label="返回顶部" class="float-btn top">
        <i class="fas fa-arrow-up"></i>
      </a>
    </div>

    <!-- 页脚 -->
    <footer class="site-footer">
      <div class="footer-container">
        <div class="footer-col footer-brand">
          <img src="/logo.png" alt="DGSDK Logo" class="footer-logo" loading="lazy" />
          <p>DGSDK（东莞史帝克自动化设备有限公司）是专业制造商，专注于静电消除系统、工业清洁机、自动化设备和精密CNC零件。</p>
        </div>
        <div class="footer-col">
          <h4>快速链接</h4>
          <a href="/zh/">首页</a>
          <a href="/zh/applications">应用领域</a>
          <a href="/zh/about">关于我们</a>
          <a href="/zh/contact">联系我们</a>
          <a href="/zh/faq">常见问题</a>
        </div>
        <div class="footer-col">
          <h4>产品</h4>
          <a href="/zh/products/static-eliminator">静电消除器</a>
          <a href="/zh/products/cleaning-machine">清洁机</a>
          <a href="/zh/products/precision-machined-parts">精密加工零件</a>
          <a href="/zh/products/automation">自动化设备</a>
        </div>
        <div class="footer-col">
          <h4>联系方式</h4>
          <p>电话：+86 13602342003</p>
          <p>WhatsApp：+61 436605126</p>
          <p>邮箱：huye63110@gmail.com</p>
          <p>地址：广东省东莞市滨海路33号</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 DGSDK 版权所有 <a href="/privacy" style="color:rgba(255,255,255,0.5);text-decoration:none;margin-left:12px;">隐私政策</a></p>
      </div>
    </footer>

    <!-- 全局报价弹窗 -->
    <div class="quote-modal" id="quoteModal">
      <div class="quote-modal-overlay" id="closeQuoteModal"></div>
      <div class="quote-modal-content">
        <button class="quote-modal-close" id="closeQuoteModalBtn">×</button>
        <h2>获取报价</h2>
        <p>请留下您的联系方式，我们将尽快与您联系。</p>
        <form class="quote-form" id="quoteFormMain">
          <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />
          <input type="text" placeholder="您的姓名" required />
          <input type="email" placeholder="您的邮箱" required />
          <textarea placeholder="您的留言"></textarea>
          <button type="submit">发送留言</button>
        </form>
      </div>
    </div>

    <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script is:inline src="/js/scripts.js"></script>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('quoteModal');
        const closeOverlay = document.getElementById('closeQuoteModal');
        const closeBtn = document.getElementById('closeQuoteModalBtn');
        const form = document.getElementById('quoteFormMain');

        document.querySelectorAll('.quote-btn').forEach(btn => {
          btn.addEventListener('click', () => modal.classList.add('active'));
        });
        if (closeOverlay) closeOverlay.addEventListener('click', () => modal.classList.remove('active'));
        if (closeBtn) closeBtn.addEventListener('click', () => modal.classList.remove('active'));

        if (form) {
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            const honeypot = form.querySelector('input[name="website"]');
            if (honeypot && honeypot.value !== '') return;
            alert('留言已发送！我们将尽快与您联系。');
            modal.classList.remove('active');
            form.reset();
          });
        }
      });
    </script>

    <Analytics />
    <SpeedInsights />
  </body>
</html>
